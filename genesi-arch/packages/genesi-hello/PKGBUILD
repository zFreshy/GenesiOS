# Maintainer: Genesi OS Team
# Based on cachyos-hello by CachyOS team

_gitname=genesi-welcome
pkgname=genesi-hello
pkgver=1.0.0
pkgrel=2
pkgdesc='Welcome screen for Genesi OS'
arch=('x86_64')
groups=('genesi')
license=('GPL-3.0-or-later')
url='https://github.com/zFreshy/genesi-welcome'
depends=(
  glib2
  gtk3
  pciutils
  procps-ng
  'libusb-1.0.so'
)
makedepends=(
  cargo
  clang
  git
  lld
  llvm
  meson
)
provides=('cachyos-hello')
conflicts=('cachyos-hello')
source=("git+https://github.com/zFreshy/genesi-welcome.git")
sha512sums=('SKIP')

prepare() {
  cd "${srcdir}/${_gitname}"
  
  # Replace CachyOS branding with Genesi
  find . -type f -not -path "./.git/*" -exec sed -i 's/CachyOS/Genesi OS/g' {} + 2>/dev/null || true
  find . -type f -not -path "./.git/*" -exec sed -i 's/cachyos/genesi/g' {} + 2>/dev/null || true
  
  # Rename desktop file if it exists
  if [ -f "cachyos-hello.desktop" ]; then
    sed -i 's/cachyos-hello/genesi-hello/g' cachyos-hello.desktop
    sed -i 's/CachyOS/Genesi OS/g' cachyos-hello.desktop
  fi
}

build() {
  cd "${srcdir}/${_gitname}"

  # Compile with clang
  export AR=llvm-ar
  export CC=clang
  export CXX=clang++
  export NM=llvm-nm
  export RANLIB=llvm-ranlib

  export RUSTFLAGS="-Cembed-bitcode -C opt-level=3 -Ccodegen-units=1 -Clinker=clang -C link-arg=-flto -Clink-arg=-fuse-ld=/usr/bin/ld.lld"

  meson setup --buildtype=release --prefix=/usr build
  meson compile -C build
}

package() {
  cd "${srcdir}/${_gitname}"

  # Compile with clang
  export AR=llvm-ar
  export CC=clang
  export CXX=clang++
  export NM=llvm-nm
  export RANLIB=llvm-ranlib

  export RUSTFLAGS="-Cembed-bitcode -C opt-level=3 -Ccodegen-units=1 -Clinker=clang -C link-arg=-flto -Clink-arg=-fuse-ld=/usr/bin/ld.lld"
  
  DESTDIR="${pkgdir}" meson install -C build

  # Install autostart
  if [ -f "cachyos-hello.desktop" ]; then
    install -Dm644 cachyos-hello.desktop \
      "$pkgdir/etc/skel/.config/autostart/genesi-hello.desktop"
  fi
}
