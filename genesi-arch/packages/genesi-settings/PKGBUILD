# Maintainer: Genesi OS Team <dev@genesios.org>
# Based on cachyos-settings by CachyOS team

pkgname=genesi-settings
pkgver=1.1.0
pkgrel=1
epoch=1
groups=(genesi)
pkgdesc='Genesi OS system settings and branding'
arch=('any')
url='https://github.com/zFreshy/GenesiOS'
license=('GPL-3.0-or-later')
depends=(
  zram-generator
  ananicy-cpp
  cachyos-ananicy-rules
  inxi
  "systemd>=256"
  iw
  wireless-regdb
)
optdepends=('libluv: for topmem'
            'lua-luv: for topmem'
            'power-profiles-daemon: For game-performance')
provides=('cachyos-settings' 'ntsync-common')
conflicts=('cachyos-settings')

package() {
    # Copy all etc files
    install -d "$pkgdir/etc"
    cp -rf "$srcdir/etc" "$pkgdir/" 2>/dev/null || true
    
    # Copy all usr files
    install -d "$pkgdir/usr"
    cp -rf "$srcdir/usr" "$pkgdir/" 2>/dev/null || true
    
    # Override with Genesi branding
    install -Dm644 "$srcdir/os-release" "$pkgdir/etc/os-release" 2>/dev/null || true
    install -Dm644 "$srcdir/lsb-release" "$pkgdir/etc/lsb-release" 2>/dev/null || true
    install -Dm644 "$srcdir/issue" "$pkgdir/etc/issue" 2>/dev/null || true
    install -Dm644 "$srcdir/hostname" "$pkgdir/etc/hostname" 2>/dev/null || true
}
