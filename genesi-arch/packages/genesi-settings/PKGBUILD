# Maintainer: Genesi OS Team
# Based on CachyOS-Settings by Peter Jung

_gitname=genesi-settings-full
pkgname=genesi-settings
pkgver=1.3.4
pkgrel=3
epoch=1
groups=(genesi)
arch=('any')
license=(GPL-1.0-only)
makedepends=('coreutils')
pkgdesc='Genesi OS - System Settings'
url="https://github.com/zFreshy/GenesiOS"
source=()
sha256sums=()
depends=(
  zram-generator
  ananicy-cpp
  cachyos-ananicy-rules
  inxi
  "systemd>=256"
  iw
  wireless-regdb
)
optdepends=('libluv: for topmem'
            'lua-luv: for topmem'
            'power-profiles-daemon: For game-performance')
provides=('ntsync-common' 'cachyos-settings')
conflicts=('cachyos-settings')

package() {
  # Copy from the cloned genesi-settings-full directory
  install -d "$pkgdir/etc"
  cp -rf "${startdir}/../../../genesi-settings-full/etc" "$pkgdir"
  install -d "$pkgdir/usr"
  cp -rf "${startdir}/../../../genesi-settings-full/usr" "$pkgdir"
  
  # Replace all CachyOS references with Genesi OS
  find "$pkgdir" -type f -exec sed -i 's/CachyOS/Genesi OS/g' {} + 2>/dev/null || true
  find "$pkgdir" -type f -exec sed -i 's/cachyos/genesi/g' {} + 2>/dev/null || true
}
