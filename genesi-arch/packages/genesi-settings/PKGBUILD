# Maintainer: Genesi OS Team
# Based on CachyOS-Settings by Peter Jung

_gitname=genesi-settings
pkgname=genesi-settings
pkgver=1.3.4
# 2026-05-30: bumped 22 -> 23 for genesi-apply-theme.sh restarting
# plasmashell after the layout JS runs. The popupHeight=300/popupWidth=450
# from v22 was correctly written to the appletsrc but plasmashell kept
# its cached in-memory size from when the panel was first built (before
# the JS rewrote the values), so the Kickoff popup still rendered at the
# Plasma default oversize. Manual `kquitapp6 plasmashell && kstart
# plasmashell` confirmed live as the fix; the script now uses the atomic
# `plasmashell --replace` equivalent.
# 2026-06-01: bumped 23 -> 24 for the genesi-apply-theme.sh qdbus6 fix — the
# floating-panel/layout step called `qdbus`, which doesn't exist on Plasma 6,
# so it silently no-op'd on installed systems. Bump forces pacman to ship it.
# 2026-06-01 (25): blue window backgrounds + blue titlebar/outline in the
# Genesi color scheme & klassyrc (kept the green accent). See submodule.
# 2026-06-01 (26): ship [Effect-blur] (Better Blur) with Saturation=127 — the
# effect defaulted to 255 (max) and over-saturated the glass titlebar green.
# 2026-06-01 (27): fix the AI Mode panel button — the .desktop now writes the
# daemon force file at /run/genesi-ai-mode/force (was /tmp, unreachable under
# the daemon's PrivateTmp). Needs a pkgrel bump so clients actually pull it.
# 2026-06-02 (28): AI Mode button must never hang. notify-send blocked ~25s
# when org.freedesktop.Notifications was unavailable, so the toggle felt dead
# even though it wrote the force file. Fire notify-send detached, with a 3s
# timeout, output suppressed — the mode flips instantly regardless.
# 2026-06-02 (29): fix system-wide notifications. genesi-apply-theme.sh ran
# genesi-layout.js which rebuilt the panel from scratch; the script-built
# systemtray never loaded the notifications applet, so org.freedesktop.
# Notifications was never registered (no notify popups at all — update icon
# missing, AI Mode toasts dead). Dropped the layout rebuild; the static skel
# appletsrc already has floating panel + sized Kickoff + a tray with
# shownItems=notifications. New installs now get a working notification server.
# 2026-06-03 (30): add the Genesi AI Mode widget (org.genesi.aimode) to the
# default panel appletsrc (applet 32, next to the AI Mode launcher). Static
# config edit only — systemtray untouched. Rebuild to pull the new skel.
# 2026-06-16 (31): ship the flicker-free first-login theming. genesi-apply-theme
# .sh no longer restarts kwin/plasmashell (the "2 piscadas" + wallpaper fade);
# it reloads in place. ALSO fixes selected-item contrast: skel kdeglobals
# [Colors:Selection] had bright-green bg + dark text (so selected text/icons
# went near-black and vanished); now it matches the Genesi.colors scheme —
# solid brand green (29,158,117) with white text. Both are pure skel changes,
# so the package version MUST bump or `pacman -Syu` won't deliver them.
# 2026-06-17 (32): the pkgrel-31 skel fix only reaches NEW users — an existing
# ~/.config/kdeglobals keeps its old dark [Colors:Selection] foreground, so
# systems installed before 31 still show near-black selected text (e.g. the
# Package Installer). genesi-apply-theme.sh can't help (self-deletes; and
# plasma-apply-colorscheme is a no-op once "Genesi" is active). Wire the
# package install scriptlet (it was never referenced -> never ran) and add a
# post_upgrade that forces the selection foregrounds to white per existing
# user, so the fix reaches already-installed systems on `pacman -Syu`.
# 2026-06-18 (33): add the Genesi Containers widget (org.genesi.containers) to
# the default panel appletsrc (applet 33, next to the AI Mode widget 32). Static
# skel config edit only — systemtray untouched. The plasmoid ships in the
# always-on genesi-containers package (genesi-desktop meta), so the reference
# always resolves. Pure skel change, so the package version MUST bump or new
# installs won't get the widget on their panel. ALSO hardens the readable-
# selection guarantee: genesi-apply-theme.sh now force-writes white
# [Colors:Selection] foregrounds on every new user's first login, so a fresh
# install can never come up with the near-black selected text again (third
# layer on top of the skel kdeglobals + Genesi.colors scheme).
# pkgrel 34: paint buttons the Genesi blue, not grey. Genesi.colors had
# [Colors:Button] BackgroundNormal=44,44,42 (grey) while Window/View were the
# brand blue, so every button stood out as off-theme; now blue (20,49,69). The
# post_upgrade scriptlet also heals already-installed users' kdeglobals. Bumps
# the submodule pointer (Genesi.colors lives there).
# pkgrel 35: make the Genesi Containers widget reach EXISTING users' panels. The
# pkgrel-33 appletsrc only adds org.genesi.containers (applet 33) for NEW users;
# an already-installed user keeps the panel plasmashell built at their first
# login, so the widget (shipped via the genesi-desktop meta) sat dormant in
# /usr/share/plasma/plasmoids and never appeared on the panel. Add a one-shot
# per-user migration: genesi-panel-migrate.sh + its autostart (in usr/share/
# genesi/migrate, NOT skel, so new users — already correct — don't re-run it).
# The post_upgrade scriptlet drops the autostart into each existing user's
# ~/.config/autostart; on next login it adds the widget to the live panel via
# plasmashell scripting (idempotent, marker-guarded, self-removing). Bumps the
# submodule pointer (the script + .desktop live there).
# pkgrel 36: uniform titlebar. The Klassy titlebar was pinned to 70% opacity over
# a ~78% window body, so it floated visibly lighter. The skel now sets
# OverrideTitleBarOpacity=false (the titlebar inherits the system [WM] colour,
# whose alpha is matched to the body) and unifies the inactive titlebar/outline,
# so titlebar and body are one shade. The window body, blur and translucency
# effect are LEFT UNTOUCHED — normal-mode glass is exactly as before; AI Mode
# reaches full opacity separately via genesi-ai-mode's opaque-scheme swap. Skel
# only reaches NEW users, so the .install gains fix_titlebar_uniformity to heal
# existing users' klassyrc/[WM] on upgrade (effective next login). Bumps the
# submodule pointer (the seeded configs live there).
# pkgrel 37: windows are now painted fully OPAQUE (color scheme + kdeglobals lose
# all alpha) and the glass comes solely from the KWin translucency effect. Reason:
# Darkly bakes a window's translucency at CREATION from the scheme alpha, so an
# alpha-carrying scheme could never be made opaque live — AI Mode windows stayed
# see-through. A compositor effect, by contrast, toggles live for every window, so
# AI Mode (helper unloads it) now goes fully opaque on demand. fix_titlebar_
# uniformity extended to strip the alpha from existing users' kdeglobals + tune
# the effect, on upgrade (effective next login). Bumps the submodule pointer.
# pkgrel 38: make the fish default-shell reach EXISTING systems too. fish is now a
# hard dep (it's the userShell new installs get via Calamares) and a new .install
# migration (migrate_default_shell_fish) chsh's users still on the old default
# /bin/bash to /usr/bin/fish on `pacman -Syu` — so CachyOS-style autosuggestions/
# completions appear in konsole/foot without a reinstall. Only /bin/bash users are
# touched (other shells kept); reversible via chsh.
pkgrel=38
epoch=1
groups=(genesi)
arch=('any')
license=(GPL-1.0-only)
makedepends=('coreutils' 'git')
pkgdesc='Genesi OS - System Settings'
url="https://github.com/zFreshy/genesi-settings"
source=("git+https://github.com/zFreshy/genesi-settings.git")
sha256sums=('SKIP')
depends=(
  zram-generator
  ananicy-cpp
  cachyos-ananicy-rules
  inxi
  "systemd>=256"
  iw
  wireless-regdb
  fish          # default interactive shell (the .install migrates existing
                # /bin/bash users to it; new installs set it via Calamares)
)
optdepends=('libluv: for topmem'
            'lua-luv: for topmem'
            'power-profiles-daemon: For game-performance')
provides=('ntsync-common' 'cachyos-settings')
conflicts=('cachyos-settings')
# Scriptlet: enables the perf services on install and, on upgrade, heals the
# selected-item text colour for users created before the readable-selection fix
# (see the .install + the pkgrel-32 note above). This was previously NOT wired,
# so it never ran.
install=cachyos-settings.install

package() {
  # Copy from the git repo
  install -d "$pkgdir/etc"
  cp -rf "${srcdir}/${_gitname}/etc" "$pkgdir"
  install -d "$pkgdir/usr"
  cp -rf "${srcdir}/${_gitname}/usr" "$pkgdir"
  
  # Make the theme applicator + panel migration scripts executable
  chmod +x "$pkgdir/usr/bin/genesi-apply-theme.sh" 2>/dev/null || true
  chmod +x "$pkgdir/usr/bin/genesi-panel-migrate.sh" 2>/dev/null || true
  
  # Replace all CachyOS references with Genesi OS
  find "$pkgdir" -type f -exec sed -i 's/CachyOS/Genesi OS/g' {} + 2>/dev/null || true
  find "$pkgdir" -type f -exec sed -i 's/cachyos/genesi/g' {} + 2>/dev/null || true
}
