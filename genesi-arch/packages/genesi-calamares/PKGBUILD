# Maintainer: Genesi OS Team
# Based on Calamares by CachyOS

_gitname=genesi-calamares
pkgname=genesi-calamares
pkgver=3.3.11
pkgrel=2
pkgdesc='Distribution-independent installer framework - Genesi OS Edition'
arch=('x86_64')
license=(GPL-3.0-or-later)
url="https://github.com/zFreshy/genesi-calamares"
depends=(
    'boost-libs'
    'ckbcomp'
    'efibootmgr'
    'gtk-update-icon-cache'
    'hwinfo'
    'icu'
    'kconfig'
    'kcoreaddons'
    'kcrash'
    'ki18n'
    'kiconthemes'
    'kio'
    'kparts'
    'kpmcore'
    'kservice'
    'kwidgetsaddons'
    'libpwquality'
    'mkinitcpio-openswap'
    'polkit-qt6'
    'python'
    'qt6-svg'
    'qt6-declarative'
    'solid'
    'squashfs-tools'
    'yaml-cpp'
    'genesi-calamares-branding'
)
makedepends=(
    'boost'
    'cmake'
    'extra-cmake-modules'
    'git'
    'python-jsonschema'
    'python-pyaml'
    'python-unidecode'
    'qt6-tools'
    'qt6-translations'
)
provides=('calamares')
conflicts=('calamares' 'calamares-git')
replaces=('calamares')
options=('!lto')
backup=('usr/share/calamares/modules/bootloader.conf'
        'usr/share/calamares/modules/displaymanager.conf'
        'usr/share/calamares/modules/initcpio.conf'
        'usr/share/calamares/modules/unpackfs.conf')

source=("git+https://github.com/zFreshy/genesi-calamares.git")
sha256sums=('SKIP')

prepare() {
    cd "${srcdir}/${_gitname}"
    
    # Replace CachyOS branding with Genesi in source code
    find . -type f \( -name "*.cpp" -o -name "*.h" -o -name "*.qml" -o -name "*.conf" -o -name "*.desc" \) \
        -exec sed -i 's/CachyOS/Genesi OS/g' {} + 2>/dev/null || true
    find . -type f \( -name "*.cpp" -o -name "*.h" -o -name "*.qml" -o -name "*.conf" -o -name "*.desc" \) \
        -exec sed -i 's/cachyos/genesi/g' {} + 2>/dev/null || true
}

build() {
    cd "${srcdir}/${_gitname}"
    
    cmake -S . -Bbuild \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_INSTALL_LIBDIR=lib \
        -DWITH_QT6=ON \
        -DWITH_PYBIND11=OFF \
        -DWITH_PYTHONQT=OFF \
        -DINSTALL_CONFIG=ON \
        -DSKIP_MODULES="dracut dracutlukscfg \
            dummycpp dummyprocess dummypython dummypythonqt \
            finishedq initramfs initramfscfg \
            interactiveterminal keyboardq license localeq \
            notesqml oemid openrcdmcryptcfg \
            packagechooserq partitionq plasmalnf \
            preservefiles rawfs services-openrc \
            summaryq tracking usersq webview welcomeq"
    
    cmake --build build
}

package() {
    cd "${srcdir}/${_gitname}"
    
    DESTDIR="${pkgdir}" cmake --install build
    
    # Update settings to use Genesi branding
    sed -i "s/branding:.*/branding: genesi/" \
        "${pkgdir}/usr/share/calamares/settings.conf"
}
