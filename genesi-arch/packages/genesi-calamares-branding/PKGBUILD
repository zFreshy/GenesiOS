# Maintainer: Genesi OS Team
pkgname=genesi-calamares-branding
pkgver=1.0.0
pkgrel=1
pkgdesc="Genesi OS branding for Calamares installer"
arch=('any')
url="https://github.com/zFreshy/GenesiOS"
license=('GPL3')
depends=(
    'calamares'  # or cachyos-calamares-next
)
provides=('calamares-branding')
conflicts=('cachyos-calamares-branding')
source=()
sha256sums=()

package() {
    # Install Genesi branding for Calamares
    install -dm755 "${pkgdir}/usr/share/calamares/branding/genesi"
    
    # Copy branding files
    cp -r "${srcdir}/../branding/"* "${pkgdir}/usr/share/calamares/branding/genesi/"
    
    # Install Calamares settings to use Genesi branding
    install -Dm644 "settings.conf" "${pkgdir}/etc/calamares/settings.conf"
    
    # Install Calamares modules configuration
    install -dm755 "${pkgdir}/etc/calamares/modules"
    cp -r modules/* "${pkgdir}/etc/calamares/modules/"
}
