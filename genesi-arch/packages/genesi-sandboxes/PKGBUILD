# Maintainer: Genesi OS Team <dev@genesios.org>
#
# Phase 4.4 — Project sandboxes (isolated workspaces). A GUI + CLI on top of
# Distrobox that spins up per-project containers with their own dependencies,
# from ready-made templates (Java + Spring Boot, React + Vite, Python + FastAPI,
# Go, Rust, C/C++). Each workspace is HOME/GUI/terminal-integrated via Distrobox.
pkgname=genesi-sandboxes
pkgver=1.0.0
# pkgrel 2: make it actually work when the backend is Docker, and wire the
# Genesi Code integration. Distrobox now prefers podman (rootless, no group);
# when only docker is present and the GUI's session predates `usermod -aG
# docker`, the CLI runs distrobox under `sg docker` so creation/enter no longer
# die with "permission denied ... docker.sock" (same plasmashell-child group
# gap the containers widget hit). Each workspace also gets a host project folder
# (~/Sandboxes/<name>, shared into the box) and an "Open in Genesi Code" action
# that opens it in the IDE — the deferred 4.4 IDE integration, now shipping.
# pkgrel 3: (1) backend detection is now LAZY — `templates-json` no longer runs
# `docker info`, so a busy docker daemon can't make the template dropdown load
# empty (the "doesn't work" report). (2) Taskbar identity — setDesktopFileName +
# StartupWMClass + a real app icon (cube) so the window shows our name/logo, not
# "python3".
# pkgrel 4: clean up the app icon — drop a stray floating accent stroke on the
# cube's top face; the green accent is now a real cube edge.
# pkgrel 5: fix the permanently-empty template dropdown. The GUI never selected
# Plasma's Qt Quick Controls style, so QQC2 fell back to the Basic style and the
# template ComboBox rendered as a flat accent-green box with unreadable items —
# the "no sandbox option appears" report. genesi_sandboxes.py now sets
# QT_QUICK_CONTROLS_STYLE=org.kde.desktop + QQuickStyle.setStyle (matching the
# AI Mode Monitor), so the dropdown lists the templates and the app picks up the
# Genesi theme. (qqc2-desktop-style is already a hard dependency.)
# pkgrel 6: the empty dropdown's REAL cause (the pkgrel-5 style fix was a wrong
# diagnosis): Main.qml had `property string backend` shadowing the `backend`
# context property (the Python object), so `Connections { target: backend }`
# bound to the empty string — every signal handler (onTemplatesLoaded, ...) was
# dead, so templates never loaded. Renamed it to `containerBackend`. Also fixed
# `wrapMode: TextArea.Wrap` (ReferenceError) -> Text.Wrap and `logArea.length`
# -> `logArea.text.length`. AND: the GUI SIGSEGV'd on launch in a VM (Qt Quick
# RHI/GL crash on VirtualBox/VMware SVGA), so it now falls back to
# QT_QUICK_BACKEND=software when systemd-detect-virt reports a VM (like the
# Monitor).
# pkgrel 7: the pkgrel-5/6 org.kde.desktop style was itself a crash trigger — it
# delegates drawing to Darkly, and Darkly6 SIGSEGVs from QML (null QWidget* in
# drawControl), so the window stopped opening at all. Switched to the Fusion
# QQC2 style (self-drawn, no Darkly, dark via QT_QPA_PLATFORMTHEME=kde): the
# ComboBox renders readable and the app launches. The Main.qml backend-shadow
# fix (real empty-dropdown cause) and the VM software backend stay.
# pkgrel 8: big UX/looks pass.
#  - LOOKS: full visual redesign sharing the AI Mode Monitor's design language
#    (new Theme.qml + GlassCard.qml + GButton.qml + StatusBanner.qml — the pilot
#    of a shared Genesi UI kit). Gradient background, glass cards, branded header,
#    custom-drawn buttons + a template picker dialog (drops the flat Fusion combo).
#  - DOCKER UX: the CLI now tells you what to do instead of leaking distrobox's
#    raw "dial unix /var/run/docker.sock" error. ensure_backend classifies docker
#    as ready / inactive (daemon stopped) / perm (not in group); create/enter
#    abort early with the exact fix; list-json reports backendReady+backendIssue
#    so the GUI shows a banner with a one-click "Start Docker" (pkexec systemctl
#    enable --now docker). podman is now a HARD dep so the rootless, no-daemon
#    backend is always present — sandboxes "just work" with zero setup.
#  - GENESI CODE: openInCode now watches the launch and surfaces the real error
#    if it crashes fast (e.g. no GPU in a VM) instead of hanging on "Opening…".
# pkgrel 9: UI polish pass on the shared kit — GlassCard gained shader-free depth
# (top sheen + bottom shade), an animated hover lift + brighten; GButton gained a
# tactile press-scale. Kept SHADER-FREE so it still renders under the software
# backend in VMs. Same GlassCard upgrade landed in the AI Monitor + API Inspector.
# pkgrel 10: the shared kit (Theme/GlassCard/GButton/StatusBanner) is no longer
# kept in app/ — it's bundled at build from the new canonical genesi-ui-kit/ (one
# source for the kit, copied in via a sibling ../ ref; NOT a published package, so
# it doesn't trip the pipeline's no-inter-package-dep rule). No runtime change.
# pkgrel 11: FIX "Open in Genesi Code" never opening the project. Genesi Code (a
# Warp fork) parses positional CLI args as URLs (Vec<Url>), not bare paths — the
# plain folder path we passed wasn't a valid URL, so it was dropped and nothing
# opened. Pass a file:// URL instead (genesi-code's uri::handle_incoming_uri ->
# open_file spawns a new session with that directory as the working directory).
pkgrel=11
pkgdesc='Isolated developer workspaces (Distrobox) with ready-made stack templates'
arch=('any')
url='https://github.com/zFreshy/GenesiOS'
license=('GPL-3.0-or-later')
# podman is a HARD dep: rootless, no daemon, no group — it's the backend that
# works with zero setup, so Distrobox always has one out of the box. docker stays
# an optional alternative for users who prefer it.
depends=('python' 'pyside6' 'qqc2-desktop-style' 'distrobox' 'podman')
optdepends=(
    'docker: alternative container backend for Distrobox'
    'konsole: terminal used to enter a workspace'
    'genesi-code: open a workspace project folder in the Genesi Code IDE'
)
source=()
sha256sums=()

package() {
    # CLI (source of truth) + GUI launcher
    install -Dm755 "${startdir}/genesi-sandboxes" \
        "$pkgdir/usr/local/bin/genesi-sandboxes"
    install -Dm755 "${startdir}/genesi-sandboxes-gui" \
        "$pkgdir/usr/local/bin/genesi-sandboxes-gui"

    # GUI app (PySide6 + Kirigami) — main window + shared Genesi UI kit
    install -Dm644 "${startdir}/app/genesi_sandboxes.py" \
        "$pkgdir/usr/share/genesi-sandboxes/app/genesi_sandboxes.py"
    install -Dm644 "${startdir}/app/Main.qml" \
        "$pkgdir/usr/share/genesi-sandboxes/app/Main.qml"
    # Shared Genesi UI kit — one canonical source, bundled in at build (see
    # genesi-ui-kit/README.md for why it's not a dependency).
    for comp in Theme GlassCard GButton StatusBanner; do
        install -Dm644 "${startdir}/../genesi-ui-kit/components/${comp}.qml" \
            "$pkgdir/usr/share/genesi-sandboxes/app/${comp}.qml"
    done

    # Desktop entry + branded app icon (taskbar/menu shows our cube, not python3)
    install -Dm644 "${startdir}/org.genesi.sandboxes.desktop" \
        "$pkgdir/usr/share/applications/org.genesi.sandboxes.desktop"
    install -Dm644 "${startdir}/app/icons/logo.svg" \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/genesi-sandboxes.svg"
}
