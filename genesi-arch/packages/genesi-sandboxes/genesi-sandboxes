#!/usr/bin/env bash
# genesi-sandboxes — isolated developer workspaces on top of Distrobox.
#
# Each "sandbox" is a Distrobox container with its own dependencies, integrated
# with the host (HOME, GUI, terminal). Templates pre-install a stack so a fresh
# "React + Vite" or "Python + FastAPI" box is one click away. This CLI is the
# single source of truth; the GUI (genesi-sandboxes-gui) just drives it.
set -euo pipefail

# Per-sandbox project directory on the host. HOME is shared into every Distrobox
# container, so this same path is visible inside the box AND openable in Genesi
# Code on the host — edit in the IDE, build inside the sandbox, one set of files.
SANDBOX_ROOT="${GENESI_SANDBOX_ROOT:-$HOME/Sandboxes}"

# ---- container backend ------------------------------------------------------
# Distrobox needs a container manager. Podman (rootless) is the clean default:
# no daemon, no group, nothing to misconfigure. We only fall back to Docker,
# whose socket is group-owned by `docker` — and a GUI launched from a session
# that predates `usermod -aG docker` (our exact case: the app is a plasmashell
# child) gets EACCES on that socket. When Docker is the only option and the
# session lacks the group but the user IS a member in /etc/group, we run
# distrobox under `sg docker`, which switches the GID from membership with no
# password and no re-login. Net effect: sandboxes "just work" right after the
# user installs docker + is added to the group, instead of failing until logout.
SG_DOCKER=""

detect_backend() {
    if [ -n "${DBX_CONTAINER_MANAGER:-}" ] && command -v "${DBX_CONTAINER_MANAGER}" >/dev/null 2>&1; then
        echo "${DBX_CONTAINER_MANAGER}"; return 0
    fi
    if command -v podman >/dev/null 2>&1; then echo podman; return 0; fi
    if command -v docker >/dev/null 2>&1; then echo docker; return 0; fi
    echo ""
}

in_docker_group() {
    [ "$(id -gn 2>/dev/null)" = docker ] && return 0
    id -nG 2>/dev/null | tr ' ' '\n' | grep -qx docker && return 0
    case ",$(getent group docker 2>/dev/null | cut -d: -f4)," in
        *,"$(id -un 2>/dev/null)",*) return 0 ;;
    esac
    return 1
}

DBX_MGR=""
# "" = ready; "inactive" = docker installed but daemon stopped; "perm" = daemon
# up but the user can't reach the socket (not in the docker group at all).
DOCKER_ISSUE=""

docker_daemon_active() {
    systemctl is-active --quiet docker 2>/dev/null && return 0
    systemctl is-active --quiet docker.socket 2>/dev/null && return 0
    return 1
}

# Detect the backend lazily — ONLY the commands that touch containers call this.
# `templates-json` (which fills the GUI's template dropdown) must never run
# `docker info`: a busy/over-loaded docker daemon makes it hang, the GUI's
# 20s loadTemplates times out, and the dropdown shows up empty ("doesn't work").
ensure_backend() {
    [ -n "${_BACKEND_DONE:-}" ] && return 0
    _BACKEND_DONE=1
    DBX_MGR="$(detect_backend)"
    [ "$DBX_MGR" = docker ] || return 0
    # Docker is the backend — confirm we can actually reach the daemon, and if
    # not, classify WHY so the GUI/CLI can tell the user exactly what to do
    # (instead of leaking distrobox's raw "dial unix /var/run/docker.sock" error).
    if docker info >/dev/null 2>&1; then
        return 0                                   # reachable directly
    fi
    if in_docker_group && sg docker -c 'docker info >/dev/null 2>&1' 2>/dev/null; then
        SG_DOCKER=1; return 0                       # reachable via group hop
    fi
    if docker_daemon_active; then
        DOCKER_ISSUE=perm
    else
        DOCKER_ISSUE=inactive
    fi
}

# Stop create/enter early with an actionable message when Docker can't be reached
# — the missing instruction users had to guess ("sudo systemctl start docker").
assert_backend_ready() {
    [ "$DBX_MGR" = docker ] || return 0
    case "$DOCKER_ISSUE" in
      inactive)
        cat >&2 <<EOF
Docker is installed but its service isn't running.
Start it (and enable it on every boot) with:

    sudo systemctl enable --now docker

Tip: install podman for a rootless backend that needs no daemon or group setup:
    sudo pacman -S podman
EOF
        exit 1 ;;
      perm)
        cat >&2 <<EOF
Your user isn't allowed to talk to Docker yet.
Add yourself to the docker group, then log out and back in:

    sudo usermod -aG docker $(id -un)
EOF
        exit 1 ;;
    esac
}

# Run distrobox with the chosen backend, group-hopping for Docker when needed.
dbx() {
    if [ -n "$SG_DOCKER" ]; then
        sg docker -c "$(printf '%q ' env DBX_CONTAINER_MANAGER=docker distrobox "$@")"
    else
        DBX_CONTAINER_MANAGER="${DBX_MGR:-podman}" distrobox "$@"
    fi
}

# Same, but stages an argv array in EARGV for a terminal's `-e` payload (a
# launched konsole is also a GUI child, so it needs the same group hop).
dbx_argv() {
    if [ -n "$SG_DOCKER" ]; then
        EARGV=(sg docker -c "$(printf '%q ' env DBX_CONTAINER_MANAGER=docker distrobox "$@")")
    else
        EARGV=(env "DBX_CONTAINER_MANAGER=${DBX_MGR:-podman}" distrobox "$@")
    fi
}

require_distrobox() {
    command -v distrobox >/dev/null 2>&1 || {
        echo "distrobox is not installed" >&2; exit 1; }
    ensure_backend
    [ -n "$DBX_MGR" ] || {
        echo "no container backend found — install podman (recommended) or docker" >&2
        exit 1; }
    assert_backend_ready
}

# ---- templates --------------------------------------------------------------
# id|label|image|packages(pacman, space-sep)|hint
# All Arch-based so there is one package manager to reason about inside the box.
read -r -d '' TEMPLATES <<'TPL' || true
java|Java + Spring Boot|archlinux:latest|jdk-openjdk maven gradle|jdk-openjdk, Maven & Gradle
node|React + Vite|archlinux:latest|nodejs npm|Node.js + npm — scaffold with: npm create vite@latest
python|Python + FastAPI|archlinux:latest|python python-pip|Python + pip — then: pip install fastapi uvicorn
go|Go|archlinux:latest|go|Go toolchain
rust|Rust|archlinux:latest|rustup base-devel|rustup (run: rustup default stable)
cpp|C / C++|archlinux:latest|base-devel cmake gdb clang|GCC/Clang, CMake, GDB
plain|Plain Arch|archlinux:latest||Empty Arch box, add what you need
TPL

tpl_field() { # id field-index(1-based)
    echo "$TEMPLATES" | awk -F'|' -v id="$1" -v f="$2" '$1==id{print $f; exit}'
}

case "${1:-list-json}" in
  templates-json)
    python3 - "$TEMPLATES" <<'PY'
import json, sys
rows = []
for line in sys.argv[1].splitlines():
    if not line.strip():
        continue
    p = (line.split("|") + [""]*5)[:5]
    rows.append({"id": p[0], "label": p[1], "image": p[2],
                 "packages": p[3], "hint": p[4]})
print(json.dumps(rows))
PY
    ;;

  list-json)
    if ! command -v distrobox >/dev/null 2>&1; then
        echo '{"distrobox":false,"backend":"","backendReady":false,"backendIssue":"","hasCode":false,"boxes":[]}'; exit 0
    fi
    has_code=false; if command -v genesi-code >/dev/null 2>&1; then has_code=true; fi
    ensure_backend
    if [ -z "$DBX_MGR" ]; then
        echo '{"distrobox":true,"backend":"none","backendReady":false,"backendIssue":"","hasCode":'"$has_code"',"boxes":[]}'
        exit 0
    fi
    # When Docker can't be reached, DON'T run `dbx list` (it would just error);
    # report the issue so the GUI shows the right banner instead of an empty list.
    if [ -n "$DOCKER_ISSUE" ]; then
        echo '{"distrobox":true,"backend":"'"$DBX_MGR"'","backendReady":false,"backendIssue":"'"$DOCKER_ISSUE"'","hasCode":'"$has_code"',"boxes":[]}'
        exit 0
    fi
    raw="$(dbx list --no-color 2>/dev/null || true)"
    BACKEND="$DBX_MGR" HASCODE="$has_code" python3 - "$raw" <<'PY'
import json, os, sys
raw = sys.argv[1] if len(sys.argv) > 1 else ""
boxes = []
for i, line in enumerate(raw.splitlines()):
    if "|" not in line:
        continue
    cols = [c.strip() for c in line.split("|")]
    if i == 0 and cols and cols[0].upper() == "ID":
        continue  # header
    cols += [""] * (4 - len(cols))
    cid, name, status, image = cols[:4]
    boxes.append({"id": cid, "name": name, "status": status, "image": image,
                  "running": status.lower().startswith("up")})
boxes.sort(key=lambda b: b["name"])
print(json.dumps({"distrobox": True,
                  "backend": os.environ.get("BACKEND", "none"),
                  "backendReady": True,
                  "backendIssue": "",
                  "hasCode": os.environ.get("HASCODE") == "true",
                  "boxes": boxes}))
PY
    ;;

  create)
    require_distrobox
    name="${2:-}"; tpl="${3:-plain}"
    [ -n "$name" ] || { echo "usage: genesi-sandboxes create <name> <template>" >&2; exit 2; }
    image="$(tpl_field "$tpl" 3)"; [ -n "$image" ] || image="archlinux:latest"
    pkgs="$(tpl_field "$tpl" 4)"
    echo ">>> Backend: $DBX_MGR${SG_DOCKER:+ (via sg docker)}"
    echo ">>> Creating sandbox '$name' from template '$tpl' ($image)…"
    dbx create --yes --name "$name" --image "$image"
    # First enter triggers the container build; do it once up front.
    dbx enter --name "$name" -- true || true
    if [ -n "$pkgs" ]; then
        echo ">>> Installing: $pkgs"
        dbx enter --name "$name" -- sudo pacman -Syu --noconfirm $pkgs
    fi
    # Give the workspace a project directory on the host (shared into the box).
    mkdir -p "$SANDBOX_ROOT/$name"
    echo ">>> Project folder: $SANDBOX_ROOT/$name"
    echo ">>> Sandbox '$name' is ready. Enter it with: genesi-sandboxes enter $name"
    ;;

  enter)
    require_distrobox
    [ -n "${2:-}" ] || { echo "usage: genesi-sandboxes enter <name>" >&2; exit 2; }
    # Land in the workspace's project folder (created on `create`; ensure it
    # exists for boxes made before this feature). It's the same shared HOME path
    # Genesi Code opens, so the terminal and the IDE share one working dir.
    mkdir -p "$SANDBOX_ROOT/$2"
    dbx_argv enter --name "$2" --additional-flags "--workdir=$SANDBOX_ROOT/$2"
    term="konsole -e"; command -v konsole >/dev/null 2>&1 || term="x-terminal-emulator -e"
    exec $term "${EARGV[@]}"
    ;;

  code)
    # Open the workspace's project folder in Genesi Code (the host-side IDE).
    [ -n "${2:-}" ] || { echo "usage: genesi-sandboxes code <name>" >&2; exit 2; }
    command -v genesi-code >/dev/null 2>&1 || {
        echo "Genesi Code is not installed" >&2; exit 1; }
    mkdir -p "$SANDBOX_ROOT/$2"
    # Genesi Code (a Warp fork) parses positional CLI args as URLs, NOT bare
    # paths — a plain path is not a valid URL, so it was silently dropped and
    # nothing opened. Pass a file:// URL instead: its CLI handles file:// by
    # spawning a new session with that directory as the working directory (see
    # uri::handle_incoming_uri -> open_file in genesi-code). Resolve to an
    # absolute path first so the URL is well-formed (file:///abs/path).
    dir="$(cd "$SANDBOX_ROOT/$2" && pwd)"
    exec genesi-code "file://$dir"
    ;;

  rm|remove)
    require_distrobox
    [ -n "${2:-}" ] || { echo "usage: genesi-sandboxes rm <name>" >&2; exit 2; }
    dbx stop --yes "$2" 2>/dev/null || true
    dbx rm --force "$2"
    ;;

  *)
    echo "usage: genesi-sandboxes {templates-json|list-json|create <name> <tpl>|enter <name>|code <name>|rm <name>}" >&2
    exit 2
    ;;
esac
