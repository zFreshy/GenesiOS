# Maintainer: Genesi OS Team
#
# caelestia-cli (caelestia-dots/cli) repackaged for the [genesi] repo. It is the
# `caelestia` command that drives the caelestia-shell desktop (Roadmap 5.1's
# "Hyprland + caelestia-shell" install option): wallpaper/scheme management,
# screenshots, shell IPC, etc. AUR-only upstream; mirrored here so the Calamares
# netinstall (pacman, no AUR) installs it. Pinned to a release tarball (not git)
# for reproducible builds. provides=caelestia-cli so the shell's dependency
# resolves to this build.
#
# Two of its declared deps are themselves Genesi repackages of AUR-only software:
# app2unit -> genesi-app2unit, python-materialyoucolor -> genesi-materialyoucolor
# (both provide the bare names). All other deps live in Arch [extra].
pkgname=genesi-caelestia-cli
pkgver=1.0.8
pkgrel=1
pkgdesc='CLI for the Caelestia desktop shell (Genesi repackage of caelestia-cli)'
arch=('any')
url='https://github.com/caelestia-dots/cli'
license=('GPL-3.0-only')
depends=('python' 'python-pillow' 'python-materialyoucolor' 'libnotify' 'swappy' 'grim' 'dart-sass'
         'app2unit' 'wl-clipboard' 'slurp' 'gpu-screen-recorder' 'dconf' 'cliphist' 'fuzzel')
optdepends=('caelestia-shell: shell control and screenshot function')
makedepends=('python-build' 'python-installer' 'python-hatch' 'python-hatch-vcs')
provides=('caelestia-cli')
conflicts=('caelestia-cli' 'caelestia-cli-git')
_archive="caelestia-$pkgver"
source=("$url/releases/download/v$pkgver/$_archive.tar.gz")
sha256sums=('1d238723b74581e9d8fae4f836837f71050d65759b11bfc9b3de71534accb368')

build() {
    cd "${srcdir}/${_archive}"
    python -m build --wheel --no-isolation
}

package() {
    cd "${srcdir}/${_archive}"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 ./completions/caelestia.fish "$pkgdir"/usr/share/fish/vendor_completions.d/caelestia.fish
}
