# Maintainer: Genesi OS Team <dev@genesios.org>
#
# Genesi Code — the Genesi OS code editor / agentic terminal (fork of Warp,
# github.com/zFreshy/genesi-code, `genesi` branch). This package does NOT
# compile the Rust workspace (that is a ~40 min, multi-GB build handled by the
# fork's own GitHub Actions). Instead it pulls the prebuilt, release-mode binary
# that genesi-code's CI publishes as a GitHub Release asset (release builds embed
# all bundled assets via rust_embed, so the binary is self-contained). Bump
# `pkgver` to the release tag you want to ship.
pkgname=genesi-code
# Floor version. publish-apps.yml overrides this at build time to the LATEST
# genesi-code GitHub Release (so every new build flows to the [genesi-apps] repo
# and surfaces in genesi-update automatically). Bump it here only as a manual
# fallback for a local `makepkg`.
pkgver=0.0.30
# pkgrel 6: revert to the clean symlink. The "loads-and-closes from the menu"
# symptom was NOT a packaging problem (the pkgrel-5 setsid/redirect wrapper was a
# wrong guess): the app's dev channel shipped an empty `logfile_name`, so off a
# tty (menu/plasmoid) the logger opened the log DIRECTORY as a file and died with
# "Is a directory (os error 21)". Fixed in the fork (channel_config.rs). With that
# fixed the canonical symlink launches correctly everywhere, so drop the wrapper.
# pkgrel 4: FIX "opens when run directly, but `genesi-code` shows nothing". The
# /usr/bin entry was a packaging wrapper that wrapped the real launcher in
# `setsid -f ... >>log 2>&1`, detaching the app into a new session and killing
# the GUI launch from the menu/terminal. Replaced with a plain symlink to the
# release launcher (designed to be symlinked via its `readlink -f` self-resolve),
# so /usr/bin/genesi-code now takes the exact code path that already works when
# run directly. Drops the per-launch log file (crashes go to the journal now).
# pkgrel 3: FIX "app loads and closes / won't launch". The release tarball ships
# TWO files — `genesi-code` (the launcher script from resources/linux/launcher)
# and `genesi-code.bin` (the real ELF). The launcher resolves its own dir and
# execs `<dir>/genesi-code.bin`, but package() only installed the script, never
# the .bin — so launch died with "genesi-code.bin: No such file or directory"
# (the script's exec line). Install the .bin alongside the script.
# pkgrel 2: launcher (genesi-code.sh) redirects stdio to a log file + /dev/null
# so a menu/KRunner launcher closing its stdout pipe can't SIGPIPE-kill the
# detached app — fixes "opens from a terminal but not from the menu". (pkgver is
# overridden to the latest release by publish-apps.yml; this pkgrel forces the
# rebuilt package to supersede the same-version one already in [genesi-apps].)
# pkgrel 7: new app icon — the Genesi leaf with a </> at its heart (replaces the
# old leaf+veins glyph). Pure icon swap; bump so the rebuilt package ships it.
# Floor release for manual local builds. publish-apps.yml replaces this with a
# unique integer derived from the GitHub Actions run, so package assets are
# never overwritten after repo-add publishes their size. pkgrel 8 supersedes
# the mutable 0.0.59-7 asset that caused "Maximum file size exceeded".
pkgrel=8
pkgdesc='Genesi Code - local-first code editor / agentic terminal for Genesi OS (Warp fork)'
arch=('x86_64')
url='https://github.com/zFreshy/genesi-code'
license=('AGPL-3.0-or-later')
# Runtime libs the release binary links against (GUI: wgpu/Vulkan + wayland/X11,
# text: fontconfig/freetype, TLS: openssl). vulkan-icd-loader loads the system
# Vulkan driver; vulkan-swrast (lavapipe) is a software Vulkan fallback. The
# launcher (genesi-code.sh) forces software GL (llvmpipe) inside a VM where the
# GPU presentation path is broken; mesa provides llvmpipe.
depends=(
    'fontconfig'
    'freetype2'
    'libxkbcommon'
    'libxkbcommon-x11'
    'wayland'
    'libx11'
    'libxcb'
    'openssl'
    'vulkan-icd-loader'
    'vulkan-swrast'
    # node + npm so the editor can auto-install its node-based language servers
    # (typescript-language-server for JS/TS, pyright for Python). Without a
    # system node the auto-install fails and the footer shows the server as
    # "stopped" with no autocomplete. With node present it uses the system
    # binary and the classic (non-AI) LSP completion works out of the box.
    'nodejs'
    'npm'
)
# NB: do NOT list `zlib` here. On CachyOS libz is provided by `zlib-ng-compat`
# (installed by default); an explicit `zlib` dep makes the publish pipeline's
# pre-install step (`pacman -S` of all aggregated PKGBUILD depends) hit an
# unresolvable conflict: "zlib and zlib-ng-compat are in conflict".
options=('!strip')  # release binary is already stripped by the build
source=(
    "genesi-code-${pkgver}-x86_64.tar.zst::https://github.com/zFreshy/genesi-code/releases/download/v${pkgver}/genesi-code-linux-x86_64.tar.zst"
    'genesi-code.desktop'
    'genesi-code.svg'
)
# The release asset is first-party (our own CI) and the version tag pins it, so
# we don't carry a churning checksum here.
sha256sums=('SKIP'
            'SKIP'
            'SKIP')

package() {
    # Self-contained release binary (assets embedded via rust_embed). Installed
    # under /usr/lib so the /usr/bin entry can be the launcher wrapper below.
    # The release tarball ships the launcher script (`genesi-code`) AND the real
    # ELF (`genesi-code.bin`) side by side; the script execs the .bin from its own
    # directory, so BOTH must land in /usr/lib/genesi-code. Missing the .bin is
    # what made the app "load and close" (exec of a nonexistent binary).
    install -Dm755 "${srcdir}/genesi-code" "${pkgdir}/usr/lib/genesi-code/genesi-code"
    install -Dm755 "${srcdir}/genesi-code.bin" "${pkgdir}/usr/lib/genesi-code/genesi-code.bin"

    # /usr/bin entry: a symlink to the release launcher, NOT a second wrapper.
    # The launcher resolves its own location with `readlink -f "$0"` precisely so
    # it can be symlinked onto PATH — invoking it through this symlink is byte-for
    # -byte the same code path as running /usr/lib/genesi-code/genesi-code
    # directly (which works). It already handles VM software-GL fallback and execs
    # the sibling .bin. The previous packaging wrapper added `setsid -f` + a stdio
    # redirect on top of this, which detached the process into a new session and
    # broke the GUI launch ("opens when run directly, but `genesi-code` from the
    # menu/terminal shows nothing"). Drop it and use the canonical launcher.
    install -dm755 "${pkgdir}/usr/bin"
    ln -s /usr/lib/genesi-code/genesi-code "${pkgdir}/usr/bin/genesi-code"

    # Desktop entry + icon. StartupWMClass matches the app_id the binary reports
    # (dev.genesi.GenesiCode) so the taskbar groups the window correctly.
    install -Dm644 "${srcdir}/genesi-code.desktop" \
        "${pkgdir}/usr/share/applications/genesi-code.desktop"
    install -Dm644 "${srcdir}/genesi-code.svg" \
        "${pkgdir}/usr/share/icons/hicolor/scalable/apps/genesi-code.svg"
}
