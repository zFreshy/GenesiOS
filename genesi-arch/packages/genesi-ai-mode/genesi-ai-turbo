#!/usr/bin/env python3
"""
Genesi Turbo — speculative decoding for local models (faster than any stock OS).

ollama doesn't expose speculative decoding, so Turbo drives llama.cpp's
`llama-server` directly: a small same-family DRAFT model proposes tokens and the
big TARGET model verifies several at once. The output is IDENTICAL to the target
model, but decode is typically 1.5-3x faster. Reuses the GGUF weights ollama
already downloaded — no re-download.

  genesi-ai-turbo bench <model> [draft]   prove the speedup (spec vs no-spec)
  genesi-ai-turbo serve <model> [--spec]  run a Turbo server on :11435
  genesi-ai-turbo recommend               print the biggest model that fits VRAM
  genesi-ai-turbo <model> [--spec]        same as `serve`

  --spec / --speculative   enable speculative decoding (a draft model proposes
                           tokens; faster decode on a mature GPU driver, but can
                           REGRESS on Vulkan/NVK). Default OFF = plain full GPU
                           offload, the reliable win. (== GENESI_TURBO_SPEC=1)

Needs llama-server, shipped by Genesi (Vulkan, any GPU):
  sudo pacman -S genesi-llama-cpp

Tuning knobs (env vars, no rebuild needed — for on-hardware tuning):
  GENESI_TURBO_CTX=4096          context window
  GENESI_TURBO_UBATCH=<n>        physical prefill batch / n_ubatch
                                 (default 1024 on GPU, 512 on CPU; lower it if a
                                  small GPU OOMs, raise it on a big GPU)
  GENESI_TURBO_BATCH=2048        logical prefill batch
  GENESI_TURBO_CACHE_REUSE=256   min prefix chunk reused across requests (KV)
  GENESI_TURBO_MLOCK=1           pin model in RAM (opt-in; risky on low RAM)
  GENESI_TURBO_NCMOE=<n>         MoE: force N layers' experts onto CPU RAM (auto
                                 by VRAM otherwise; only used for MoE models that
                                 spill VRAM)
  GENESI_TURBO_NO_MOE=1          disable MoE expert-offload (fall back to plain
                                 partial offload; `serve` also auto-falls-back to
                                 this if --n-cpu-moe trips the model loader)
  GENESI_TURBO_THREADS=<n>       CPU inference threads for DECODE (default: fast/
                                 perf cores)
  GENESI_TURBO_THREADS_BATCH=<n> CPU threads for PREFILL (default: all logical
                                 cores — prefill is compute-bound, SMT helps)
  GENESI_TURBO_PRIO=2            CPU thread scheduling priority (above-normal)
  GENESI_TURBO_NO_CPU_TUNE=1     skip the CPU prefill-threads / priority tuning
  GENESI_TURBO_NO_NGRAM=1        disable model-free n-gram/prompt-lookup spec
                                 (on by default when no draft model — free win on
                                 code/agent/RAG output, harmless otherwise)
  GENESI_TURBO_SELF_DRAFT=1      when no same-family draft exists, build a low-bit
                                 self-draft (Q2) of the model for speculation
                                 (opt-in; modest ~1.1-1.3x and only if both fit
                                 VRAM, so usually a no-op on an 8 GB card)
  GENESI_TURBO_DRAFT_MAX=8       max tokens the draft proposes (speculative only)
  GENESI_TURBO_DRAFT_MIN=1       min draft length — floor for dynamic draft length
  GENESI_TURBO_DRAFT_P=0.6       stop drafting below this acceptance probability
  GENESI_TURBO_SLOT_PATH=<dir>   where to persist prompt/KV slots to disk
  GENESI_TURBO_NO_SLOT_CACHE=1   disable persistent prompt/KV cache to disk
  GENESI_TURBO_SPEC=1            force speculative decoding ON for `serve`
  GENESI_TURBO_NO_SPEC=1         force speculative decoding OFF for `serve`
                                 Default (neither set): AUTO — spec is ON when the
                                 installed llama-server is the CUDA build (the
                                 proven win on a mature driver) and OFF on Vulkan/
                                 NVK (where the draft+verify can cost more than
                                 plain offload saves). It also self-disables when
                                 the target model spills VRAM (no draft then).
  GENESI_TURBO_FORCE_DRAFT=1     force the draft even on CPU-only (usually slower)
"""
import os
import re
import sys
import json
import time
import signal
import shutil
import socket
import tempfile
import subprocess
import urllib.request

TURBO_PORT = 11435
PROMPT = "Explain how a CPU instruction pipeline works, in about 200 words."

# (family substring in the target tag -> a tiny, SAME-tokenizer draft model)
# The draft MUST share the target's vocab/tokenizer or speculation gets near-zero
# acceptance (or fails), so map each family to its OWN smallest member — never a
# cross-generation draft (e.g. gemma3 must use gemma3:1b, NOT gemma2). Longest /
# most-specific prefixes first (pick_draft uses startswith).
DRAFT_FOR = [
    ("llama3.3", "llama3.2:1b"),
    ("llama3.1", "llama3.2:1b"),
    ("llama3.2", "llama3.2:1b"),
    ("llama3",   "llama3.2:1b"),
    ("qwen2.5",  "qwen2.5:0.5b"),
    ("qwen2",    "qwen2.5:0.5b"),
    ("qwen3",    "qwen3:0.6b"),
    ("gemma3",   "gemma3:1b"),
    ("gemma2",   "gemma2:2b"),
]
TINY = (":0.5b", ":0.6b", ":1b", ":1.5b")


def _daemon_models_dir():
    """The OLLAMA_MODELS the ollama systemd service actually runs with.

    This is the source of truth: the daemon writes models *here*, and on
    Genesi/Arch it is set to bare /var/lib/ollama — with blobs/ and manifests/
    directly inside, NOT under a models/ subdir. Guessing conventional paths
    misses this, so we ask systemd what the running daemon uses."""
    try:
        out = subprocess.run(
            ["systemctl", "show", "ollama", "-p", "Environment"],
            capture_output=True, text=True, timeout=5).stdout
    except Exception:
        return None
    # Line looks like: Environment=HOME=/var/lib/ollama OLLAMA_MODELS=/var/lib/ollama ...
    for tok in out.replace("Environment=", "", 1).split():
        if tok.startswith("OLLAMA_MODELS="):
            return tok.split("=", 1)[1].strip() or None
    return None


def _candidate_model_dirs():
    """Yield every plausible Ollama model root, in priority order.

    The daemon may store models in any of these depending on how Ollama was
    installed: an explicit OLLAMA_MODELS (Genesi/Arch use bare /var/lib/ollama,
    blobs+manifests directly inside), the upstream installer's
    /usr/share/ollama/.ollama, or a user's ~/.ollama. Crucially, MORE THAN ONE
    can exist at once — e.g. empty/stale .../models/manifests dirs sitting next
    to the real ones — so callers must probe *every* root for the specific
    model they want instead of locking onto the first dir with a manifests/
    subdir. We list the systemd daemon's real OLLAMA_MODELS first."""
    seen = set()
    for d in (os.environ.get("OLLAMA_MODELS"),
              _daemon_models_dir(),
              "/var/lib/ollama",
              "/usr/share/ollama/.ollama/models",
              "/usr/share/ollama",
              "/var/lib/ollama/.ollama/models",
              "/var/lib/ollama/models",
              os.path.expanduser("~/.ollama/models")):
        if d and d not in seen and os.path.isdir(os.path.join(d, "manifests")):
            seen.add(d)
            yield d


def models_dir():
    """First existing model root (any with a manifests/ dir), or None.

    Kept for the permission-fix path; model *resolution* uses gguf_path, which
    searches all roots — see _candidate_model_dirs()."""
    for d in _candidate_model_dirs():
        return d
    return None


def gguf_path(tag):
    """The GGUF blob ollama stored for `tag` (e.g. 'llama3.1:8b'), or None.

    Searches every candidate model root (not just the first one with a
    manifests/ dir) so a stale/empty root can't shadow the one the daemon
    actually pulled into."""
    name, _, ver = tag.partition(":")
    ver = ver or "latest"
    roots = list(_candidate_model_dirs())
    if not roots:
        print("[!] No Ollama models directory found (no manifests/ dir anywhere)",
              file=sys.stderr)
        return None
    last_err = None
    for md in roots:
        man = os.path.join(md, "manifests", "registry.ollama.ai", "library", name, ver)
        if not os.path.isfile(man):
            last_err = f"[!] Manifest not found: {man}"
            continue
        try:
            m = json.load(open(man))
        except Exception as e:
            last_err = f"[!] Error reading manifest {man}: {e}"
            continue
        for layer in m.get("layers", []):
            if layer.get("mediaType", "").endswith("image.model"):
                digest = layer.get("digest", "")
                # Ollama sometimes uses sha256-xxx, sometimes sha256:xxx in digest, but the file is always sha256-xxx
                blob_name = digest.replace(":", "-")
                blob = os.path.join(md, "blobs", blob_name)
                if not os.path.isfile(blob):
                    last_err = f"[!] Blob not found: {blob}"
                    break
                if not os.access(blob, os.R_OK):
                    last_err = f"[!] Permission denied to read blob: {blob}"
                    break
                return blob
        else:
            last_err = f"[!] No image.model layer found in manifest {man}"
    # Nothing matched in any root — report the most specific reason we hit.
    if last_err:
        print(last_err, file=sys.stderr)
    return None


def _fix_ollama_permissions():
    """Try to open up the Ollama models tree so any local user can read the
    GGUF blobs. Ollama's systemd service runs as the `ollama` user, so newly
    pulled files are readable only by root/ollama.  The genesi-ollama.conf
    drop-in fixes this on service start, but models pulled *after* that need
    a one-shot chmod. We try pkexec first (graphical polkit prompt, no
    terminal), then fall back to sudo (works in a tty session)."""
    # Candidate roots — the daemon may use any of these.
    candidates = [
        "/var/lib/ollama",
        "/usr/share/ollama/.ollama",
    ]
    # Also consider OLLAMA_MODELS env if set.
    env_models = os.environ.get("OLLAMA_MODELS")
    if env_models:
        candidates.insert(0, os.path.dirname(env_models)
                          if env_models.endswith("/models") else env_models)

    for root in candidates:
        models = os.path.join(root, "models")
        # Also check the hidden .ollama/models subpath common in systemd setups.
        for mdir in (models, os.path.join(root, ".ollama", "models")):
            if not os.path.isdir(mdir):
                continue
            # Build the chmod command: make dirs traversable, files readable.
            sh = (f"chmod a+rx {root} {mdir} 2>/dev/null; "
                  f"chmod -R a+rX {mdir}/blobs {mdir}/manifests 2>/dev/null || true")
            # Try pkexec (graphical prompt), then sudo (tty).
            for escalator in ("pkexec", "sudo"):
                if not shutil.which(escalator):
                    continue
                print(f":: fixing model permissions via {escalator}…",
                      flush=True)
                rc = subprocess.run(
                    [escalator, "/bin/sh", "-c", sh],
                    timeout=120).returncode
                if rc == 0:
                    return True
            break  # found the dir, no point checking more candidates
    return False


def ensure(tag):
    """Make sure `tag` is pulled; return its GGUF path (or None on failure)."""
    p = gguf_path(tag)
    if p:
        return p
    print(f":: pulling {tag} ...", flush=True)
    if subprocess.run(["ollama", "pull", tag]).returncode != 0:
        return None
    p = gguf_path(tag)
    if p:
        return p
    # Pull succeeded but we still can't resolve the GGUF. Almost always the
    # daemon (ollama user) wrote files the current user can't traverse/read, so
    # open up the perms and try once more across all roots.
    print("\n[!] Model pulled but its files aren't readable — fixing permissions…",
          file=sys.stderr, flush=True)
    if _fix_ollama_permissions():
        p = gguf_path(tag)
        if p:
            return p
    print("[!] Still cannot read the model. Run manually:", file=sys.stderr)
    print("    sudo chmod -R a+rX /var/lib/ollama /usr/share/ollama/.ollama",
          file=sys.stderr)
    return p


def pick_draft(main):
    low = main.lower()
    if any(t in low for t in TINY):
        return None                       # already tiny — nothing to speculate
    for key, draft in DRAFT_FOR:
        if low.startswith(key):
            return draft
    return None


def self_draft_path(main_gguf):
    """A low-bit (Q2_K) quant of the SAME model, to use as a speculative draft
    when the family has no published tiny sibling (mistral, gemma1, phi…). Same
    tokenizer is GUARANTEED (it's literally the same model), so acceptance is high.
    Built once with `llama-quantize` and cached under ~/.cache/genesi-turbo/drafts.

    HONEST CAVEAT: a self-draft has the SAME number of layers as the target, so
    it's only ~memory-ratio faster (≈2× for Q2 vs Q4), not the ~10× a 1B-drafts-7B
    sibling gives — net gain is a modest ~1.1–1.3×, AND both must fit VRAM (on an
    8 GB card a 7B target + its Q2 draft usually DON'T, so server_cmd's fit check
    drops it). Hence opt-in: GENESI_TURBO_SELF_DRAFT=1. Returns a path or None."""
    qbin = llama_bin("llama-quantize")
    if not qbin:
        return None
    cache = os.path.expanduser("~/.cache/genesi-turbo/drafts")
    try:
        os.makedirs(cache, exist_ok=True)
    except OSError:
        return None
    out = os.path.join(cache, os.path.basename(main_gguf) + ".q2k.gguf")
    if os.path.isfile(out) and os.path.getsize(out) > 0:
        return out
    quant = os.environ.get("GENESI_TURBO_SELF_DRAFT_QUANT", "Q2_K")
    print(f":: building a {quant} self-draft (one-off, ~1-2 min) → {out}",
          flush=True)
    try:
        r = subprocess.run([qbin, main_gguf, out, quant], timeout=1800)
    except Exception as e:
        print(f"   [!] self-draft quantize failed: {e}", file=sys.stderr)
        return None
    if r.returncode == 0 and os.path.isfile(out):
        return out
    # Clean up a partial file so we retry cleanly next time.
    try:
        os.remove(out)
    except OSError:
        pass
    print("   [!] self-draft quantize did not produce a model — skipping.",
          file=sys.stderr)
    return None


def llama_bin(name):
    for cand in (name, "/usr/bin/" + name):
        b = shutil.which(cand) or (cand if os.path.exists(cand) else None)
        if b:
            return b
    return None


def _env_int(name, default):
    try:
        v = int(os.environ.get(name, "").strip())
        return v if v > 0 else default
    except Exception:
        return default


def _env_flag(name):
    return os.environ.get(name, "").strip().lower() in ("1", "true", "yes", "on")


def _nvidia_vram_mb():
    """Total VRAM (MiB) of the largest NVIDIA GPU via nvidia-smi, or 0.

    Works only with the proprietary/open NVIDIA driver. On the live ISO (and any
    nouveau/NVK setup) the binary may exist but the query fails — hence the
    Vulkan fallback below."""
    if not shutil.which("nvidia-smi"):
        return 0
    try:
        out = subprocess.run(
            ["nvidia-smi", "--query-gpu=memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5).stdout
    except Exception:
        return 0
    best = 0
    for line in out.splitlines():
        v = line.strip()
        if v.isdigit():
            best = max(best, int(v))
    return best


def _vulkan_vram_mb():
    """Total VRAM (MiB) of the largest GPU as seen by llama.cpp's own backend,
    via `llama-server --list-devices`. Vendor-agnostic (NVK/nouveau, RADV, ANV,
    NVIDIA) and, crucially, reports exactly what we can actually offload to —
    the same Vulkan device the server will use. Returns 0 if unavailable."""
    binp = llama_bin("llama-server")
    if not binp:
        return 0
    try:
        r = subprocess.run([binp, "--list-devices"],
                           capture_output=True, text=True, timeout=20)
        text = (r.stdout or "") + (r.stderr or "")
    except Exception:
        return 0
    best = 0
    # device lines look like: "  Vulkan0: NVIDIA GeForce RTX 3050 (8448 MiB, ...)"
    for m in re.finditer(r"\((\d+)\s*MiB", text):
        best = max(best, int(m.group(1)))
    return best


def _detect_vram_mb():
    """Best VRAM (MiB) we can find: nvidia-smi first (proprietary/open driver),
    then the Vulkan backend (covers the live-ISO nouveau case + AMD/Intel)."""
    return _nvidia_vram_mb() or _vulkan_vram_mb()


_BACKEND_CACHE = None


def backend_is_cuda():
    """True when the installed llama-server is the CUDA build.

    Speculative decoding is the proven Turbo win on the mature CUDA driver, so on
    a CUDA build `serve` enables it by default; on the Vulkan build (genesi-llama-
    cpp, which runs on any GPU incl. nouveau/NVK) it can REGRESS, so it stays off.
    We tell them apart by the device backend llama.cpp itself reports: the CUDA
    build lists `CUDA0: ...`, the Vulkan build lists `Vulkan0: ...`. Cached. Honour
    GENESI_TURBO_NO_SPEC / GENESI_TURBO_SPEC at the call site, not here."""
    global _BACKEND_CACHE
    if _BACKEND_CACHE is not None:
        return _BACKEND_CACHE
    _BACKEND_CACHE = False
    binp = llama_bin("llama-server")
    if binp:
        try:
            r = subprocess.run([binp, "--list-devices"],
                               capture_output=True, text=True, timeout=20)
            text = (r.stdout or "") + (r.stderr or "")
            # Match a real CUDA device line, not just the word "cuda" in help.
            _BACKEND_CACHE = bool(re.search(r"\bCUDA\d", text))
        except Exception:
            _BACKEND_CACHE = False
    return _BACKEND_CACHE


# GGUF metadata value types (https://github.com/ggml-org/ggml gguf spec).
_GGUF_SCALAR = {0: 1, 1: 1, 2: 2, 3: 2, 4: 4, 5: 4, 6: 4, 7: 1,
                10: 8, 11: 8, 12: 8}     # type -> byte size
_GGUF_FMT = {0: "B", 1: "b", 2: "H", 3: "h", 4: "I", 5: "i", 6: "f",
             7: "?", 10: "Q", 11: "q", 12: "d"}
_GGUF_STRING = 8
_GGUF_ARRAY = 9


def gguf_meta(path, suffixes):
    """Read selected metadata keys from a GGUF file header WITHOUT loading the
    model. Returns {suffix: value} for any key whose name ends with one of
    `suffixes` (e.g. '.expert_count', '.block_count'). Pure stdlib, bounded, and
    fully defensive — a malformed/partial header yields {} so callers fall back
    to their default behaviour. We need this to spot Mixture-of-Experts models
    (expert_count > 1): their huge expert tensors can be streamed from CPU RAM
    cheaply (only a few experts fire per token), so a ~30B-A3B can run at ~7B
    speed on an 8 GB card instead of crawling when dense layers spill over PCIe."""
    import struct
    found = {}
    try:
        f = open(path, "rb")
    except OSError:
        return found
    with f:
        if f.read(4) != b"GGUF":
            return found
        try:
            ver = struct.unpack("<I", f.read(4))[0]
            cfmt = "<Q" if ver >= 2 else "<I"     # v2/v3 counts are 64-bit
            csz = 8 if ver >= 2 else 4
            f.read(csz)                            # tensor_count (skip)
            n_kv = struct.unpack(cfmt, f.read(csz))[0]
        except Exception:
            return found

        def rd_str():
            ln = struct.unpack(cfmt, f.read(csz))[0]
            return f.read(ln)

        def skip(vt):
            if vt in _GGUF_SCALAR:
                f.seek(_GGUF_SCALAR[vt], 1)
            elif vt == _GGUF_STRING:
                rd_str()
            elif vt == _GGUF_ARRAY:
                et = struct.unpack("<I", f.read(4))[0]
                n = struct.unpack(cfmt, f.read(csz))[0]
                if et in _GGUF_SCALAR:
                    f.seek(_GGUF_SCALAR[et] * n, 1)        # fast-skip numeric arrays
                else:
                    for _ in range(n):
                        skip(et)
            else:
                raise ValueError("bad gguf type")

        def read(vt):
            if vt in _GGUF_SCALAR:
                return struct.unpack("<" + _GGUF_FMT[vt], f.read(_GGUF_SCALAR[vt]))[0]
            if vt == _GGUF_STRING:
                return rd_str().decode("utf-8", "replace")
            raise ValueError("unread gguf type")

        try:
            for _ in range(min(int(n_kv), 100000)):
                key = rd_str().decode("utf-8", "replace")
                vt = struct.unpack("<I", f.read(4))[0]
                hit = next((s for s in suffixes if key.endswith(s)), None)
                if hit is not None and vt != _GGUF_ARRAY:
                    found[hit] = read(vt)
                else:
                    skip(vt)
                if len(found) >= len(suffixes):
                    break
        except Exception:
            pass
    return found


_HELP_CACHE = None


def _llama_help():
    """Cached `llama-server --help` text, so we can pick flag names that match
    the INSTALLED build. llama.cpp renames/removes flags often — e.g. --draft
    was removed in favor of --spec-draft-n-max, and model-free --spec-type ngram
    speculation was added — and genesi-llama-cpp tracks upstream master. Empty
    string if llama-server isn't available."""
    global _HELP_CACHE
    if _HELP_CACHE is None:
        binp = llama_bin("llama-server")
        if not binp:
            _HELP_CACHE = ""
        else:
            try:
                r = subprocess.run([binp, "--help"], capture_output=True,
                                   text=True, timeout=15)
                _HELP_CACHE = (r.stdout or "") + (r.stderr or "")
            except Exception:
                _HELP_CACHE = ""
    return _HELP_CACHE


def _pick_flag(help_txt, *candidates):
    """Return the first candidate flag name that the INSTALLED llama-server
    actually lists in --help, or None. llama.cpp renames speculative-decoding
    flags often across versions, so we never hardcode one name — we probe and
    use whatever this build supports (and silently skip the feature if none)."""
    for c in candidates:
        if c in help_txt:
            return c
    return None


# Advisor model catalogue (ollama tag -> params in billions), biggest last. Used
# by `recommend` to pick the largest model that still runs 100% in VRAM.
RECOMMEND_MODELS = [
    ("llama3.2:1b",  1.2), ("llama3.2:3b",  3.2),
    ("llama3.1:8b",  8.0), ("qwen2.5:7b",   7.6),
    ("qwen2.5:14b", 14.8), ("qwen2.5:32b", 32.5),
]

# MoE "power picks" (ollama tag -> total params B, active params B). These run
# FAR bigger brains than a dense model that fits VRAM, because only the active
# experts compute per token — Turbo keeps attention on the GPU and streams the
# cold experts from RAM (--n-cpu-moe). Constraint is system RAM (to hold the
# experts), not VRAM. Biggest last.
MOE_MODELS = [
    ("gpt-oss:20b",    21.0, 3.6),
    ("qwen3:30b-a3b",  30.0, 3.3),
]


def _total_ram_gb():
    """Total system RAM in GB from /proc/meminfo, or 0.0."""
    try:
        for line in open("/proc/meminfo"):
            if line.startswith("MemTotal:"):
                return int(line.split()[1]) / (1024.0 * 1024.0)
    except Exception:
        pass
    return 0.0


def recommend_moe(vram_mb, ram_gb):
    """Biggest MoE whose experts fit in system RAM and whose attention fits VRAM,
    or None. The win: ~30B-class quality at ~7B speed on a small card."""
    if vram_mb < 4000:                 # need a bit of VRAM for attention + KV
        return None
    ram_budget = ram_gb * 0.7          # leave headroom for the OS + apps
    best = None
    for tag, total, active in MOE_MODELS:
        total_gb = total * 4.8 / 8.0   # Q4 GGUF size ≈ params * bpw / 8
        if total_gb <= ram_budget and (best is None or total > best[1]):
            best = (tag, total, active)
    return best


def recommend_model():
    """Advisor → Turbo model pick: the BIGGEST model whose Q4_K_M weights fit
    100% in VRAM (so Turbo offloads it fully — the single biggest speed lever).
    Returns (tag, vram_mb, budget_gb). Falls back to a small model with no GPU."""
    vram_mb = _detect_vram_mb()
    budget = max(vram_mb / 1024.0 - 1.2, 0.0)     # overhead + KV headroom
    best = None
    for tag, p in RECOMMEND_MODELS:
        q4 = p * 4.8 / 8.0                          # GGUF GB ≈ params * bpw / 8
        if q4 <= budget and (best is None or p > best[1]):
            best = (tag, p)
    tag = best[0] if best else ("llama3.2:3b" if budget >= 1.8 else "llama3.2:1b")
    return tag, vram_mb, budget


def cmd_recommend():
    """Print the recommended Turbo model. stdout = just the tag (machine-readable
    for the Monitor); human detail goes to stderr."""
    tag, vram_mb, budget = recommend_model()
    print(tag)
    if vram_mb > 0:
        print(f":: {vram_mb / 1024.0:.1f}GB VRAM → fits ~{budget:.1f}GB on GPU → "
              f"recommended Turbo model: {tag}", file=sys.stderr)
    else:
        print(":: no GPU/VRAM detected → small CPU-friendly model recommended: "
              f"{tag}", file=sys.stderr)
    # MoE power pick: a much bigger brain that still runs fast here via expert
    # offload (only stdout stays machine-readable; this is human advice).
    moe = recommend_moe(vram_mb, _total_ram_gb())
    if moe:
        print(f":: power pick (MoE): {moe[0]} — {moe[1]:.0f}B brain, only "
              f"~{moe[2]:.0f}B active/token, so Turbo runs it at small-model speed "
              f"(experts streamed from RAM). Pull it and run Turbo as usual.",
              file=sys.stderr)


def _performance_cores(fallback):
    """Best-effort count of the FAST physical cores for CPU inference.

    On Intel hybrid CPUs (P + E cores, e.g. the i5-13420H) spreading llama.cpp
    across the slow E-cores adds cross-core sync stalls and REGRESSES tokens/s,
    so we count only the top-frequency physical cores (one entry per core_id,
    HT siblings deduped). Falls back to `fallback` (physical core count) on any
    machine that doesn't expose the topology (VMs, odd kernels)."""
    base = "/sys/devices/system/cpu"
    try:
        core_freq = {}                       # physical core_id -> max freq (kHz)
        for cpu in os.listdir(base):
            if not re.fullmatch(r"cpu\d+", cpu):
                continue
            try:
                with open(f"{base}/{cpu}/topology/core_id") as f:
                    cid = int(f.read().strip())
                with open(f"{base}/{cpu}/cpufreq/cpuinfo_max_freq") as f:
                    mf = int(f.read().strip())
            except (OSError, ValueError):
                return fallback              # incomplete data -> don't guess
            core_freq[cid] = max(core_freq.get(cid, 0), mf)
        if not core_freq:
            return fallback
        top = max(core_freq.values())
        # P-cores sit within ~5% of the top clock; E-cores are well below it.
        fast = sum(1 for f in core_freq.values() if f >= top * 0.95)
        return fast if fast >= 1 else fallback
    except OSError:
        return fallback


def server_cmd(main_gguf, draft_gguf):
    binp = llama_bin("llama-server")
    if not binp:
        return None
        
    try:
        s = json.load(open("/run/genesi-ai-mode/state.json"))
        hw = s.get("hardware") or {}
        gpus = hw.get("gpus") or []
        vram_mb = max([g.get("vram_mb") or 0 for g in gpus], default=0)
        ram_mb = hw.get("ram_mb") or 0
        phys_cores = hw.get("physical_cores") or 4
    except Exception:
        vram_mb = 0
        ram_mb = 0
        phys_cores = 4

    # state.json is the primary source, but the daemon can miss the GPU (it
    # profiles at boot, possibly before the driver is ready, and nvidia-smi
    # doesn't work under nouveau/NVK at all). If there's no VRAM figure, detect
    # it directly (nvidia-smi, then the Vulkan backend) so we still offload to
    # the GPU instead of silently falling back to CPU.
    if vram_mb <= 0:
        vram_mb = _detect_vram_mb()

    gpu = vram_mb > 0 or shutil.which("nvidia-smi") is not None
    vram_gb = vram_mb / 1024.0
    budget_gb = max(vram_gb - 1.2, 0.5) if vram_gb >= 1.0 else 0.0

    try:
        main_gb = os.path.getsize(main_gguf) / (1024**3)
    except OSError:
        main_gb = 0.0

    try:
        draft_gb = os.path.getsize(draft_gguf) / (1024**3) if draft_gguf else 0.0
    except OSError:
        draft_gb = 0.0

    fits_main = main_gb <= budget_gb if budget_gb > 0 else False
    fits_both = (main_gb + draft_gb) <= budget_gb if budget_gb > 0 else False

    # Mixture-of-Experts detection. A MoE model only activates a few experts per
    # token, so when it doesn't fit VRAM we DON'T spill random dense layers over
    # the slow PCIe bus — we keep all attention on the GPU and push just the
    # expert (FFN) tensors to CPU RAM (`--n-cpu-moe K`). Result: big-model brains
    # at near-small-model speed on a small card. Reading the GGUF header is cheap
    # and defensive (any failure -> {} -> we fall back to plain partial offload).
    moe = gguf_meta(main_gguf, (".expert_count", ".block_count"))
    is_moe = (int(moe.get(".expert_count") or 0) > 1
              and not _env_flag("GENESI_TURBO_NO_MOE"))
    n_cpu_moe = None            # how many layers' experts to keep on CPU (MoE)
    ncmoe_flag = None           # the flag name this llama.cpp build supports

    # Decide WHERE we run and HOW MANY layers go on the GPU. ngl_value:
    #   None  -> CPU only
    #   "999" -> full offload (the whole model fits in VRAM, fastest)
    #   "auto" -> let llama.cpp fit as many layers as the VRAM holds (a blind
    #             -ngl 999 OOMs a small/partially-full card; "auto" is VRAM-safe)
    # Spec decoding only pays off when BOTH target and draft fit on the GPU.
    ngl_value = None
    if gpu:
        if fits_both:
            ngl_value = "999"                # target + draft both fit -> spec on GPU
        elif fits_main:
            if draft_gguf:
                print(f"   [!] Draft model dropped: not enough VRAM for both (budget: {budget_gb:.1f}GB).", flush=True)
            draft_gguf = None
            ngl_value = "999"
        else:
            if vram_gb > 0:
                print(f"   [!] WARNING: Model ({main_gb:.1f}GB) exceeds safe VRAM budget ({budget_gb:.1f}GB).", flush=True)
                print("       Part of it runs on the CPU, so decode will be SLOW no "
                      "matter the backend. For full-GPU speed pick a model that "
                      "fits — see `genesi-ai-turbo recommend` — or pull a smaller "
                      "quant (e.g. a q3_K_M / IQ4_XS tag) of this model.", flush=True)
            free_ram_gb = (ram_mb / 1024.0) * 0.6
            if ram_mb > 0 and main_gb > free_ram_gb:
                print("   [!] DANGER: System RAM is too low to safely offload. Expect severe lag or OOM.", flush=True)
            if draft_gguf:
                print("   [!] Draft model dropped: the target model is already spilling VRAM.", flush=True)
                draft_gguf = None            # never speculate when the target spills
            if is_moe and vram_gb > 2.0:
                # MoE expert-offload (the out-of-the-box win): keep ALL attention
                # layers on the GPU (-ngl 999) and move just enough layers' EXPERT
                # tensors to CPU RAM to fit the VRAM budget. Only a couple of
                # experts fire per token, so streaming them from RAM costs far less
                # than spilling whole dense layers over PCIe.
                ncmoe_flag = _pick_flag(_llama_help(), "--n-cpu-moe", "--cpu-moe")
            if is_moe and ncmoe_flag and vram_gb > 2.0:
                blocks = int(moe.get(".block_count") or 0)
                # ≈90% of a big MoE's bytes are expert tensors; size per layer.
                per_layer = (main_gb * 0.9 / blocks) if blocks > 0 else 0.0
                if ncmoe_flag == "--n-cpu-moe" and per_layer > 0:
                    over = max(main_gb - budget_gb, 0.0)
                    k = int(over / per_layer) + 2            # +headroom for KV/ctx
                    k = max(1, min(blocks, k))
                    n_cpu_moe = _env_int("GENESI_TURBO_NCMOE", k)
                    print(f"   [moe] Mixture-of-Experts: experts of {n_cpu_moe}/{blocks} "
                          f"layers on CPU RAM, attention 100% on GPU — big-model "
                          f"brains at small-model speed.", flush=True)
                else:
                    # Build only exposes the all-or-nothing --cpu-moe (all experts
                    # on CPU). Still a huge win vs random dense spill.
                    n_cpu_moe = -1                            # sentinel: --cpu-moe
                    print("   [moe] Mixture-of-Experts: all expert tensors on CPU "
                          "RAM, attention 100% on GPU (--cpu-moe).", flush=True)
                ngl_value = "999"            # all attention layers on the GPU
            elif vram_gb > 2.0:
                # Dense model: partial offload — fit as many layers as the VRAM
                # holds instead of forcing all of them. 'auto' needs a recent
                # llama.cpp; older builds force all layers.
                ngl_value = "auto" if "--gpu-layers" in _llama_help() and "auto" in _llama_help() else "999"
    else:
        # CPU-only. Running a second (draft) model on the same cores almost
        # always costs more than the speculation saves, and the extra weights
        # risk OOM on low-RAM laptops. This is exactly what made Turbo SLOWER
        # than stock ollama on an 8GB CPU-only notebook (it kept the draft).
        # Disable it unless the user explicitly opts in.
        if draft_gguf and not _env_flag("GENESI_TURBO_FORCE_DRAFT"):
            print("   [!] CPU-only: speculative decoding disabled (a CPU draft slows decode). "
                  "Set GENESI_TURBO_FORCE_DRAFT=1 to override.", flush=True)
            draft_gguf = None

    # GPU offload active (full or partial) gates the GPU-only tunings below.
    use_ngl_999 = ngl_value is not None

    ctx = _env_int("GENESI_TURBO_CTX", 4096)
    # Prefill (reading the prompt) is compute-bound, so a bigger physical batch
    # (n_ubatch / -ub) reads the prompt in fewer, fatter passes. Larger -ub costs
    # more compute-buffer memory, so default to a modest bump only on GPU and the
    # llama.cpp default (512) on CPU. Env-overridable for on-HW tuning.
    batch = _env_int("GENESI_TURBO_BATCH", 2048)
    ubatch = _env_int("GENESI_TURBO_UBATCH", 1024 if gpu else 512)
    threads = _env_int("GENESI_TURBO_THREADS", _performance_cores(phys_cores))
    cmd = [binp, "-m", main_gguf, "--host", "127.0.0.1",
           "--port", str(TURBO_PORT),
           "-c", str(ctx),
           "-b", str(batch),               # logical prefill batch
           "-ub", str(ubatch),             # physical prefill batch (n_ubatch)
           # KV-cache reuse: keep matching prefix chunks across requests via KV
           # shifting, so a repeated system prompt isn't re-prefilled every turn
           # (near-instant on the 2nd+ message). Pure win, negligible memory.
           "--cache-reuse", str(_env_int("GENESI_TURBO_CACHE_REUSE", 256)),
           "--threads", str(threads)]
           # NOTE: NO --prompt-cache / --prompt-cache-all here. Those are
           # llama-CLI (main) flags; llama-server rejects them with
           #   error: invalid argument: --prompt-cache
           # and refuses to start (broke every Turbo launch, 2026-06-05).
           # In-session prefix reuse is already handled by --cache-reuse above;
           # cross-restart persistence in llama-server is a runtime API
           # (--slot-save-path + /slots?action=save), not a startup flag.

    # Flash attention + quantized KV cache are a clear win on the GPU (they cut
    # memory bandwidth, which is the bottleneck there), but on CPU the q8_0 KV
    # has to be de-quantized every single step and CPU flash-attn isn't faster —
    # both REGRESS tokens/s. So: GPU gets -fa on + q8_0 KV; CPU gets f16 KV
    # (llama.cpp default, no flag) and lets llama.cpp auto-decide flash-attn.
    if use_ngl_999:
        cmd += ["-fa", "on",                 # flash attention (decode + prefill)
                "--cache-type-k", "q8_0",    # 8-bit KV halves KV bandwidth on GPU
                "--cache-type-v", "q8_0"]
    else:
        cmd += ["-fa", "auto"]               # CPU: f16 KV (default) + auto FA

    if ngl_value:
        cmd += ["-ngl", ngl_value]

    # MoE expert-offload flag (set above when a Mixture-of-Experts model spills
    # VRAM): --n-cpu-moe K keeps K layers' experts on CPU RAM; --cpu-moe keeps
    # them all there. Attention stays on the GPU via -ngl 999.
    if n_cpu_moe is not None and ncmoe_flag:
        if ncmoe_flag == "--n-cpu-moe" and n_cpu_moe > 0:
            cmd += ["--n-cpu-moe", str(n_cpu_moe)]
        else:
            cmd += ["--cpu-moe"]

    # mlock: pin the model in RAM (no swap/reclaim) for steady CPU inference.
    # Opt-in only — risky on low-RAM machines and the live ISO (RAM-backed fs),
    # so default OFF; enable with GENESI_TURBO_MLOCK=1.
    if _env_flag("GENESI_TURBO_MLOCK"):
        cmd += ["--mlock"]

    help_txt = _llama_help()

    # CPU decode tuning (GPU-less boxes, where decode is CPU-bound). Two real wins:
    #  - SPLIT the thread counts: --threads stays the fast PHYSICAL cores for
    #    DECODE (memory-bandwidth-bound — SMT siblings / E-cores just add sync
    #    stalls), while --threads-batch uses ALL logical cores for PREFILL
    #    (compute-bound — SMT actually helps there). Reading the prompt gets faster
    #    without slowing generation.
    #  - --prio 2 (above-normal thread scheduling priority) cuts run-to-run jitter
    #    from other desktop processes. Both gated on --help (names vary) and
    #    env-tunable; skip the lot with GENESI_TURBO_NO_CPU_TUNE=1.
    if not gpu and not _env_flag("GENESI_TURBO_NO_CPU_TUNE"):
        tb_flag = _pick_flag(help_txt, "--threads-batch", "-tb")
        if tb_flag:
            cmd += [tb_flag, str(_env_int("GENESI_TURBO_THREADS_BATCH",
                                          os.cpu_count() or threads))]
        if "--prio" in help_txt:
            cmd += ["--prio", str(_env_int("GENESI_TURBO_PRIO", 2))]

    # Persistent prompt/KV cache to disk (Zero Cold-Start). --slot-save-path
    # enables llama-server's runtime slot save/restore API (/slots?action=save|
    # restore), so a long system-prompt's KV can survive a server restart — the
    # first reply of a returning chat stays fast even after a reboot. Harmless
    # when unused: it only enables the capability + a save dir, never changes
    # decode. Path defaults to a per-user cache; gated on the binary supporting
    # the flag. Disable with GENESI_TURBO_NO_SLOT_CACHE=1.
    if "--slot-save-path" in help_txt and not _env_flag("GENESI_TURBO_NO_SLOT_CACHE"):
        slot_dir = (os.environ.get("GENESI_TURBO_SLOT_PATH")
                    or os.path.expanduser("~/.cache/genesi-turbo/slots"))
        try:
            os.makedirs(slot_dir, exist_ok=True)
            cmd += ["--slot-save-path", slot_dir]
        except OSError:
            pass

    if draft_gguf:
        # Speculative decoding with a same-family draft model. The draft-count
        # flag was renamed in recent llama.cpp: master uses --spec-draft-n-max,
        # older builds use --draft. Pick whatever the installed binary lists so
        # the server doesn't refuse to start on a "removed argument".
        draft_max = _env_int("GENESI_TURBO_DRAFT_MAX", 8)
        max_flag = _pick_flag(help_txt, "--spec-draft-n-max", "--draft-max", "--draft")
        cmd += ["-md", draft_gguf]
        if max_flag:
            cmd += [max_flag, str(draft_max)]
        # The draft MUST be GPU-resident too (-ngld). Without it the draft runs
        # on the CPU while the target is on the GPU, so the slow CPU draft
        # becomes the bottleneck and speculation yields no speedup.
        if use_ngl_999:
            cmd += ["-ngld", "999"]
        # Dynamic draft length (Lote C): instead of always proposing a fixed N
        # tokens, let the draft length ADAPT to the live acceptance rate —
        # speculate more on easy/repetitive spans, back off on hard ones. We set
        # a floor (--draft-min) and a probability threshold (--draft-p-min) so
        # llama.cpp stops drafting once the draft's confidence drops. Beats a
        # fixed N. Flag names vary by version, so each is gated on --help and
        # simply skipped on a build that doesn't expose it (then N stays fixed).
        # Env-tunable: GENESI_TURBO_DRAFT_MIN / GENESI_TURBO_DRAFT_P.
        min_flag = _pick_flag(help_txt, "--spec-draft-n-min", "--draft-min", "--draft-n-min")
        if min_flag:
            cmd += [min_flag, str(_env_int("GENESI_TURBO_DRAFT_MIN", 1))]
        p_flag = _pick_flag(help_txt, "--spec-draft-p-min", "--draft-p-min")
        if p_flag:
            cmd += [p_flag, (os.environ.get("GENESI_TURBO_DRAFT_P", "").strip() or "0.6")]
        # Recent llama.cpp LOADS the draft but does NOT speculate unless an
        # implementation is selected: --spec-type defaults to 'none', which logs
        # "no implementations specified for speculative decoding" — the draft
        # just wastes VRAM with zero speedup (exactly what we saw). draft-simple
        # is the classic draft-model speculation. Older builds without
        # --spec-type speculate from -md alone, so we only add it when supported.
        if "--spec-type" in help_txt:
            cmd += ["--spec-type", "draft-simple"]
    elif "--spec-type" in help_txt and not _env_flag("GENESI_TURBO_NO_NGRAM"):
        # No draft model: model-free n-gram / prompt-lookup speculation. It
        # speculates from the context's OWN n-grams — no second model, no extra
        # VRAM, negligible compute. HUGE on code / agent / RAG / edit workloads
        # where the output copies chunks of the input (Genesi Code!), and harmless
        # on novel text (output is identical either way). Now enabled on GPU too,
        # not just CPU-only: ollama doesn't do this by default, so it's a real
        # Turbo edge for fitting models that have NO same-family draft (mistral,
        # gemma1, phi…) — exactly the case where Turbo used to equal plain ollama.
        # It's also the engine behind "retrieval speculation": when MemPalace
        # injects a relevant PAST answer into the context, n-gram picks those
        # tokens straight up (REST-lite, no llama.cpp fork). Disable with
        # GENESI_TURBO_NO_NGRAM=1.
        cmd += ["--spec-type", "ngram-simple"]

    return cmd


def wait_ready(timeout=900):   # big models on a CPU-only VM can take 5-8 min
    end = time.time() + timeout
    while time.time() < end:
        try:
            with urllib.request.urlopen(f"http://127.0.0.1:{TURBO_PORT}/health",
                                        timeout=2) as r:
                if json.loads(r.read()).get("status") == "ok":
                    return True
        except Exception:
            pass
        time.sleep(1)
    return False


def turbo_healthy():
    """Is a Turbo server already up and serving on our port?"""
    try:
        with urllib.request.urlopen(f"http://127.0.0.1:{TURBO_PORT}/health",
                                    timeout=2) as r:
            return json.loads(r.read()).get("status") == "ok"
    except Exception:
        return False


def port_busy(port=TURBO_PORT):
    """True only if something is ACTIVELY LISTENING on 127.0.0.1:<port>.

    We set SO_REUSEADDR before bind. Without it, a just-stopped llama-server
    leaves the port in TIME_WAIT (the kernel holds 127.0.0.1:11435 for ~1-2 min
    for its closed client connections), so a plain bind() fails with EADDRINUSE
    and we'd WRONGLY report "busy" — that's the "toggle Turbo off then on within a
    few minutes fails as if it's already running, and pkill finds nothing on the
    port" bug. SO_REUSEADDR lets bind succeed over a TIME_WAIT remnant, so this
    returns True only for a LIVE listener. (llama-server's HTTP backend also binds
    with SO_REUSEADDR, so it can re-take the port immediately too.)"""
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            s.bind(("127.0.0.1", port))
            return False
        except OSError:
            return True


def free_turbo_port():
    """Free our port by stopping any llama-server holding it, and WAIT until the
    socket is actually released.

    The old version just fired `pkill` (SIGTERM) and slept 1.5s. llama-server
    catches SIGTERM and unwinds the model + GPU context first, so it often still
    held the port after the sleep — then the very next `serve` saw the port busy
    and bailed with "already running", even though the user had just toggled
    Turbo off. That's the flaky on/off the user hit. Now: SIGTERM, poll until the
    port frees, then escalate to SIGKILL if it's still bound."""
    if not shutil.which("pkill"):
        return
    pattern = f"llama-server.*--port {TURBO_PORT}"
    subprocess.run(["pkill", "-f", pattern], check=False)
    # Give it up to ~6s to shut down cleanly and release the socket.
    for _ in range(24):
        if not port_busy():
            return
        time.sleep(0.25)
    # Still holding the port — force kill, then wait a final moment for the
    # kernel to reclaim the socket.
    subprocess.run(["pkill", "-9", "-f", pattern], check=False)
    for _ in range(16):
        if not port_busy():
            return
        time.sleep(0.25)


def measure(n=256):
    body = json.dumps({"prompt": PROMPT, "n_predict": n,
                       "temperature": 0.7, "cache_prompt": False}).encode()
    req = urllib.request.Request(f"http://127.0.0.1:{TURBO_PORT}/completion",
                                 data=body, headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=900) as r:
        t = json.loads(r.read()).get("timings", {})
    return t.get("predicted_per_second"), t.get("predicted_n")


def stop(proc):
    try:
        proc.send_signal(signal.SIGINT)
        proc.wait(timeout=10)
    except Exception:
        try:
            proc.kill()
        except Exception:
            pass


def _tail(path, n=18):
    try:
        return "".join(open(path).readlines()[-n:])
    except Exception:
        return ""


def cmd_bench(main, draft):
    main_g = ensure(main)
    if not main_g:
        sys.exit(f"could not resolve/pull {main}")
    if not llama_bin("llama-server"):
        sys.exit("llama-server not found — install the Genesi Vulkan build:\n"
                 "  sudo pacman -S genesi-llama-cpp   (ships llama.cpp + Vulkan)")
    draft = draft or pick_draft(main)
    if not draft:
        sys.exit(f"no same-family draft for {main}; pass one explicitly:\n"
                 f"  genesi-ai-turbo bench {main} qwen2.5:0.5b")
    draft_g = ensure(draft)
    if not draft_g:
        sys.exit(f"could not resolve/pull draft {draft}")

    results = {}
    for label, dg in (("no-spec", None), ("turbo (spec)", draft_g)):
        print(f":: starting {label} ...", flush=True)
        # bench is a diagnostic: force the draft through even on CPU-only so the
        # user can SEE the real spec-vs-no-spec delta on their own hardware.
        # `serve` auto-disables the draft on CPU (where it's a net loss); here we
        # want the measurement, not the policy.
        if dg:
            os.environ["GENESI_TURBO_FORCE_DRAFT"] = "1"
        cmd = server_cmd(main_g, dg)
        print("   " + " ".join(cmd), flush=True)
        log = tempfile.NamedTemporaryFile("w", delete=False, suffix=".log").name
        proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=open(log, "w"))
        try:
            if not wait_ready():
                print(f"   {label}: server never became ready — last log lines:")
                print(_tail(log))
                continue
            tps, ntok = measure()
            results[label] = tps
            print(f"   {label}: {tps:.1f} tok/s ({ntok} tokens)")
        finally:
            stop(proc)
        time.sleep(2)

    a, b = results.get("no-spec"), results.get("turbo (spec)")
    print(f"\n  Genesi Turbo — {main}  (draft: {draft})\n")
    if a and b:
        print(f"  {'no-spec':16}{a:8.1f} tok/s")
        print(f"  {'turbo (spec)':16}{b:8.1f} tok/s")
        print(f"\n  >> {a:.1f} -> {b:.1f} tok/s   ({(b - a) / a * 100:+.0f}%)  "
              f"same output, speculative decoding")
    else:
        print("  (incomplete — run `genesi-ai-turbo serve %s` to see server logs)" % main)


def _serve_with_fallback(main_g, draft_g):
    """Launch the Turbo server, degrading GRACEFULLY if an optimisation makes it
    fail to load. Some models load in ollama (its own bundled llama.cpp) but trip
    our system llama-server — usually `--n-cpu-moe` (MoE expert-offload) or a draft
    model. Instead of just dying with a scary loader error, we try the optimised
    command and, if it doesn't come up, retry without the riskier extras, ending
    with plain full/auto offload (exactly what ollama does). The final, plainest
    variant is exec'd so the steady-state process is llama-server itself (clean
    stop / health / port handling). For an already-plain command (no MoE, no
    draft) this is a single exec — zero behaviour change from before."""
    full = server_cmd(main_g, draft_g)
    if not full:
        return
    variants = [("optimised", full)]
    risky = ("--n-cpu-moe" in full) or ("--cpu-moe" in full) or bool(draft_g)
    if ("--n-cpu-moe" in full) or ("--cpu-moe" in full):
        os.environ["GENESI_TURBO_NO_MOE"] = "1"
        nomoe = server_cmd(main_g, draft_g)
        os.environ.pop("GENESI_TURBO_NO_MOE", None)
        if nomoe and nomoe != full:
            variants.append(("no-MoE offload", nomoe))
    if draft_g:
        os.environ["GENESI_TURBO_NO_MOE"] = "1"
        plain = server_cmd(main_g, None)
        os.environ.pop("GENESI_TURBO_NO_MOE", None)
        if plain and all(plain != c for _, c in variants):
            variants.append(("plain offload", plain))

    last = len(variants) - 1
    for i, (label, cmd) in enumerate(variants):
        if risky:
            print(f":: Genesi Turbo: trying {label}…", flush=True)
        print("   " + " ".join(cmd), flush=True)
        if i == last:
            os.execvp(cmd[0], cmd)            # final attempt becomes the process
            return
        log = tempfile.NamedTemporaryFile("w", delete=False, suffix=".log").name
        proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL,
                                stderr=open(log, "w"))
        ok, end = False, time.time() + 900    # a big model can take minutes to load
        while time.time() < end:
            if turbo_healthy():
                ok = True
                break
            if proc.poll() is not None:       # process exited = load failed
                break
            time.sleep(1)
        if ok:
            print(f":: Genesi Turbo up ({label}). API: "
                  f"http://127.0.0.1:{TURBO_PORT}/v1   Ctrl-C to stop", flush=True)
            try:
                proc.wait()
            except KeyboardInterrupt:
                stop(proc)
            return
        print(f"[!] {label} failed to come up — falling back:\n{_tail(log)}",
              file=sys.stderr, flush=True)
        try:
            proc.kill()
        except Exception:
            pass
        free_turbo_port()


def cmd_serve(main, draft, spec=False):
    # Port already taken? This is common — the Monitor or a previous terminal
    # already started Turbo. If it's healthy, reuse it (don't fail to bind).
    # If it's bound but unresponsive, it's a stale llama-server: free the port.
    if port_busy():
        if turbo_healthy():
            print(f":: Turbo is already running at http://127.0.0.1:{TURBO_PORT} — reusing it.")
            return
        print(f"[!] Port {TURBO_PORT} is held by an unresponsive process — freeing it…",
              file=sys.stderr, flush=True)
        free_turbo_port()
        if port_busy():
            sys.exit(f"port {TURBO_PORT} is still busy. Stop the process manually:\n"
                     f"  pkill -f 'llama-server.*{TURBO_PORT}'")
    main_g = ensure(main)
    if not main_g:
        sys.exit(f"could not resolve/pull {main}")
    if not server_cmd(main_g, None):
        sys.exit("llama-server not found — install the Genesi Vulkan build:\n"
                 "  sudo pacman -S genesi-llama-cpp   (ships llama.cpp + Vulkan)")
    # Default Turbo = plain full GPU offload, the reliable proven win (GPU >> CPU
    # is where the big speedup comes from). Speculative decoding is a MAYBE-win:
    # it helps on a mature driver (CUDA) but can REGRESS on Vulkan/NVK, where the
    # draft + verification cost more than plain offload saves (measured: plain
    # offload 21 t/s vs spec ~baseline on an NVK 3050). So spec is opt-in — pass
    # a draft explicitly, or set GENESI_TURBO_SPEC=1. `bench` always compares
    # both so you can check whether spec actually helps on your hardware first.
    if draft is None and (spec or _env_flag("GENESI_TURBO_SPEC")):
        draft = pick_draft(main)
    draft_g = ensure(draft) if draft else None
    # No same-family draft, but the user opted into a self-draft (GENESI_TURBO_
    # SELF_DRAFT=1)? Build/cache a low-bit quant of the model itself as the draft.
    # server_cmd's VRAM-fit check still decides whether it's actually used.
    if (draft_g is None and (spec or _env_flag("GENESI_TURBO_SPEC"))
            and _env_flag("GENESI_TURBO_SELF_DRAFT")):
        draft_g = self_draft_path(main_g)
        if draft_g:
            draft = "self-draft (Q2)"
    print(f":: Genesi Turbo serving {main}" +
          (f" + draft {draft} (speculative)" if draft_g
           else " (full GPU offload)"))
    print(f"   API: http://127.0.0.1:{TURBO_PORT}/v1   (OpenAI-compatible)  Ctrl-C to stop")
    # Launch with graceful degradation: if MoE/draft trips the loader, fall back
    # to plain offload (what ollama does) instead of dying on a model ollama runs.
    _serve_with_fallback(main_g, draft_g)


def main():
    argv = sys.argv[1:]
    if argv and argv[0] in ("-h", "--help"):
        print(__doc__)
        return
    # Pull the speculative-decoding flag out of the args (it may appear anywhere).
    # Default: spec OFF (plain full GPU offload, the reliable win). Opt in with
    # --spec/--speculative, or globally with GENESI_TURBO_SPEC=1.
    spec = _env_flag("GENESI_TURBO_SPEC")
    # Did the user (or env) pin spec explicitly? If not, `serve` decides AUTO from
    # the backend: ON for the CUDA build (the proven win), OFF for Vulkan/NVK.
    spec_pinned = (_env_flag("GENESI_TURBO_SPEC")
                   or _env_flag("GENESI_TURBO_NO_SPEC"))
    pos = []
    for a in argv:
        al = a.lower()
        if al in ("--spec", "--speculative"):
            spec, spec_pinned = True, True
        elif al in ("--no-spec", "--no-speculative"):
            spec, spec_pinned = False, True
        else:
            pos.append(a)
    if not pos:
        print(__doc__)
        return
    action, rest = pos[0], pos[1:]
    if action == "recommend":
        cmd_recommend()
        return
    # AUTO spec: with nothing pinned, default to speculative decoding on a CUDA
    # build (it pays off there) and plain offload on Vulkan/NVK (where it can
    # regress). The draft is still dropped automatically if the target spills
    # VRAM, so this only ever engages when it can actually help.
    if not spec_pinned and backend_is_cuda():
        spec = True
    if action in ("bench", "serve"):
        if not rest:
            sys.exit(f"usage: genesi-ai-turbo {action} <model> [draft-model] [--spec]")
        if action == "bench":
            cmd_bench(rest[0], rest[1] if len(rest) > 1 else None)
        else:
            cmd_serve(rest[0], rest[1] if len(rest) > 1 else None, spec=spec)
    else:
        cmd_serve(action, rest[0] if rest else None, spec=spec)


if __name__ == "__main__":
    main()
