# ── Smart auto-detection (roadmap 2.6 follow-up) ──────────────────────────────
# The old logic treated "an AI process exists" as "AI Mode should be ON". But
# ollama runs `ollama serve` as a persistent systemd daemon — it's ALWAYS there
# once enabled — so AI Mode latched ON forever and never powered back down when
# the user stopped generating. We now drive AI Mode off *actual workload*:
#   active — generating right now (GPU/CPU busy, or a one-shot CLI is running)
#   warm   — a model is resident (ollama keep_alive / a Turbo server) but idle
#   idle   — a server may be listening, but nothing is loaded or working
# Hysteresis avoids flapping between chat turns (you read a reply, then type the
# next prompt 30 s later — that gap must NOT drop AI Mode):
#   • promote to "max" instantly when generation resumes (no perf lost),
#   • ease "max"→"balanced" only after WARM_DEMOTE_SECONDS without crunching
#     (releases GPU clock/power locks; governor stays performance),
#   • power AI Mode fully OFF only after IDLE_TIMEOUT_DEFAULT of no activity.
IDLE_TIMEOUT_DEFAULT = 90   # s of no AI activity before AI Mode powers down
WARM_DEMOTE_SECONDS  = 30   # s after generation stops before easing max→balanced
ACTIVE_GPU_UTIL      = 20   # % GPU utilization that counts as "actively generating"
ACTIVE_CPU_PCT       = 40   # % CPU (one core) of an AI proc that counts as active

# AI servers that run as persistent daemons on Genesi: their mere presence does
# NOT mean work is happening (ollama serve is always up). Anything else that
# matches AI_PROCESSES is a user-launched tool → presence counts as active use.
PERSISTENT_AI = ("ollama", "llama-server")

# Persistent state (survives reboot, unlike /run). Created by the service's
# StateDirectory=genesi-ai-mode → /var/lib/genesi-ai-mode (root-owned). We keep
# a tiny MRU of the model weight files the user actually loaded, so on the NEXT
# boot the daemon can warm the most-recently-used model into the page cache
# while the machine is idle — making the first prompt after login instant,
# instead of paying a cold disk load. Pure cache warming; nothing to restore.
PERSIST_DIR = "/var/lib/genesi-ai-mode"
WARM_DB     = PERSIST_DIR + "/warm.json"
WARM_DB_MAX = 4      # how many distinct models to remember (MRU)

