def _run(cmd, timeout=8):
    """Run an external tool, never let it hang the daemon. Returns (rc, out)."""
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return p.returncode, (p.stdout or "").strip()
    except (subprocess.TimeoutExpired, OSError) as e:
        logger.debug(f"cmd {cmd!r} failed: {e}")
        return 1, ""


def _atomic_write(path, data, mode=0o644):
    d = os.path.dirname(path)
    fd, tmp = tempfile.mkstemp(dir=d, prefix=".tmp-")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(data)
        os.chmod(tmp, mode)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def _read(path):
    try:
        with open(path) as f:
            return f.read().strip()
    except OSError:
        return None


def _write(path, value):
    try:
        with open(path, "w") as f:
            f.write(str(value))
        return True
    except OSError as e:
        logger.debug(f"write {path}={value} failed: {e}")
        return False


def _vulkan_vram_mb():
    """Largest GPU VRAM (MiB) as reported by llama.cpp's own backend
    (`llama-server --list-devices`). Vendor-agnostic — works under nouveau/NVK,
    RADV and ANV, where nvidia-smi and sysfs give us nothing. 0 if unavailable.
    Only used to SIZE a GPU we already found via DRM, never to invent one."""
    binp = shutil.which("llama-server") or "/usr/bin/llama-server"
    if not os.path.exists(binp):
        return 0
    try:
        r = subprocess.run([binp, "--list-devices"],
                           capture_output=True, text=True, timeout=20)
        text = (r.stdout or "") + (r.stderr or "")
    except Exception:
        return 0
    best = 0
    # device lines look like: "  Vulkan0: NVIDIA GeForce RTX 3050 (8448 MiB, ...)"
    for m in re.finditer(r"\((\d+)\s*MiB", text):
        best = max(best, int(m.group(1)))
    return best


def _performance_cpu_ids():
    """Logical CPU ids on the FASTEST physical cores (P-cores + their HT
    siblings). On a hybrid Intel CPU (P/E) this lets us pin inference to the
    fast cores so it never lands on the slow E-cores (which add cross-core sync
    stalls). On a uniform CPU it returns every CPU (so pinning is a no-op).
    Empty list on boxes that don't expose cpufreq (VMs) → caller skips pinning."""
    base = "/sys/devices/system/cpu"
    freqs = {}                                   # logical cpu id -> max freq (kHz)
    try:
        for cpu in os.listdir(base):
            m = re.fullmatch(r"cpu(\d+)", cpu)
            if not m:
                continue
            try:
                with open(f"{base}/{cpu}/cpufreq/cpuinfo_max_freq") as f:
                    freqs[int(m.group(1))] = int(f.read().strip())
            except (OSError, ValueError):
                return []                        # incomplete data → don't guess
    except OSError:
        return []
    if not freqs:
        return []
    top = max(freqs.values())
    return sorted(i for i, mf in freqs.items() if mf >= top * 0.95)


# ── Hardware detection ───────────────────────────────────────────────────────
class HardwareProfile:
    """One-shot profile of the host. `on_battery` is re-checked live."""

    def __init__(self):
        self.virtualized = self._detect_virt()
        self.cpu_vendor = self._cpu_vendor()
        self.logical_cores = psutil.cpu_count() or 1
        self.physical_cores = psutil.cpu_count(logical=False) or self.logical_cores
        self.has_governor = os.path.exists(GOVERNOR_GLOB.format(0))
        self.has_epp = os.path.exists(EPP_GLOB.format(0))
        self.gpus = self._detect_gpus()
        self.total_ram_mb = int(psutil.virtual_memory().total / (1024 * 1024))
        self.chassis = self._chassis()
        self.has_power_profiles = shutil.which("powerprofilesctl") is not None
        self.has_platform_profile = os.path.exists(PLATFORM_PROFILE)

    def _detect_virt(self):
        rc, out = _run(["systemd-detect-virt"], timeout=4)
        return rc == 0 and out not in ("", "none")

    def _cpu_vendor(self):
        info = _read("/proc/cpuinfo") or ""
        if "AuthenticAMD" in info:
            return "amd"
        if "GenuineIntel" in info:
            return "intel"
        return "unknown"

    def _detect_gpus(self):
        gpus = []
        nvidia_via_smi = False
        # NVIDIA via nvidia-smi (authoritative for VRAM + control surface)
        if shutil.which("nvidia-smi"):
            rc, out = _run(["nvidia-smi",
                            "--query-gpu=index,memory.total",
                            "--format=csv,noheader,nounits"])
            if rc == 0:
                for line in out.splitlines():
                    parts = [p.strip() for p in line.split(",")]
                    if len(parts) >= 2 and parts[0].isdigit():
                        gpus.append({"vendor": "nvidia", "index": int(parts[0]),
                                     "vram_mb": _to_int(parts[1])})
                        nvidia_via_smi = True
        # AMD / Intel / NVIDIA via DRM sysfs
        try:
            for card in sorted(os.listdir(DRM_PATH)):
                if not re.fullmatch(r"card\d+", card):
                    continue
                dev = os.path.join(DRM_PATH, card, "device")
                vendor = _read(os.path.join(dev, "vendor"))
                if vendor == "0x1002":
                    dpm = os.path.join(dev, "power_dpm_force_performance_level")
                    if os.path.exists(dpm):
                        gpus.append({"vendor": "amd", "card": card, "dpm": dpm})
                elif vendor == "0x8086":
                    g = {"vendor": "intel", "card": card}
                    # i915 exposes the GT frequency window directly under the
                    # card; gt_RP0 is the hardware ceiling we lift the cap to.
                    base = os.path.join(DRM_PATH, card)
                    gt_max = os.path.join(base, "gt_max_freq_mhz")
                    gt_rp0 = os.path.join(base, "gt_RP0_freq_mhz")
                    if os.path.exists(gt_max) and os.path.exists(gt_rp0):
                        g["gt_max"] = gt_max
                        g["gt_rp0"] = gt_rp0
                    gpus.append(g)
                elif vendor == "0x10de" and not nvidia_via_smi:
                    # NVIDIA present but nvidia-smi unusable (nouveau/NVK, or the
                    # proprietary driver not ready yet). Record it so we don't
                    # report "no GPU"; VRAM/control come later once nvidia-smi
                    # works (the run loop re-detects). No "index" key here, so
                    # the nvidia control path skips it until then.
                    gpus.append({"vendor": "nvidia", "card": card})
        except OSError:
            pass
        # We found a real GPU via DRM but couldn't size its VRAM (nouveau/NVK
        # have no nvidia-smi and no standard sysfs VRAM total). Ask llama.cpp's
        # Vulkan backend so the advisor/Turbo get a real budget instead of
        # falling back to "no GPU". Guarded by `gpus` so a CPU-only/VM box never
        # invents a GPU here.
        if gpus and not any((g.get("vram_mb") or 0) > 0 for g in gpus):
            vram = _vulkan_vram_mb()
            if vram > 0:
                gpus[0]["vram_mb"] = vram
        return gpus

    def _chassis(self):
        # A battery present => treat as laptop.
        try:
            for ps in os.listdir(POWER_SUPPLY):
                if (_read(os.path.join(POWER_SUPPLY, ps, "type")) or "") == "Battery":
                    return "laptop"
        except OSError:
            pass
        return "desktop"

    def on_battery(self):
        """True only if a battery is discharging (AC absent)."""
        try:
            for ps in os.listdir(POWER_SUPPLY):
                base = os.path.join(POWER_SUPPLY, ps)
                t = _read(os.path.join(base, "type"))
                if t == "Mains":
                    online = _read(os.path.join(base, "online"))
                    if online == "1":
                        return False
                elif t == "Battery":
                    if (_read(os.path.join(base, "status")) or "") == "Discharging":
                        return True
        except OSError:
            pass
        return False

    def summary(self):
        return {
            "virtualized": self.virtualized,
            "cpu_vendor": self.cpu_vendor,
            "physical_cores": self.physical_cores,
            "logical_cores": self.logical_cores,
            "ram_mb": self.total_ram_mb,
            "chassis": self.chassis,
            "gpus": [{k: v for k, v in g.items() if k in ("vendor", "vram_mb")}
                     for g in self.gpus],
        }


def _to_int(s, default=None):
    try:
        return int(float(s))
    except (TypeError, ValueError):
        return default


# ── The optimizer ────────────────────────────────────────────────────────────
class AIOptimizer:
    def __init__(self, hw):
        self.hw = hw
        self.ai_mode_active = False
        self.aggressive = False     # full power (AC or forced) vs battery-safe
        self.profile = "auto"       # effective intensity: max|balanced|battery
        # Performance-core pinning (hybrid Intel P/E). perf_cpus = the fast
        # logical CPUs; is_hybrid = there really is a slow tier to avoid.
        self.perf_cpus = _performance_cpu_ids()
        self.is_hybrid = 0 < len(self.perf_cpus) < (self.hw.logical_cores or 0)
        self.originals = {}
        self.applied = []           # static enable-time tweaks (governor, …)
        self.io_applied = []        # dynamic: I/O schedulers we switched
        self.ai_processes = []
        self.throttled = False      # thermal guard eased the governor
        self._preloaded = set()     # model files already warmed into RAM
        self.preloaded_mb = 0
        self._warm_files = {}       # {path: size} of the last-used model, kept
                                    # warm in page cache while idle (predictive)
        self._last_warm = 0.0       # throttle for maybe_warm_idle()
        self._warm_key = None       # id of the model currently in _warm_files
                                    # (so we persist the MRU only when it changes)
        self._seeded_warm = False   # did we seed _warm_files from the MRU at boot?
        # Smart auto-detect bookkeeping (see the activity model up top).
        self._activity = "idle"     # last classified workload state
        self._last_active_ts = 0.0  # last time we saw active|warm (OFF timeout)
        self._last_crunch_ts = 0.0  # last time we saw "active" (max→balanced demote)
        self._cpu_handles = {}      # {pid: psutil.Process} kept across polls so
                                    # cpu_percent() yields a real delta, not 0.0
        self._ollama_ps_cache = (0.0, None)  # (ts, /api/ps result) — cached per loop
        self._restore_originals_on_start()
        # If we recovered an active session, give it the full grace period so we
        # don't power down on the very first loop before any activity is seen.
        if self.ai_mode_active:
            self._last_active_ts = self._last_crunch_ts = time.time()

    # ── detection ────────────────────────────────────────────────────────────
    def detect_ai_processes(self):
        found = []
        for proc in psutil.process_iter(["pid", "name", "cmdline"]):
            try:
                name = (proc.info["name"] or "").lower()
                cmd = " ".join(proc.info["cmdline"] or []).lower()
                if any(p in name or p in cmd for p in AI_PROCESSES):
                    found.append(proc)
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        return found

    # ── workload classification ────────────────────────────────────────────
    def assess_activity(self, metrics):
        """Classify the live AI workload as 'active' | 'warm' | 'idle'.

        Cheap: reuses signals already gathered this loop (process list, GPU
        metrics, cached per-process CPU%, and a 4s-cached ollama /api/ps)."""
        if not self.ai_processes:
            return "idle"
        # A user-launched (non-daemon) AI tool running => active by presence.
        if self._has_interactive_ai():
            return "active"
        # GPU crunching right now (only meaningful once AI Mode polls the GPU).
        for g in metrics.get("gpus", []):
            if (g.get("util") or 0) >= ACTIVE_GPU_UTIL:
                return "active"
        # CPU crunching — covers CPU-only inference, where GPU util tells nothing.
        if self._ai_cpu_busy() >= ACTIVE_CPU_PCT:
            return "active"
        # Nothing crunching, but a model is resident: ollama keeps it for its
        # keep_alive window, and a llama-server (Turbo) always holds its model.
        if self._llama_server_present() or self._ollama_loaded():
            return "warm"
        # A server is listening but holds no model and isn't working => idle.
        return "idle"

    def _has_interactive_ai(self):
        """True if a detected AI process is NOT one of the always-on daemons
        (ollama serve / llama-server) — i.e. a tool the user launched to work."""
        for p in self.ai_processes:
            try:
                blob = (p.name() or "").lower() + " " + \
                       " ".join(p.cmdline() or []).lower()
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
            if not any(s in blob for s in PERSISTENT_AI):
                return True
        return False

    def _llama_server_present(self):
        for p in self.ai_processes:
            try:
                if "llama-server" in (p.name() or "").lower() or \
                   "llama-server" in " ".join(p.cmdline() or []).lower():
                    return True
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        return False

    def _ollama_loaded(self):
        """True if ollama currently has at least one model resident (/api/ps)."""
        return bool(self.ollama_status())

    def _ai_cpu_busy(self):
        """Highest CPU% (relative to one core) across AI processes. Uses cached
        Process handles so psutil computes a real delta between polls — a fresh
        handle would always read 0.0 on its first call. Returns 0.0 until a
        baseline exists, so a just-appeared process never reads as 'active'."""
        busy = 0.0
        live = {}
        for p in self.ai_processes:
            try:
                pid = p.pid
                handle = self._cpu_handles.get(pid) or p
                pct = handle.cpu_percent(None)   # since this handle's last call
                live[pid] = handle
                busy = max(busy, pct)
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        self._cpu_handles = live                 # self-cleans dead pids
        return busy

    def _idle_timeout(self):
        """Seconds of no activity before AI Mode powers down. Read live from
        advanced.conf (`ai_idle_timeout`), default IDLE_TIMEOUT_DEFAULT."""
        v = self._advanced_conf().get("ai_idle_timeout")
        try:
            n = int(v)
            return n if n >= 0 else IDLE_TIMEOUT_DEFAULT
        except (TypeError, ValueError):
            return IDLE_TIMEOUT_DEFAULT

    def read_force(self):
        v = (_read(FORCE_FILE) or "").lower()
        return v if v in ("on", "off") else None

    def read_profile(self):
        """User-selected intensity profile, or None (= auto)."""
        v = (_read(PROFILE_FILE) or "").lower()
        return v if v in ("max", "balanced", "battery") else None

    def _effective_profile(self, forced, activity=None):
        """Resolve the intensity to apply this run.
          max      — full send: governor + EPP + power-profile + GPU clocks
          balanced — fast CPU/mem (governor perf + mem knobs + pause hogs),
                     leaves power/thermal envelope and GPU power untouched
          battery  — lightest: pause hogs + mem knobs only, governor left as-is
          auto     — max while crunching, balanced when only resident-idle
                     (releases GPU clock/power locks), battery on battery
        An explicit user profile always wins. `activity` ('active'|'warm') only
        steers the auto path on AC: a loaded-but-idle model eases to balanced.
        """
        p = self.read_profile()
        if p in ("max", "balanced", "battery"):
            return p
        if self.hw.on_battery() and not forced:
            return "battery"
        # auto on AC (or forced ON): full power while working, ease off when the
        # model is merely resident-and-idle so we don't cook the GPU at idle.
        if activity == "warm" and not forced:
            return "balanced"
        return "max"

    # ── CPU governor ─────────────────────────────────────────────────────────
    def _read_governor(self):
        return _read(GOVERNOR_GLOB.format(0))

    def _set_governor(self, gov):
        if not gov:
            return
        n = 0
        for cpu in range(self.hw.logical_cores):
            if _write(GOVERNOR_GLOB.format(cpu), gov):
                n += 1
        if n:
            logger.info(f"CPU governor -> {gov} ({n} cores)")

    # ── EPP (energy/performance bias on amd-pstate / intel_pstate) ────────────
    def _read_epp(self):
        return _read(EPP_GLOB.format(0))

    def _set_epp(self, value):
        if not value:
            return
        n = 0
        for cpu in range(self.hw.logical_cores):
            if _write(EPP_GLOB.format(cpu), value):
                n += 1
        if n:
            logger.info(f"EPP -> {value} ({n} cores)")

    # ── THP ──────────────────────────────────────────────────────────────────
    def _read_thp(self):
        data = _read(THP_ENABLED) or ""
        m = re.search(r"\[(\w+)\]", data)
        return m.group(1) if m else None

    # ── power profile ────────────────────────────────────────────────────────
    def _read_power_profile(self):
        if self.hw.has_power_profiles:
            rc, out = _run(["powerprofilesctl", "get"])
            if rc == 0 and out:
                return ("ppd", out)
        if self.hw.has_platform_profile:
            v = _read(PLATFORM_PROFILE)
            if v:
                return ("platform", v)
        return None

    def _set_power_profile(self, target):
        if self.hw.has_power_profiles:
            _run(["powerprofilesctl", "set", target])
            logger.info(f"power profile -> {target}")
        elif self.hw.has_platform_profile:
            _write(PLATFORM_PROFILE, target)
            logger.info(f"platform_profile -> {target}")

    def _restore_power_profile(self, saved):
        if not saved:
            return
        kind, value = saved
        if kind == "ppd":
            _run(["powerprofilesctl", "set", value])
        elif kind == "platform":
            _write(PLATFORM_PROFILE, value)
        logger.info(f"power profile restored -> {value}")

    # ── GPU: NVIDIA ──────────────────────────────────────────────────────────
    def _nvidia_capture_and_apply(self):
        saved = []
        for gpu in [g for g in self.hw.gpus
                    if g["vendor"] == "nvidia" and "index" in g]:
            idx = str(gpu["index"])
            rc, out = _run(["nvidia-smi", "-i", idx,
                            "--query-gpu=persistence_mode,power.limit,power.max_limit",
                            "--format=csv,noheader,nounits"])
            if rc != 0 or not out:
                continue
            parts = [p.strip() for p in out.split(",")]
            pm, cur_pl, max_pl = (parts + ["", "", ""])[:3]
            entry = {"index": idx, "pm": pm, "pl": cur_pl, "clocks_locked": False}
            # Persistence keeps the driver loaded (lower latency between runs).
            _run(["nvidia-smi", "-i", idx, "-pm", "1"])
            mp = _to_int(max_pl)
            if mp:
                _run(["nvidia-smi", "-i", idx, "-pl", str(mp)])
            # Lock graphics + memory clocks at max so the card doesn't drop to a
            # lower P-state between requests — LLM inference is memory-bandwidth
            # bound, so a memory clock stuck below P0 costs tokens/s. Best-effort:
            # some GeForce cards reject -lmc; -rgc/-rmc on disable undoes it.
            entry["clocks_locked"] = self._nvidia_lock_clocks(idx)
            saved.append(entry)
            logger.info("NVIDIA GPU %s: persistence on, power limit -> %sW%s",
                        idx, max_pl, ", clocks locked max" if entry["clocks_locked"] else "")
        if saved:
            locked = sum(1 for s in saved if s.get("clocks_locked"))
            self.applied.append("NVIDIA max power+clocks (%d GPU)" % len(saved)
                                if locked else "NVIDIA max power (%d GPU)" % len(saved))
        return saved

    def _nvidia_lock_clocks(self, idx):
        rc, out = _run(["nvidia-smi", "-i", idx,
                        "--query-gpu=clocks.max.graphics,clocks.max.memory",
                        "--format=csv,noheader,nounits"])
        if rc != 0 or not out:
            return False
        parts = [p.strip() for p in out.split(",")]
        gmax, mmax = _to_int(parts[0] if parts else None), \
            _to_int(parts[1] if len(parts) > 1 else None)
        locked = False
        if gmax:
            rc, _ = _run(["nvidia-smi", "-i", idx, "-lgc", f"{gmax},{gmax}"])
            locked = locked or rc == 0
        if mmax:
            # -lmc may be unsupported on consumer cards; ignore failures.
            _run(["nvidia-smi", "-i", idx, "-lmc", f"{mmax},{mmax}"])
        return locked

    def _nvidia_restore(self, saved):
        for s in saved or []:
            idx = s["index"]
            if s.get("clocks_locked"):
                _run(["nvidia-smi", "-i", idx, "-rgc"])   # reset graphics clocks
                _run(["nvidia-smi", "-i", idx, "-rmc"])   # reset memory clocks
            pl = _to_int(s.get("pl"))
            if pl:
                _run(["nvidia-smi", "-i", idx, "-pl", str(pl)])
            if (s.get("pm") or "").lower().startswith("disab"):
                _run(["nvidia-smi", "-i", idx, "-pm", "0"])
            logger.info(f"NVIDIA GPU {idx} restored")

    # ── GPU: AMD ─────────────────────────────────────────────────────────────
    def _amd_capture_and_apply(self):
        saved = []
        for gpu in [g for g in self.hw.gpus if g["vendor"] == "amd"]:
            dpm = gpu["dpm"]
            cur = _read(dpm)
            if cur is None:
                continue
            saved.append({"dpm": dpm, "level": cur})
            _write(dpm, "high")
            logger.info(f"AMD GPU {gpu['card']}: dpm {cur} -> high")
        if saved:
            self.applied.append(f"AMD GPU high ({len(saved)})")
        return saved

    def _amd_restore(self, saved):
        for s in saved or []:
            _write(s["dpm"], s.get("level", "auto"))
            logger.info(f"AMD GPU restored -> {s.get('level')}")

    # ── GPU: Intel (i915 GT frequency cap) ───────────────────────────────────
    def _intel_capture_and_apply(self):
        saved = []
        for gpu in [g for g in self.hw.gpus if g["vendor"] == "intel" and g.get("gt_max")]:
            cur = _read(gpu["gt_max"])
            rp0 = _read(gpu["gt_rp0"])
            if cur is None or not rp0:
                continue
            saved.append({"path": gpu["gt_max"], "value": cur})
            if _write(gpu["gt_max"], rp0):
                logger.info(f"Intel GPU {gpu['card']}: max freq {cur} -> {rp0} MHz")
        if saved:
            self.applied.append(f"Intel GPU max freq ({len(saved)})")
        return saved

    def _intel_restore(self, saved):
        for s in saved or []:
            if _write(s["path"], s.get("value")):
                logger.info(f"Intel GPU max freq restored -> {s.get('value')} MHz")

    # ── originals persistence ────────────────────────────────────────────────
    def _persist_originals(self):
        try:
            _atomic_write(ORIGINALS_FILE, json.dumps(self.originals), mode=0o600)
        except OSError as e:
            logger.error(f"persist originals failed: {e}")

    def _clear_originals(self):
        self.originals = {}
        try:
            os.unlink(ORIGINALS_FILE)
        except FileNotFoundError:
            pass
        except OSError as e:
            logger.debug(f"clear originals: {e}")

    def _restore_originals_on_start(self):
        try:
            with open(ORIGINALS_FILE) as f:
                self.originals = json.load(f)
            self.ai_mode_active = True
            self.aggressive = self.originals.get("_aggressive", False)
            self.profile = self.originals.get("_profile", "auto")
            logger.info("Recovered AI Mode state from a previous run")
        except FileNotFoundError:
            pass
        except (OSError, ValueError) as e:
            logger.warning(f"ignoring unreadable originals: {e}")

    # ── advanced opt-in levers (2.8.9) ───────────────────────────────────────
    @staticmethod
    def _advanced_conf():
        """Parse /etc/genesi-ai-mode/advanced.conf (key=value, '#' comments),
        read live. Missing keys default OFF — these are opt-in tradeoffs."""
        conf = {}
        data = _read(ADVANCED_CONF)
        if data:
            for line in data.splitlines():
                line = line.split("#", 1)[0].strip()
                if "=" in line:
                    k, v = line.split("=", 1)
                    conf[k.strip().lower()] = v.strip().lower()
        return conf

    def _apply_advanced(self, o):
        """Apply the enabled opt-in knobs, capturing each original into
        o['advanced'] so disable restores it exactly. Default off; only reached
        on the aggressive (AC/forced) path. USB-autosuspend and mitigations-off
        are deliberately NOT here — see advanced.conf (boot-time / too broad)."""
        conf = self._advanced_conf()
        adv = {}
        # Explicit huge pages: reserve N×2MB pages for the weights. The
        # reservation is stolen from normal allocations, so it's risky on low
        # RAM — refuse if it would eat >50% of currently-free RAM.
        hp = conf.get("hugepages", "off")
        if hp not in ("", "off", "0", "false", "no"):
            try:
                want = int(hp)
            except ValueError:
                want = 0
            if want > 0:
                free_mb = psutil.virtual_memory().available / (1024 * 1024)
                if want * 2 <= free_mb * 0.5:
                    cur = _to_int(_read(NR_HUGEPAGES))
                    if _write(NR_HUGEPAGES, want):
                        adv["nr_hugepages"] = cur if cur is not None else 0
                        self.applied.append(f"huge pages: {want}×2MB")
                else:
                    logger.warning(
                        "huge pages: refusing %d pages (>50%% of free RAM)", want)
        # PCIe ASPM → performance: no link power-saving = lower latency to the
        # GPU. Sysfs lists the options with the active one in [brackets].
        if conf.get("pcie_aspm") in ("on", "performance", "1", "true", "yes"):
            cur = _read(PCIE_ASPM_POLICY)
            if cur and _write(PCIE_ASPM_POLICY, "performance"):
                m = re.search(r"\[(\w+)\]", cur)
                adv["pcie_aspm"] = m.group(1) if m else "default"
                self.applied.append("PCIe ASPM: performance")
        # sched-ext throughput scheduler (2.8.7): while AI Mode runs, load a BPF
        # sched_ext scheduler in throughput-oriented "server" mode via scxctl,
        # and switch back to whatever was running on disable. Opt-in AND
        # capability-gated: needs a sched_ext-capable kernel (/sys/kernel/
        # sched_ext) and the scxctl tool (CachyOS scx-scheds). No-op otherwise,
        # so it can never hurt a machine without sched-ext. Value may be a bare
        # scheduler name, "on" (→ scx_bpfland), optionally with ":mode".
        sx = conf.get("sched_ext", "off")
        if (sx not in ("", "off", "0", "false", "no")
                and os.path.isdir(SCHED_EXT_SYS) and shutil.which("scxctl")):
            sched, _, mode = sx.partition(":")
            sched = sched.strip()
            if sched in ("on", "1", "true", "yes"):
                sched = "scx_bpfland"
            mode = (mode.strip() or "server")
            prev = self._scx_get()
            # `start` if nothing is loaded, `switch` if a scheduler already runs
            # (start refuses while one is active; switch swaps it out).
            verb = "switch" if prev[0] else "start"
            if self._scx_run([verb, "-s", sched, "-m", mode]):
                adv["sched_ext"] = {"running": prev[0], "sched": prev[1],
                                    "mode": prev[2]}
                self.applied.append(f"sched-ext: {sched} ({mode})")
        # ZRAM AI swap (roadmap 2.8.11 Tier 4 / "Ideia 3"): bring up a compressed-
        # RAM swap device at HIGH priority while AI Mode runs aggressively, so that
        # when a big model + the browser exhaust RAM, cold pages compress in RAM
        # instead of stalling the desktop on slow SSD swap (the Windows-style
        # "freeze" when switching between the browser and the AI). Fully torn down
        # on disable. Opt-in; silent no-op without the zram module + tools, so it
        # can never hurt a machine that lacks them. Value: `on` (default size =
        # half RAM, capped 16G) or an explicit size like `8G`.
        zr = conf.get("zram_ai", "off")
        if (zr not in ("", "off", "0", "false", "no")
                and shutil.which("zramctl") and shutil.which("mkswap")
                and shutil.which("swapon")):
            if zr in ("on", "1", "true", "yes"):
                ram_gb = psutil.virtual_memory().total / (1024 ** 3)
                size = f"{int(min(max(ram_gb / 2, 1), 16))}G"
            else:
                size = zr.upper()
            dev = self._zram_setup(size)
            if dev:
                adv["zram_ai"] = dev
                self.applied.append(f"ZRAM AI swap: {size} ({dev})")
        if adv:
            o["advanced"] = adv

    @staticmethod
    def _zram_setup(size):
        """Create a zstd-compressed zram device of `size`, make it swap, and
        swapon at high priority (so the kernel prefers compressed RAM over disk).
        Returns the /dev/zramN path on success, else None. Never raises."""
        try:
            subprocess.run(["modprobe", "zram"], capture_output=True, timeout=10)
            # Prefer zstd; fall back to no explicit algorithm if unsupported.
            for args in (["zramctl", "--find", "--size", size, "--algorithm", "zstd"],
                         ["zramctl", "--find", "--size", size]):
                r = subprocess.run(args, capture_output=True, text=True, timeout=15)
                if r.returncode == 0:
                    dev = (r.stdout or "").strip().splitlines()
                    dev = dev[-1].strip() if dev else ""
                    break
            else:
                return None
            if not dev.startswith("/dev/"):
                return None
            if subprocess.run(["mkswap", dev], capture_output=True,
                              timeout=15).returncode != 0:
                subprocess.run(["zramctl", "--reset", dev], capture_output=True)
                return None
            if subprocess.run(["swapon", "--priority", "100", dev],
                              capture_output=True, timeout=15).returncode != 0:
                subprocess.run(["zramctl", "--reset", dev], capture_output=True)
                return None
            logger.info("ZRAM AI swap up: %s (%s)", dev, size)
            return dev
        except Exception as e:
            logger.debug("zram setup failed: %s", e)
            return None

    @staticmethod
    def _zram_teardown(dev):
        """swapoff + reset the zram device created by _zram_setup. Best-effort."""
        try:
            subprocess.run(["swapoff", dev], capture_output=True, timeout=15)
            subprocess.run(["zramctl", "--reset", dev], capture_output=True, timeout=10)
            logger.info("ZRAM AI swap removed: %s", dev)
        except Exception as e:
            logger.debug("zram teardown failed: %s", e)

    @staticmethod
    def _scx_run(args):
        """Run `scxctl <args>`; return True on success. Best-effort, never raises."""
        try:
            r = subprocess.run(["scxctl"] + args, capture_output=True,
                               text=True, timeout=15)
            return r.returncode == 0
        except Exception:
            return False

    @staticmethod
    def _scx_get():
        """(running, sched, mode) parsed from `scxctl get`, best-effort. Returns
        (False, None, None) when nothing is loaded or scxctl is unavailable."""
        try:
            out = subprocess.run(["scxctl", "get"], capture_output=True,
                                 text=True, timeout=10)
            txt = (out.stdout or "") + (out.stderr or "")
        except Exception:
            return (False, None, None)
        m = re.search(r"(scx_\w+)", txt)
        if not m:
            return (False, None, None)
        mm = re.search(r"\b(auto|gaming|powersave|lowlatency|server)\b", txt, re.I)
        return (True, m.group(1), mm.group(1).lower() if mm else None)

    def _restore_advanced(self, adv):
        if not adv:
            return
        if "nr_hugepages" in adv:
            _write(NR_HUGEPAGES, adv["nr_hugepages"])
        if adv.get("pcie_aspm"):
            _write(PCIE_ASPM_POLICY, adv["pcie_aspm"])
        sx = adv.get("sched_ext")
        if sx is not None:
            # Put the scheduler back exactly as we found it: switch to the
            # previous scx scheduler if one was running, otherwise stop ours so
            # the kernel returns to its default (CFS/EEVDF).
            if sx.get("running") and sx.get("sched"):
                self._scx_run(["switch", "-s", sx["sched"],
                               "-m", sx.get("mode") or "auto"])
            else:
                self._scx_run(["stop"])
        zdev = adv.get("zram_ai")
        if zdev:
            self._zram_teardown(zdev)

    def changes_summary(self):
        """2.8.8: structured before/after of exactly what AI Mode changed,
        derived from the persisted `originals` snapshot so it survives a daemon
        restart (the `applied` list does not). [{lever, from, to}, …]."""
        if not self.ai_mode_active:
            return []
        o = self.originals
        out = []

        def add(lever, frm, to):
            out.append({"lever": lever,
                        "from": "—" if frm in (None, "") else str(frm),
                        "to": str(to)})

        if "governor" in o:
            add("CPU governor", o.get("governor"), "performance")
        if "swappiness" in o:
            add("swappiness", o.get("swappiness"), 10)
        if "thp" in o:
            add("THP", o.get("thp"), "madvise")
        if o.get("epp"):
            add("EPP", o.get("epp"), "performance")
        if o.get("power_profile"):
            add("power profile", "prev", "performance")
        for key, label in (("nvidia", "NVIDIA"), ("amd", "AMD GPU"),
                           ("intel", "Intel GPU")):
            v = o.get(key)
            if v:
                try:
                    n = len(v)
                except TypeError:
                    n = 0
                add(label, "default",
                    "max power/clocks" + (f" ({n})" if n else ""))
        io = o.get("io_sched")
        if isinstance(io, dict):
            for dev, prev in io.items():
                add(f"I/O sched ({dev})", prev, "none/mq-deadline")
        adv = o.get("advanced") or {}
        if "nr_hugepages" in adv:
            add("huge pages", adv.get("nr_hugepages"), "reserved")
        if adv.get("pcie_aspm"):
            add("PCIe ASPM", adv.get("pcie_aspm"), "performance")
        sx = adv.get("sched_ext")
        if isinstance(sx, dict):
            add("sched-ext", sx.get("sched") or "default", "throughput scheduler")
        if adv.get("zram_ai"):
            add("ZRAM AI swap", "off", "high-priority compressed RAM")
        return out

    # ── transitions ──────────────────────────────────────────────────────────
    def enable_ai_mode(self, forced, profile=None):
        if self.ai_mode_active:
            return
        if profile is None:
            profile = self._effective_profile(forced)
        self.profile = profile
        self.aggressive = profile == "max"      # full power/GPU only on "max"
        logger.info("Enabling AI Mode (profile=%s)", profile)
        self.applied = []
        o = {"_aggressive": self.aggressive, "_profile": profile}

        # CPU governor → performance for max/balanced; the battery profile leaves
        # it untouched to preserve autonomy (the single biggest power knob).
        if self.hw.has_governor and profile in ("max", "balanced"):
            o["governor"] = self._read_governor()
            self._set_governor("performance")
            self.applied.append("CPU governor: performance")
        o["swappiness"] = _to_int(_read(SWAPPINESS))
        if _write(SWAPPINESS, 10):
            self.applied.append("swappiness: 10")
        # THP `madvise`, NOT `always`. Forcing `always` makes khugepaged churn
        # and stalls allocations on synchronous compaction — that showed up as
        # run-to-run jitter where AI Mode was occasionally *slower* on the same
        # prompt. `madvise` lets apps opt in without the forced-collapse penalty
        # (the standard high-performance recommendation). Captured + restored.
        o["thp"] = self._read_thp()
        if _write(THP_ENABLED, "madvise"):
            self.applied.append("THP: madvise")

        # Pause file indexers (CPU/IO hogs) — safe, reversible, also saves power
        self._pause_background()

        # On hybrid CPUs, inference gets pinned to the performance cores (done
        # live in prioritize_ai_processes, since the process may not exist yet).
        if self.is_hybrid:
            self.applied.append("AI cores: P-cores (%d)" % len(self.perf_cpus))

        # Power-hungry knobs only when on AC (or explicitly forced)
        if self.aggressive:
            if self.hw.has_epp:
                o["epp"] = self._read_epp()
                self._set_epp("performance")
                self.applied.append("EPP: performance")
            o["power_profile"] = self._read_power_profile()
            if o["power_profile"]:
                self._set_power_profile("performance")
                self.applied.append("power profile: performance")
            o["nvidia"] = self._nvidia_capture_and_apply()
            o["amd"] = self._amd_capture_and_apply()
            o["intel"] = self._intel_capture_and_apply()
            self._apply_advanced(o)

        self.originals = o
        self._persist_originals()
        self.ai_mode_active = True
        logger.info("AI Mode enabled: " + ", ".join(self.applied))

    def disable_ai_mode(self):
        if not self.ai_mode_active:
            return
        logger.info("Disabling AI Mode...")
        o = self.originals
        if "governor" in o:
            self._set_governor(o.get("governor"))
        if o.get("epp"):
            self._set_epp(o["epp"])
        if o.get("swappiness") is not None:
            _write(SWAPPINESS, o["swappiness"])
        if o.get("thp"):
            _write(THP_ENABLED, o["thp"])
        if o.get("power_profile"):
            self._restore_power_profile(o["power_profile"])
        self._nvidia_restore(o.get("nvidia"))
        self._amd_restore(o.get("amd"))
        self._intel_restore(o.get("intel"))
        self._restore_advanced(o.get("advanced"))
        self._restore_io(o.get("io_sched"))
        self._resume_background()

        for proc in self.ai_processes:
            try:
                proc.nice(0)
                if self.is_hybrid:
                    try:
                        proc.cpu_affinity(list(range(self.hw.logical_cores)))
                    except (psutil.NoSuchProcess, psutil.AccessDenied, OSError):
                        pass
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue

        self.ai_mode_active = False
        self.throttled = False
        self.profile = "auto"
        self.applied = []
        self.io_applied = []
        self._preloaded.clear()
        self.preloaded_mb = 0
        self._clear_originals()
        logger.info("AI Mode disabled")

    def prioritize_ai_processes(self):
        for proc in self.ai_processes:
            try:
                if proc.nice() != AI_NICE:
                    proc.nice(AI_NICE)
                    logger.info(f"Prioritized {proc.name()} (PID {proc.pid})")
                # On hybrid CPUs, pin inference to the performance cores so it
                # never gets migrated onto the slow E-cores. No-op on uniform
                # CPUs (perf_cpus == all CPUs) and VMs (is_hybrid False).
                if self.is_hybrid:
                    try:
                        if set(proc.cpu_affinity()) != set(self.perf_cpus):
                            proc.cpu_affinity(self.perf_cpus)
                            logger.info("Pinned %s (PID %s) to P-cores %s",
                                        proc.name(), proc.pid, self.perf_cpus)
                    except (psutil.NoSuchProcess, psutil.AccessDenied, OSError):
                        pass
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue

    # ── model weights: preload into RAM + tune the disk they live on ─────────
    def _find_model_files(self):
        """Large weight files currently mmapped by the running AI processes.
        Reads /proc/<pid>/maps (the daemon is root, so this works across the
        ollama user). Returns {path: size_bytes}."""
        files = {}
        for proc in self.ai_processes:
            try:
                pid = proc.pid
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
            maps = _read(f"/proc/{pid}/maps")
            if not maps:
                continue
            for line in maps.splitlines():
                # addr perms offset dev inode pathname
                parts = line.split(None, 5)
                if len(parts) < 6:
                    continue
                path = parts[5]
                if not path.startswith("/") or path in files:
                    continue
                low = path.lower()
                if not (low.endswith(MODEL_EXTS) or "/blobs/" in low):
                    continue
                try:
                    sz = os.path.getsize(path)
                except OSError:
                    continue
                if sz >= MODEL_MIN_BYTES:
                    files[path] = sz
        return files

    def maybe_preload(self):
        """Ask the kernel to pull the active model weights into the page cache
        (async readahead) so the next load is instant and inference never stalls
        on a cold read. Pure cache warming — nothing to restore. Skipped for
        weights already on a RAM-backed fs (tmpfs/overlay, e.g. a live ISO) and
        when free RAM is too tight to hold them safely."""
        found = self._find_model_files()
        if found:
            # Remember the active model's weight files so we can keep them warm
            # in the page cache later, while the machine is idle (see
            # maybe_warm_idle) — so the NEXT load reads from RAM, not disk.
            self._warm_files = dict(found)
            # Persist this model to the MRU so a FUTURE boot can warm it before
            # the user ever launches it (predictive preload at login). Only
            # written when the active model actually changes, never every poll.
            key = self._warm_key_for(found)
            if key != self._warm_key:
                self._warm_key = key
                self._remember_model(found)
        for path, size in found.items():
            if path in self._preloaded:
                continue
            self._preloaded.add(path)   # mark once; never thrash on churn
            try:
                st = os.stat(path)
            except OSError:
                continue
            if os.major(st.st_dev) == 0:            # tmpfs/overlay → already RAM
                continue
            avail = psutil.virtual_memory().available
            if size > avail * 0.6:                  # don't induce memory pressure
                logger.info("preload skip %s (%dMB > free budget)",
                            os.path.basename(path), int(size / (1024 * 1024)))
                continue
            try:
                fd = os.open(path, os.O_RDONLY)
                try:
                    os.posix_fadvise(fd, 0, 0, os.POSIX_FADV_WILLNEED)
                finally:
                    os.close(fd)
            except OSError as e:
                logger.debug(f"preload {path} failed: {e}")
                continue
            mb = int(size / (1024 * 1024))
            self.preloaded_mb += mb
            logger.info("Preloaded %s (%dMB) into page cache",
                        os.path.basename(path), mb)

    def maybe_warm_idle(self):
        """Predictive preload: while the machine is IDLE (no AI running), keep
        the last-used model's weights warm in the page cache so the NEXT launch
        loads from RAM instead of disk — the first piece of the always-warm
        daemon. Pure cache warming: reclaimable RAM, nothing to restore.

        Deliberately conservative so it can never hurt a low-RAM box: throttled
        (every WARM_INTERVAL s), skipped on a RAM-backed fs, and gated to models
        that fit comfortably (< 50% of *available* RAM) — so on a tight 6 GB VM
        it simply does nothing, while an 8 GB+ machine gets instant first loads."""
        # Predictive preload at LOGIN: on a fresh boot nothing has run yet, so
        # _warm_files is empty. Seed it (once) from the persisted MRU — the model
        # the user loaded most recently last session — so the very first launch
        # after login is instant, not just the second one in a session.
        if not self._warm_files and not self._seeded_warm:
            self._seeded_warm = True
            self._seed_warm_from_mru()
        if not self._warm_files:
            return
        now = time.time()
        if now - self._last_warm < WARM_INTERVAL:
            return
        self._last_warm = now
        avail = psutil.virtual_memory().available
        for path, size in list(self._warm_files.items()):
            try:
                stt = os.stat(path)
            except OSError:
                self._warm_files.pop(path, None)    # model file gone
                continue
            if os.major(stt.st_dev) == 0:           # tmpfs/overlay → already RAM
                continue
            if size > avail * 0.5:                  # too tight — leave RAM alone
                continue
            try:
                fd = os.open(path, os.O_RDONLY)
                try:
                    os.posix_fadvise(fd, 0, 0, os.POSIX_FADV_WILLNEED)
                finally:
                    os.close(fd)
            except OSError:
                self._warm_files.pop(path, None)

    # ── predictive-preload MRU (persisted across reboots) ────────────────────
    @staticmethod
    def _warm_key_for(files):
        """Stable id for a model = its sorted weight-file paths. Lets us detect
        when the active model actually changed (so we persist only on change)."""
        return "|".join(sorted(files))

    def _load_mru(self):
        """Read the persisted MRU list ([{files:{path:size}, last_used:ts}, …],
        newest first). Best-effort: a missing/corrupt file just means no history
        yet. Never raises."""
        try:
            with open(WARM_DB) as f:
                data = json.load(f)
        except (OSError, ValueError):
            return []
        out = []
        if isinstance(data, dict):
            data = data.get("models", [])
        if isinstance(data, list):
            for e in data:
                if isinstance(e, dict) and isinstance(e.get("files"), dict):
                    out.append(e)
        return out

    def _remember_model(self, files):
        """Record `files` as the most-recently-used model in the persisted MRU,
        de-duplicated and capped at WARM_DB_MAX. Best-effort; never raises into
        the main loop (a read-only /var or missing dir is fine — predictive
        preload just won't survive the reboot then)."""
        key = self._warm_key_for(files)
        mru = [e for e in self._load_mru() if self._warm_key_for(e["files"]) != key]
        mru.insert(0, {"files": dict(files), "last_used": time.time()})
        mru = mru[:WARM_DB_MAX]
        try:
            os.makedirs(PERSIST_DIR, exist_ok=True)
            tmp = WARM_DB + ".tmp"
            with open(tmp, "w") as f:
                json.dump({"models": mru}, f)
            os.replace(tmp, WARM_DB)
        except OSError as e:
            logger.debug(f"warm-db write failed: {e}")

    def _seed_warm_from_mru(self):
        """Populate _warm_files from the persisted MRU so maybe_warm_idle can warm
        the user's recent models before they launch anything. Pre-caches the
        most-recently-used models (2.8.3) — not just the newest one — accumulating
        their weight files newest-first while the running total stays under ~40%
        of currently-free RAM, so an 8 GB+ box keeps a couple of recent models
        instant while a tight box still warms just one (or none). Sizes refreshed
        from disk; vanished files skipped."""
        try:
            avail = psutil.virtual_memory().available
        except Exception:
            avail = 0
        budget = avail * 0.4
        files = {}
        total = 0
        for entry in self._load_mru():
            for path in entry.get("files", {}):
                if path in files:
                    continue
                try:
                    sz = os.path.getsize(path)
                except OSError:
                    continue
                if sz < MODEL_MIN_BYTES:
                    continue
                if budget and total + sz > budget:
                    continue
                files[path] = sz
                total += sz
        if files:
            self._warm_files = files
            self._warm_key = self._warm_key_for(files)
            logger.info("Predictive preload: warming %d recent model file(s) "
                        "(%dMB) at idle", len(files), int(total / (1024 * 1024)))

    def _queue_dir_for(self, path):
        """The /sys block-queue dir (the one with queue/scheduler) of the disk
        backing `path` — walking partition → parent disk."""
        try:
            dev = os.stat(path).st_dev
        except OSError:
            return None
        if os.major(dev) == 0:                      # virtual fs, no real disk
            return None
        real = os.path.realpath(f"/sys/dev/block/{os.major(dev)}:{os.minor(dev)}")
        cur = real
        for _ in range(4):                          # partition up to whole disk
            if os.path.exists(os.path.join(cur, "queue", "scheduler")):
                return cur
            cur = os.path.dirname(cur)
        return None

    def maybe_tune_io(self):
        """Switch the model disk's I/O scheduler to one tuned for big sequential
        reads, capturing the original so disable restores it. Only on AC/forced
        (it's a system-wide knob), and only when the device offers a target."""
        if not self.aggressive:
            return
        io_orig = self.originals.setdefault("io_sched", {})
        for path in self._find_model_files():
            qd = self._queue_dir_for(path)
            if not qd:
                continue
            dev = os.path.basename(qd)
            if dev in io_orig:                      # already handled this disk
                continue
            sched_file = os.path.join(qd, "queue", "scheduler")
            raw = _read(sched_file) or ""
            avail = [s.strip("[]") for s in raw.split()]
            m = re.search(r"\[([\w-]+)\]", raw)
            cur = m.group(1) if m else None
            target = next((t for t in IO_SCHED_PREFS if t in avail), None)
            io_orig[dev] = cur                      # record even if we skip
            if not target or target == cur:
                continue
            if _write(sched_file, target):
                self.io_applied.append(f"I/O sched {dev}: {target}")
                self._persist_originals()
                logger.info("I/O scheduler %s: %s -> %s", dev, cur, target)

    def _restore_io(self, io_sched):
        for dev, cur in (io_sched or {}).items():
            if cur and _write(f"/sys/block/{dev}/queue/scheduler", cur):
                logger.info("I/O scheduler %s restored -> %s", dev, cur)

    def write_ollama_env(self):
        """Pick Ollama concurrency limits and drop them where the ollama unit's
        EnvironmentFile picks them up. Always-on sane defaults (not part of the
        reversible on/off cycle), same spirit as genesi-ollama.conf.

        NUM_PARALLEL=1: Genesi is a single-user desktop, so one parallel slot
        gives that one request the FULL context window and all the VRAM — the
        fastest single-request speed, and it stops a borderline model from
        spilling onto the CPU (each extra slot reserves another KV cache). A
        throughput/multi-user box can override this with its own drop-in."""
        ram_gb = self.hw.total_ram_mb / 1024
        vram_gb = sum(g.get("vram_mb") or 0 for g in self.hw.gpus) / 1024
        parallel = 1
        budget_gb = vram_gb if vram_gb >= 2 else ram_gb
        loaded = 1 if budget_gb < 12 else 2 if budget_gb < 32 else 3
        body = (f"OLLAMA_NUM_PARALLEL={parallel}\n"
                f"OLLAMA_MAX_LOADED_MODELS={loaded}\n")
        try:
            _atomic_write(OLLAMA_ENV_FILE, body)
            logger.info("Ollama tuning: NUM_PARALLEL=%d MAX_LOADED_MODELS=%d "
                        "(RAM %.0fGB, VRAM %.0fGB)",
                        parallel, loaded, ram_gb, vram_gb)
        except OSError as e:
            logger.debug(f"ollama env write: {e}")

    def effective_applied(self):
        """Static enable tweaks plus the dynamic ones (preload, I/O) for display."""
        out = list(self.applied)
        if self.preloaded_mb:
            out.append(f"model preloaded ({self.preloaded_mb}MB in RAM)")
        out.extend(self.io_applied)
        return out

    # ── background indexers (SIGSTOP while AI runs, SIGCONT after) ────────────
    @staticmethod
    def _hog_names():
        """Built-in indexers plus any admin-provided extras, read live so the
        list can be edited without restarting the daemon."""
        names = set(BACKGROUND_HOGS)
        data = _read(EXTRA_HOGS_FILE)
        if data:
            for line in data.splitlines():
                n = line.split("#", 1)[0].strip()
                if n:
                    names.add(n)
        return names

    def _pause_background(self):
        hogs = self._hog_names()
        paused = 0
        for p in psutil.process_iter(["pid", "name"]):
            try:
                if (p.info["name"] or "") in hogs:
                    p.suspend()
                    paused += 1
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        if paused:
            self.applied.append(f"paused indexers ({paused})")
            logger.info(f"Paused {paused} background indexer(s)")
        return paused

    def _resume_background(self):
        # Resume by name (robust to PID churn / a daemon restart). SIGCONT to an
        # already-running process is a harmless no-op.
        hogs = self._hog_names()
        for p in psutil.process_iter(["pid", "name"]):
            try:
                if (p.info["name"] or "") in hogs:
                    p.resume()
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue

    # ── thermal guard ────────────────────────────────────────────────────────
    def thermal_guard(self, metrics):
        """If the machine runs too hot under AI Mode, ease the governor back to
        its original so we avoid hard thermal throttling (which is net-slower);
        restore performance once it cools. No-op without temps / governor (VM)."""
        if not self.aggressive or "governor" not in self.originals:
            return
        cpu = metrics.get("cpu_temp_c")
        gtemps = [g.get("temp_c") for g in metrics.get("gpus", []) if g.get("temp_c")]
        hot = (cpu is not None and cpu >= CPU_HOT_C) or any(t >= GPU_HOT_C for t in gtemps)
        cool = (cpu is None or cpu <= CPU_COOL_C) and all(t <= GPU_COOL_C for t in gtemps)
        if hot and not self.throttled:
            self._set_governor(self.originals.get("governor") or "schedutil")
            self.throttled = True
            logger.warning("Thermal guard: hot (cpu=%sC) — easing governor", cpu)
        elif cool and self.throttled:
            self._set_governor("performance")
            self.throttled = False
            logger.info("Thermal guard: cooled — performance restored")

    # ── live metrics (read-only; GPU polled only while AI Mode is on) ────────
    def collect_metrics(self):
        vm = psutil.virtual_memory()
        metrics = {
            "cpu_percent": round(psutil.cpu_percent(interval=None), 1),
            "cpu_temp_c": self._cpu_temp(),
            "ram_used_mb": int(vm.used / (1024 * 1024)),
            "ram_total_mb": self.hw.total_ram_mb,
            "gpus": [],
        }
        # Don't poll the GPU 24/7 — only while AI Mode is actually engaged.
        if not self.ai_mode_active:
            return metrics

        if any(g["vendor"] == "nvidia" for g in self.hw.gpus):
            rc, out = _run([
                "nvidia-smi",
                "--query-gpu=index,utilization.gpu,memory.used,memory.total,temperature.gpu",
                "--format=csv,noheader,nounits"])
            if rc == 0:
                for line in out.splitlines():
                    p = [x.strip() for x in line.split(",")]
                    if len(p) >= 5:
                        metrics["gpus"].append({
                            "vendor": "nvidia", "index": _to_int(p[0]),
                            "util": _to_int(p[1]), "vram_used_mb": _to_int(p[2]),
                            "vram_total_mb": _to_int(p[3]), "temp_c": _to_int(p[4]),
                        })

        for g in self.hw.gpus:
            if g["vendor"] != "amd":
                continue
            dev = os.path.dirname(g["dpm"])
            used = _to_int(_read(os.path.join(dev, "mem_info_vram_used")))
            total = _to_int(_read(os.path.join(dev, "mem_info_vram_total")))
            metrics["gpus"].append({
                "vendor": "amd", "card": g.get("card"),
                "util": _to_int(_read(os.path.join(dev, "gpu_busy_percent"))),
                "vram_used_mb": int(used / (1024 * 1024)) if used else None,
                "vram_total_mb": int(total / (1024 * 1024)) if total else None,
                "temp_c": self._amd_temp(dev),
            })
        return metrics

    def _amd_temp(self, dev):
        try:
            hwmon = os.path.join(dev, "hwmon")
            for h in os.listdir(hwmon):
                t = _read(os.path.join(hwmon, h, "temp1_input"))
                if t:
                    return round(int(t) / 1000)
        except (OSError, ValueError):
            pass
        return None

    def _cpu_temp(self):
        try:
            temps = psutil.sensors_temperatures()
        except (AttributeError, OSError):
            return None
        for key in ("k10temp", "coretemp", "zenpower", "acpitz", "cpu_thermal"):
            entries = temps.get(key)
            if entries:
                return round(entries[0].current)
        for entries in temps.values():       # fallback: any available sensor
            if entries:
                return round(entries[0].current)
        return None

    def ollama_status(self):
        """Loaded Ollama models via the local API. Cached for 4s so the same
        loop's activity check and state export share one /api/ps request."""
        now = time.time()
        ts, cached = self._ollama_ps_cache
        if now - ts < 4.0:
            return cached
        result = self._ollama_status_uncached()
        self._ollama_ps_cache = (now, result)
        return result

    def _ollama_status_uncached(self):
        """Loaded Ollama models via the local API — only when ollama is running."""
        if not any(self._is_ollama(p) for p in self.ai_processes):
            return None
        try:
            with urllib.request.urlopen(OLLAMA_API, timeout=2) as r:
                data = json.loads(r.read().decode())
        except Exception as e:
            logger.debug(f"ollama /api/ps: {e}")
            return None
        models = []
        for mdl in data.get("models", []):
            size = mdl.get("size") or 0
            vram = mdl.get("size_vram") or 0
            if size and vram >= size:
                where = "GPU"
            elif vram == 0:
                where = "CPU"
            else:
                where = "CPU+GPU"
            models.append({
                "name": mdl.get("name") or mdl.get("model"),
                "size_mb": int(size / (1024 * 1024)) if size else None,
                "vram_mb": int(vram / (1024 * 1024)) if vram else None,
                "where": where,
            })
        return models

    @staticmethod
    def _is_ollama(proc):
        try:
            return "ollama" in proc.name().lower()
        except (psutil.NoSuchProcess, psutil.AccessDenied):
            return False

    def tokens_per_second(self):
        """Best-effort live generation rate, scraped from the ollama journal
        (the llama runner logs an `eval rate: N tokens/s` line per request).
        Returns the most recent value seen in the last couple of minutes, or
        None — the format is engine/version-dependent, so treat it as a hint."""
        if not any(self._is_ollama(p) for p in self.ai_processes):
            return None
        rc, out = _run(["journalctl", "-u", "ollama", "--no-pager",
                        "-o", "cat", "-n", "120", "--since", "-2min"], timeout=4)
        if rc != 0 or not out:
            return None
        rate = None
        for line in out.splitlines():
            m = (re.search(r"eval rate:\s*([\d.]+)\s*tokens/s", line) or
                 re.search(r"([\d.]+)\s*tokens per second", line))
            if m:
                try:
                    rate = round(float(m.group(1)), 1)
                except ValueError:
                    pass
        return rate

    # ── state export ─────────────────────────────────────────────────────────
    def _save_state(self, force_mode, metrics):
        procs = []
        for p in self.ai_processes:
            try:
                procs.append({"pid": p.pid, "name": p.name()})
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue
        state = {
            "ai_mode_active": self.ai_mode_active,
            "activity": self._activity,   # active | warm | idle (auto-detect)
            "force_mode": force_mode or "auto",
            "aggressive": self.aggressive,
            "profile": self.profile if self.ai_mode_active else "auto",
            "profile_mode": self.read_profile() or "auto",
            "throttled": self.throttled,
            "applied": self.effective_applied(),
            "changes": self.changes_summary(),
            "ai_processes": procs,
            "ollama": self.ollama_status(),
            "tokens_per_second": self.tokens_per_second() if self.ai_mode_active else None,
            "hardware": self.hw.summary(),
            "metrics": metrics,
            "timestamp": time.time(),
        }
        try:
            _atomic_write(STATE_FILE, json.dumps(state))
        except OSError as e:
            logger.debug(f"state write: {e}")

    def manage_always_warm(self):
        """Tier 1 always-warm shared Turbo server, driven by the opt-in
        advanced.conf `always_warm_turbo` knob. Implemented as a real systemd
        unit (genesi-turbo.service) rather than a daemon-spawned child, so the
        warm server survives a genesi-aid restart, restarts on failure, and is
        the SINGLE owner of :11435 (no child process racing the unit for the
        port). The unit resolves the model to keep warm itself (recommend →
        biggest fits-VRAM). Off by default; this just reflects the knob."""
        want = self._advanced_conf().get("always_warm_turbo") in (
            "on", "1", "true", "yes")
        try:
            active = subprocess.run(
                ["systemctl", "is-active", "genesi-turbo.service"],
                capture_output=True, timeout=8).returncode == 0
        except Exception:
            return
        if want and not active:
            logger.info("Always-warm Turbo: starting genesi-turbo.service")
            subprocess.run(["systemctl", "start", "genesi-turbo.service"],
                           capture_output=True)
        elif not want and active:
            logger.info("Always-warm Turbo: stopping genesi-turbo.service")
            subprocess.run(["systemctl", "stop", "genesi-turbo.service"],
                           capture_output=True)

    # ── main loop ────────────────────────────────────────────────────────────
    def _maybe_redetect_gpus(self):
        """The hardware profile is built once at startup, but genesi-aid starts
        early — before the NVIDIA driver is necessarily ready — so a GPU can be
        missed and cached as 'absent' for the whole session (the dashboard then
        shows "no GPU" on a machine that has one, and Turbo runs on the CPU).
        Re-probe every ~30s until we have a GPU with VRAM, then stop. Give up
        after ~20 min so a genuinely GPU-less box doesn't probe forever."""
        if any((g.get("vram_mb") or 0) > 0 for g in self.hw.gpus):
            return                                   # already have a usable GPU
        if getattr(self, "_gpu_probes", 0) >= 40:
            return                                   # GPU-less / give up
        now = time.time()
        if now - getattr(self, "_last_gpu_probe", 0.0) < 30:
            return
        self._last_gpu_probe = now
        self._gpu_probes = getattr(self, "_gpu_probes", 0) + 1
        found = self.hw._detect_gpus()
        if found and (not self.hw.gpus
                      or any((g.get("vram_mb") or 0) > 0 for g in found)):
            self.hw.gpus = found
            logger.info("GPU (re)detected: %s", self.hw.summary().get("gpus"))

    def run(self):
        logger.info("Genesi AI Daemon started | %s",
                    json.dumps(self.hw.summary()))
        self.write_ollama_env()
        while True:
            try:
                self._maybe_redetect_gpus()
                force = self.read_force()
                self.ai_processes = self.detect_ai_processes()

                # Classify the live workload first (drives every decision below).
                # GPU is only polled once AI Mode is already engaged, so on the
                # loop that turns it ON we rely on process/CPU/ollama signals and
                # the GPU tier refines on the next pass — a harmless 5s lag.
                metrics = self.collect_metrics()
                activity = self.assess_activity(metrics)
                self._activity = activity
                now = time.time()
                if activity in ("active", "warm"):
                    self._last_active_ts = now
                if activity == "active":
                    self._last_crunch_ts = now
                idle_for = now - self._last_active_ts

                # Should AI Mode be engaged at all?
                if force == "off":
                    want = False
                elif force == "on":
                    want = True
                elif activity in ("active", "warm"):
                    want = True
                else:
                    # Idle: hold through a grace window so we don't power down
                    # between chat turns (read a reply, type the next prompt),
                    # then drop. Never powers UP from idle — only sustains.
                    want = self.ai_mode_active and idle_for < self._idle_timeout()

                # Auto-mode intensity tier: stay 'max' while crunching and for a
                # short hold after; ease to 'balanced' once the model is merely
                # resident-idle (releases GPU clock/power locks, keeps governor
                # responsive). An explicit user profile / force overrides this.
                tier = ("active" if (now - self._last_crunch_ts) < WARM_DEMOTE_SECONDS
                        else "warm")
                desired = self._effective_profile(force == "on", activity=tier)

                if want and not self.ai_mode_active:
                    self.enable_ai_mode(forced=(force == "on"), profile=desired)
                elif not want and self.ai_mode_active:
                    self.disable_ai_mode()
                elif want and self.ai_mode_active:
                    # Re-apply when the resolved intensity changes — a user
                    # profile switch, or the auto tier easing max→balanced (or
                    # promoting back to max when generation resumes).
                    if desired != self.profile:
                        self.disable_ai_mode()
                        self.enable_ai_mode(forced=(force == "on"), profile=desired)

                if self.ai_mode_active:
                    self.prioritize_ai_processes()
                    self.maybe_preload()
                    self.maybe_tune_io()
                else:
                    # Idle: keep the last-used model warm in page cache so the
                    # next launch loads from RAM (RAM-gated; no-op on tight boxes).
                    self.maybe_warm_idle()

                self.manage_always_warm()

                if self.ai_mode_active:
                    self.thermal_guard(metrics)
                self._save_state(force, metrics)
                time.sleep(POLL_SECONDS)
            except KeyboardInterrupt:
                logger.info("Shutting down...")
                if self.ai_mode_active:
                    self.disable_ai_mode()
                break
            except Exception as e:
                logger.error(f"main loop error: {e}")
                time.sleep(POLL_SECONDS)


def main():
    if os.geteuid() != 0:
        print("Error: genesi-aid must run as root", file=sys.stderr)
        sys.exit(1)
    os.makedirs(RUN_DIR, exist_ok=True)
    AIOptimizer(HardwareProfile()).run()


if __name__ == "__main__":
    main()
