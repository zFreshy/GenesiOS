#!/usr/bin/env bash
# genesi-ai-mode — control / inspect the Genesi AI optimization daemon.
#
#   genesi-ai-mode on        force AI Mode ON  (stay on even with no AI running)
#   genesi-ai-mode off       force AI Mode OFF (stay off even while AI runs)
#   genesi-ai-mode auto      remove the override, follow automatic detection
#   genesi-ai-mode toggle    flip between forced-ON and automatic
#   genesi-ai-mode status    print the daemon state (JSON)
#   genesi-ai-mode info      human-readable status (hardware + applied tweaks)
#   genesi-ai-mode bench [m] benchmark a model (default llama3.2) OFF vs ON
#
# The override is just a file in the daemon's world-writable runtime dir, so no
# sudo is needed to flip it.
set -euo pipefail

DIR=/run/genesi-ai-mode
FORCE="$DIR/force"
STATE="$DIR/state.json"

ensure_dir() {
    [ -d "$DIR" ] || mkdir -p "$DIR" 2>/dev/null || {
        echo "genesi-ai-mode: $DIR missing (is genesi-aid running?)" >&2
        exit 1
    }
}

case "${1:-status}" in
    on)     ensure_dir; printf 'on'  > "$FORCE" ;;
    off)    ensure_dir; printf 'off' > "$FORCE" ;;
    auto)   rm -f "$FORCE" ;;
    toggle)
        if [ "$(cat "$FORCE" 2>/dev/null || true)" = on ]; then
            rm -f "$FORCE"
        else
            ensure_dir; printf 'on' > "$FORCE"
        fi
        ;;
    status)
        if [ -r "$STATE" ]; then
            cat "$STATE"; echo
        else
            echo '{"error":"genesi-aid not running"}'
        fi
        ;;
    info)
        if [ ! -r "$STATE" ]; then
            echo "genesi-aid not running"; exit 1
        fi
        python3 - "$STATE" <<'PY'
import json, sys
s = json.load(open(sys.argv[1]))
hw = s.get("hardware", {})
gpus = hw.get("gpus", []) or [{"vendor": "none"}]
gpu_s = ", ".join(g.get("vendor", "?") +
                  (f" {g['vram_mb']}MB" if g.get("vram_mb") else "") for g in gpus)
print(f"AI Mode : {'ON' if s.get('ai_mode_active') else 'OFF'} "
      f"(force={s.get('force_mode')}, mode={'max' if s.get('aggressive') else 'battery-safe'})")
print(f"Hardware: {hw.get('cpu_vendor','?')} {hw.get('physical_cores','?')}c/"
      f"{hw.get('logical_cores','?')}t, {hw.get('ram_mb',0)}MB RAM, "
      f"{hw.get('chassis','?')}{' (VM)' if hw.get('virtualized') else ''}")
print(f"GPU     : {gpu_s}")
procs = s.get("ai_processes", [])
print("AI procs: " + (", ".join(f"{p['name']}({p['pid']})" for p in procs) or "none"))
applied = s.get("applied", [])
print("Applied : " + (", ".join(applied) if applied else "—"))
if s.get("throttled"):
    print("Thermal : THROTTLED (governor eased to cool down)")
mt = s.get("metrics", {})
if mt:
    ram = f"{mt.get('ram_used_mb',0)}/{mt.get('ram_total_mb',0)}MB"
    ct = mt.get("cpu_temp_c")
    temp = f", {ct}C" if ct is not None else ""
    print(f"Live    : CPU {mt.get('cpu_percent','?')}%{temp}, RAM {ram}")
    for g in mt.get("gpus", []):
        vu, vt = g.get("vram_used_mb"), g.get("vram_total_mb")
        vram = f"{vu}/{vt}MB" if vu is not None and vt is not None else "?"
        print(f"  GPU {g.get('vendor')}: {g.get('util','?')}% util, "
              f"VRAM {vram}, {g.get('temp_c','?')}C")
for mdl in (s.get("ollama") or []):
    sz = f"{mdl['size_mb']}MB" if mdl.get("size_mb") else "?"
    print(f"Ollama  : {mdl.get('name')} ({sz}, {mdl.get('where','?')})")
PY
        ;;
    bench)
        MODEL="${2:-llama3.2}"
        PROMPT="Write a Python function that returns the nth Fibonacci number, with a short explanation."
        command -v ollama >/dev/null || { echo "ollama is not installed (sudo pacman -S ollama)"; exit 1; }
        echo ":: warming up $MODEL ..."
        ollama run "$MODEL" "hi" >/dev/null 2>&1 || { echo "could not run $MODEL (pull it first?)"; exit 1; }
        echo ":: AI Mode OFF ..."
        genesi-ai-mode off >/dev/null; sleep 6
        OFF_OUT="$(ollama run "$MODEL" --verbose "$PROMPT" 2>&1)"
        echo ":: AI Mode ON ..."
        genesi-ai-mode on  >/dev/null; sleep 6
        ON_OUT="$(ollama run "$MODEL" --verbose "$PROMPT" 2>&1)"
        genesi-ai-mode auto >/dev/null
        OFF_OUT="$OFF_OUT" ON_OUT="$ON_OUT" MODEL="$MODEL" python3 <<'PY'
import os, re
def parse(t):
    d = {}
    for line in t.splitlines():
        if ":" in line:
            k, _, v = line.partition(":")
            d[k.strip().lower()] = v.strip()
    return d
off, on = parse(os.environ["OFF_OUT"]), parse(os.environ["ON_OUT"])
def num(s):
    m = re.search(r"[-+]?[0-9]*\.?[0-9]+", s or "")
    return float(m.group()) if m else None
rows = [
    ("generation rate", "eval rate"),
    ("prompt rate",     "prompt eval rate"),
    ("tokens generated","eval count"),
    ("generation time", "eval duration"),
    ("model load",      "load duration"),
    ("total time",      "total duration"),
]
print(f"\n  benchmark: {os.environ['MODEL']}\n")
print(f"  {'metric':16} {'OFF':>14} {'ON':>14}")
print("  " + "-" * 46)
for label, key in rows:
    print(f"  {label:16} {off.get(key,'?'):>14} {on.get(key,'?'):>14}")
ro, rn = num(off.get("eval rate")), num(on.get("eval rate"))
if ro and rn:
    print(f"\n  >> generation: {ro:.2f} -> {rn:.2f} tokens/s  ({(rn-ro)/ro*100:+.1f}%)")
print("\n  (on a VM expect ~0%: the CPU governor, the biggest lever, is a")
print("   no-op without real cpufreq. Run on bare metal for the true gain.)")
PY
        ;;
    *)
        echo "usage: genesi-ai-mode {on|off|auto|toggle|status|info|bench [model]}" >&2
        exit 2
        ;;
esac
