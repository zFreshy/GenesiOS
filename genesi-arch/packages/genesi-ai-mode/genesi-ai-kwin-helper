#!/usr/bin/env python3
"""
Genesi AI Mode — KWin effect trimmer (runs in the user's Plasma session).

While AI Mode is ON, unload the desktop effects that make windows glassy — blur,
background contrast, and translucency — so every window snaps fully opaque (no
blur AND no transparency) and the compositor stops competing with inference for
the GPU. Reload exactly what we unloaded when AI Mode turns off, restoring the
glass.

This works because Genesi's glass is now sourced ENTIRELY from KWin's
`translucency` compositor effect (windows are painted opaque by the color scheme;
the effect makes them see-through and forceblur frosts it). A compositor effect
toggles live for EVERY window — open or new — which an app-level translucency
(color-scheme alpha) could not: that stays baked into a window from creation and
can't be removed live. So unloading the effect is the only thing that reliably
makes the whole desktop opaque on demand.

Lives in the user session (not the root daemon) because KWin's DBus is
session-scoped. Everything is guarded: on a non-KWin/non-Plasma session, or if
DBus isn't reachable, it just sits idle and changes nothing.

Disable it any time with:  systemctl --user mask genesi-ai-kwin-helper  (or
remove the autostart entry). Effects to manage can be overridden by setting
GENESI_KWIN_EFFECTS to a comma-separated list.
"""
import os
import time
import shutil
import json
import subprocess

STATE_FILE = "/run/genesi-ai-mode/state.json"
POLL_SECONDS = 3
# Effect plugin ids as KWin's Effects DBus knows them. They are the SHORT ids
# (blur, contrast, translucency) — NOT the "kwin4_effect_*" names used in
# kwinrc's [Plugins] group. Using "kwin4_effect_translucency" alone was a real
# bug: isEffectLoaded() returned false for it, so the helper "unloaded" nothing
# and the actual `translucency` effect stayed on, leaving windows see-through in
# AI Mode. Confirmed on Plasma 6.5: `translucency` is loaded, the prefixed name
# is not. We list both so a KDE build that uses the long id is still covered (a
# non-existent id is simply skipped by the isEffectLoaded guard).
EFFECTS = [e.strip() for e in
           os.environ.get("GENESI_KWIN_EFFECTS",
                          "blur,contrast,translucency,kwin4_effect_translucency"
                          ).split(",")
           if e.strip()]

KWIN_SERVICE = "org.kde.KWin"
KWIN_EFFECTS_PATH = "/Effects"
KWIN_EFFECTS_IFACE = "org.kde.kwin.Effects"


def _qdbus_bin():
    for name in ("qdbus6", "qdbus-qt6", "qdbus"):
        if shutil.which(name):
            return name
    return None


QDBUS = _qdbus_bin()


def _call(method, *args):
    if not QDBUS:
        return None
    cmd = [QDBUS, KWIN_SERVICE, KWIN_EFFECTS_PATH,
           f"{KWIN_EFFECTS_IFACE}.{method}", *args]
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
        if p.returncode != 0:
            return None
        return (p.stdout or "").strip()
    except (subprocess.TimeoutExpired, OSError):
        return None


def _is_loaded(effect):
    return _call("isEffectLoaded", effect) == "true"


def _read_active():
    try:
        with open(STATE_FILE) as f:
            return bool(json.load(f).get("ai_mode_active"))
    except (OSError, ValueError):
        return None


def _wait_for_kwin(probe, attempts=15, delay=2):
    """Autostart can fire before KWin's DBus is up; retry briefly, then give up
    quietly (e.g. a non-KWin session)."""
    for _ in range(attempts):
        if _call("isEffectLoaded", probe) is not None:
            return True
        time.sleep(delay)
    return False


def main():
    if not QDBUS or not EFFECTS:
        return  # nothing we can do without qdbus / no effects to manage
    if not _wait_for_kwin(EFFECTS[0]):
        return  # not a reachable KWin session — sit out

    applied = False
    unloaded = []
    last = None
    try:
        while True:
            active = _read_active()
            if active is None:
                time.sleep(POLL_SECONDS)
                continue
            if active and not applied:
                unloaded = []
                for eff in EFFECTS:
                    if _is_loaded(eff):
                        if _call("unloadEffect", eff) is not None:
                            unloaded.append(eff)
                applied = True
                if unloaded != last:
                    print(f"AI Mode ON: unloaded effects {unloaded}", flush=True)
            elif not active and applied:
                for eff in unloaded:
                    _call("loadEffect", eff)
                print(f"AI Mode OFF: reloaded effects {unloaded}", flush=True)
                applied = False
                unloaded = []
            last = unloaded
            time.sleep(POLL_SECONDS)
    finally:
        # Never leave the desktop trimmed if we're killed mid-AI-Mode (logout,
        # SIGTERM): put the effects back.
        if applied:
            for eff in unloaded:
                _call("loadEffect", eff)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        pass
