post_install() {
    echo "==> Creating AI Mode runtime directory..."
    systemd-tmpfiles --create /usr/lib/tmpfiles.d/genesi-ai-mode.conf 2>/dev/null || true
    echo "==> Applying AI Mode sysctl tuning..."
    sysctl --system >/dev/null 2>&1 || true
    # Pick up the Ollama drop-in (no-op until Ollama is installed).
    systemctl daemon-reload 2>/dev/null || true
    echo "==> Enabling genesi-aid service..."
    systemctl enable genesi-aid.service 2>/dev/null || true
    echo "==> AI Mode is ready. Start now with: sudo systemctl start genesi-aid"
}

post_upgrade() {
    systemd-tmpfiles --create /usr/lib/tmpfiles.d/genesi-ai-mode.conf 2>/dev/null || true
    sysctl --system >/dev/null 2>&1 || true
    echo "==> Restarting genesi-aid service..."
    systemctl daemon-reload 2>/dev/null || true
    systemctl restart genesi-aid.service 2>/dev/null || true
    # Aplica as novas permissões de leitura no diretório de modelos do Ollama
    systemctl try-restart ollama.service 2>/dev/null || true
}

pre_remove() {
    echo "==> Stopping and disabling genesi-aid service..."
    systemctl stop genesi-aid.service 2>/dev/null || true
    systemctl disable genesi-aid.service 2>/dev/null || true
    # Also tear down the optional always-warm Turbo unit so it isn't orphaned.
    systemctl disable --now genesi-turbo.service 2>/dev/null || true
}
