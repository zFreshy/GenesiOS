# Maintainer: Genesi OS Team
# Source: https://github.com/zFreshy/genesi-update (fork of CachyOS/cachy-update)
pkgname=genesi-update
pkgver=1.0.0
# 2026-06-01 (2): add genesi-update.install — enable genesi-update.timer for all
# users globally. It shipped disabled, so the auto update-check never ran and
# the systray "updates available" icon never lit up on installed systems.
pkgrel=2
pkgdesc="Interactive update notifier & applier for Genesi OS with systray applet"
install='genesi-update.install'
arch=('any')
url="https://github.com/zFreshy/genesi-update"
license=('GPL-3.0-or-later')
depends=(
    'bash'
    'systemd'
    'pacman'
    'pacman-contrib'
    'archlinux-contrib'
    'curl'
    'fakeroot'
    'htmlq'
    'diffutils'
    'hicolor-icon-theme'
    'python'
    'python-pyqt6'
    'qt6-svg'
    'glib2'
    'xdg-utils'
    'libnotify'
)
optdepends=(
    'paru: AUR support'
    'yay: AUR support'
    'pikaur: AUR support'
    'flatpak: Flatpak support'
    'sudo: privilege elevation'
    'sudo-rs: privilege elevation'
    'opendoas: privilege elevation'
)
makedepends=('make' 'scdoc' 'gettext')
provides=('genesi-update')
conflicts=('genesi-updater')
replaces=('genesi-updater')
source=("git+https://github.com/zFreshy/genesi-update.git#branch=main")
sha256sums=('SKIP')

build() {
    cd "${srcdir}/genesi-update"
    # Skip msgfmt for now — the rebrand sed pass collapsed `Arch-Update` and
    # `Cachy-Update` into the same `Genesi-Update` string, which produces
    # duplicate msgids in every .po file. Translations can be re-introduced
    # later by regenerating the .pot from sources and running msgmerge.
    make locales=""
}

package() {
    cd "${srcdir}/genesi-update"
    make PREFIX=/usr DESTDIR="${pkgdir}" locales="" install
}
