#!/usr/bin/env python3
"""
Genesi OS Update Checker
Checks for system updates and notifies the user
"""

import os
import sys
import json
import subprocess
import logging
from pathlib import Path
from datetime import datetime

# Configuration
CONFIG_FILE = "/etc/genesi-updater.conf"
STATE_FILE = "/var/lib/genesi-updater/state.json"
LOG_FILE = "/var/log/genesi-updater.log"

# Setup logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler(LOG_FILE),
        logging.StreamHandler()
    ]
)

class GenesiUpdater:
    def __init__(self):
        self.config = self.load_config()
        self.state = self.load_state()
        
    def load_config(self):
        """Load configuration from file"""
        config = {
            'check_interval': 3600,  # 1 hour in seconds
            'auto_download': False,
            'notify_user': True,
            'include_aur': False,
        }
        
        if os.path.exists(CONFIG_FILE):
            try:
                with open(CONFIG_FILE, 'r') as f:
                    for line in f:
                        line = line.strip()
                        if line and not line.startswith('#'):
                            key, value = line.split('=', 1)
                            key = key.strip()
                            value = value.strip().strip('"\'')
                            
                            if key in config:
                                if isinstance(config[key], bool):
                                    config[key] = value.lower() in ('true', 'yes', '1')
                                elif isinstance(config[key], int):
                                    config[key] = int(value)
                                else:
                                    config[key] = value
            except Exception as e:
                logging.error(f"Error loading config: {e}")
        
        return config
    
    def load_state(self):
        """Load previous state"""
        if os.path.exists(STATE_FILE):
            try:
                with open(STATE_FILE, 'r') as f:
                    return json.load(f)
            except:
                pass
        return {
            'last_check': None,
            'updates_available': 0,
            'packages': []
        }
    
    def save_state(self):
        """Save current state"""
        os.makedirs(os.path.dirname(STATE_FILE), exist_ok=True)
        with open(STATE_FILE, 'w') as f:
            json.dump(self.state, f, indent=2)
    
    def check_updates(self):
        """Check for available updates"""
        logging.info("Checking for updates...")
        
        try:
            # Use checkupdates to check for updates without requiring root
            result = subprocess.run(
                ['checkupdates'],
                capture_output=True,
                text=True,
                timeout=60
            )
            
            if result.returncode == 0 and result.stdout.strip():
                # Parse update list
                updates = []
                for line in result.stdout.strip().split('\n'):
                    if line:
                        parts = line.split()
                        if len(parts) >= 4:
                            pkg_name = parts[0]
                            old_ver = parts[1]
                            new_ver = parts[3]
                            updates.append({
                                'name': pkg_name,
                                'old_version': old_ver,
                                'new_version': new_ver
                            })
                
                self.state['updates_available'] = len(updates)
                self.state['packages'] = updates
                self.state['last_check'] = datetime.now().isoformat()
                
                logging.info(f"Found {len(updates)} updates")
                return updates
            else:
                logging.info("No updates available")
                self.state['updates_available'] = 0
                self.state['packages'] = []
                self.state['last_check'] = datetime.now().isoformat()
                return []
                
        except subprocess.TimeoutExpired:
            logging.error("Update check timed out")
            return None
        except Exception as e:
            logging.error(f"Error checking updates: {e}")
            return None
    
    def notify_updates(self, updates):
        """Send desktop notification about updates"""
        if not self.config['notify_user'] or not updates:
            return
        
        count = len(updates)
        
        # Create notification
        title = f"🔄 {count} Update{'s' if count > 1 else ''} Available"
        
        # List first 5 packages
        pkg_list = ', '.join([u['name'] for u in updates[:5]])
        if count > 5:
            pkg_list += f", and {count - 5} more..."
        
        body = f"Packages: {pkg_list}\n\nClick to open Discover and update."
        
        try:
            subprocess.run([
                'notify-send',
                '-a', 'Genesi Updater',
                '-i', '/usr/share/pixmaps/genesi-logo.png',
                '-u', 'normal',
                '-t', '10000',  # 10 seconds
                title,
                body
            ])
            logging.info("Notification sent")
        except Exception as e:
            logging.error(f"Error sending notification: {e}")
    
    def run(self):
        """Main update check routine"""
        logging.info("Genesi Updater started")
        
        # Check for updates
        updates = self.check_updates()
        
        # Save state
        self.save_state()
        
        # Notify if updates found
        if updates:
            self.notify_updates(updates)
            
            # Write flag file for widget
            flag_file = "/tmp/genesi-updates-available"
            with open(flag_file, 'w') as f:
                f.write(str(len(updates)))
        else:
            # Remove flag file
            flag_file = "/tmp/genesi-updates-available"
            if os.path.exists(flag_file):
                os.remove(flag_file)
        
        logging.info("Update check complete")

def main():
    if os.geteuid() != 0:
        # Run as regular user for checkupdates
        pass
    
    updater = GenesiUpdater()
    updater.run()

if __name__ == '__main__':
    main()
