[Desktop Entry]
Type=Application
Name=Genesi Update Notifier
Comment=Monitors for system updates and shows notifications
Exec=/usr/local/bin/genesi-update-notifier
Icon=system-software-update
Terminal=false
Categories=System;
X-KDE-autostart-after=panel
X-KDE-StartupNotify=false
X-GNOME-Autostart-enabled=true
Hidden=false
