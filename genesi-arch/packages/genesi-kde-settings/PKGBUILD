# Maintainer: Genesi OS Team <dev@genesios.org>
# Based on cachyos-kde-settings by CachyOS team

pkgname=genesi-kde-settings
pkgver=1.0.0
pkgrel=2
pkgdesc='Genesi OS KDE Plasma settings and theme'
arch=('any')
url='https://github.com/zFreshy/GenesiOS'
license=('GPL-3.0-or-later')
depends=('plasma-desktop' 'breeze' 'breeze-gtk')
optdepends=('klassy: Rounded window corners and better decorations')
conflicts=('cachyos-kde-settings' 'cachyos-desktop-settings')
provides=('cachyos-kde-settings' 'cachyos-desktop-settings')
source=()
sha256sums=()

package() {
    # Copy files from package directory (not srcdir)
    cp -r "${startdir}/etc" "$pkgdir/"
    cp -r "${startdir}/usr" "$pkgdir/"
    
    # Make desktop icons executable
    chmod +x "$pkgdir/etc/skel/Desktop/"*.desktop 2>/dev/null || true
}
