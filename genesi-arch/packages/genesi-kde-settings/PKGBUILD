# Maintainer: Genesi OS Team
# Based on CachyOS KDE Settings

_gitname=genesi-pkgbuilds
pkgname=genesi-kde-settings
pkgdesc='Genesi OS KDE Plasma Settings with Glassmorphism'
pkgver=4.9
pkgrel=5
arch=('any')
url="https://github.com/zFreshy/genesi-pkgbuilds"
license=(GPL-1.0-only)
depends=('ttf-fantasque-nerd'
    'noto-fonts'
    'ttf-fira-sans'
    'capitaine-cursors'
)
makedepends=('coreutils' 'git')
provides=('cachyos-desktop-settings' 'cachyos-kde-settings')
conflicts=('cachyos-desktop-settings' 'cachyos-kde-settings')
source=("git+https://github.com/zFreshy/genesi-pkgbuilds.git")
sha512sums=('SKIP')

package() {
    # Get the kde-settings from our repo
    local _srcdir="${srcdir}/${_gitname}/cachyos-kde-settings"
    
    # Download the tarball if the directory structure doesn't exist
    if [ ! -d "${_srcdir}/cachyos-kde-settings-4.9" ]; then
        cd "${_srcdir}"
        curl -L "https://github.com/cachyos/cachyos-kde-settings/archive/4.9.tar.gz" -o cachyos-kde-settings-4.9.tar.gz
        tar xzf cachyos-kde-settings-4.9.tar.gz
    fi
    
    install -d "$pkgdir/etc"
    cp -rf "${_srcdir}/cachyos-kde-settings-4.9/etc" "$pkgdir" 2>/dev/null || true
    install -d "$pkgdir/usr"
    cp -rf "${_srcdir}/cachyos-kde-settings-4.9/usr" "$pkgdir" 2>/dev/null || true
    
    # Replace all CachyOS branding with Genesi OS
    find "$pkgdir" -type f -exec sed -i 's/CachyOS/Genesi OS/g' {} + 2>/dev/null || true
    find "$pkgdir" -type f -exec sed -i 's/cachyos/genesi/g' {} + 2>/dev/null || true
    
    # Apply Genesi colors (green theme)
    find "$pkgdir" -type f \( -name "*.conf" -o -name "*.css" -o -name "*.qml" \) | while read file; do
        sed -i 's/#3daee9/#00ff9f/g' "$file" 2>/dev/null || true  # Accent color
        sed -i 's/#232629/#0a0f0d/g' "$file" 2>/dev/null || true  # Background
    done
}
