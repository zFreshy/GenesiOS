# Maintainer: Genesi OS Team
#
# Genesi branding/config overlay for the "Hyprland + caelestia-shell" desktop
# option (Roadmap 5.1). It ships a ready-to-use Hyprland config into /etc/skel so
# every new user logs straight into a working caelestia desktop with the Genesi
# wallpaper and Material You scheme derived from it — the Hyprland equivalent of
# what genesi-kde-settings does for Plasma.
#
# Payload-only (no build). Installed by the Hyprland-Desktop netinstall group.
#
# NOTE: deliberately does NOT provide/conflict cachyos-desktop-settings. The
# always-on "Genesi OS" netinstall group installs genesi-kde-settings (which
# already provides cachyos-desktop-settings) on every system regardless of DE, so
# claiming that virtual here would make the two Genesi settings packages conflict.
pkgname=genesi-caelestia-settings
pkgver=1.0.0
# pkgrel 2: fix a malformed gradient color in hyprland.conf
# (col.active_border had `rgba(00 aaff ee)` with spaces in the hex). Hyprland
# 0.55 failed to parse it and the broken `general {}` block cascaded into bogus
# "dwindle:pseudotile does not exist" / "togglesplit dispatcher" errors on first
# Hyprland launch. Now `rgba(00aaffee)`.
# pkgrel 3: (1) render caelestia under the Qt Quick SOFTWARE backend inside VMs
# (systemd-detect-virt != none) — on VirtualBox the GPU/EGL path crashed
# Quickshell to a black screen; real hardware still gets GPU rendering/blur.
# (2) stop forcing the Genesi wallpaper — use caelestia's own default so its
# Material You palette comes from the shipped caelestia look.
# pkgrel 4: fix the magenta "missing icon" placeholders in the launcher/menus.
# The Hyprland session shipped no icon theme, so Qt/Quickshell (caelestia) and
# GTK apps had no app icons. Depend on papirus-icon-theme and set it as the
# default via /etc/skel qt6ct.conf + kdeglobals + gtk-3.0/settings.ini. Safe in
# /etc/skel: genesi-kde-settings strips its own skel, so nothing conflicts. Icons
# are CPU-rendered, so this is visible even under the VM software backend.
# pkgrel 5: default terminal kitty -> foot. kitty needs OpenGL and crashed to
# nothing inside VirtualBox (same GL gap that black-screened Quickshell); foot is
# a pure-software Wayland terminal that renders in VMs and is light on real
# hardware, so SUPER+Return works everywhere.
# pkgrel 6: fix the two on-screen Hyprland config errors for real. pkgrel 2 blamed
# a malformed gradient colour — that was WRONG (the errors persisted on bare metal
# after that fix). The real cause is Hyprland 0.54/0.55 breaking changes:
#   * `dwindle:pseudotile` was REMOVED in 0.55 (pseudotile is per-window only now)
#     -> dropped `pseudotile = true` from the dwindle {} block (line 88 error).
#       Pseudotiling still works via the `pseudo` dispatcher (SUPER+P) already bound.
#   * `togglesplit` stopped being a direct dispatcher in 0.54+ -> now sent via
#     `layoutmsg, togglesplit` (line 113 "dispatcher does not exist" error).
# Also: (a) tapping SUPER alone now opens the caelestia launcher (Windows-like;
# bindr SUPER,SUPER_L), and (b) start the Genesi update-notifier tray from
# hyprland.conf — Hyprland ignores /etc/xdg/autostart, so the shipped tray
# .desktop never fired under this session and no tray icon appeared. New dep:
# genesi-update (provides the `genesi-update --tray` SNI applet).
# pkgrel 7: migrate EXISTING users on upgrade. hyprland.conf ships via /etc/skel,
# which only seeds NEW accounts, so pkgrel 6's fixes + tray exec-once never
# reached an already-installed user (new binaries present, but nothing starts
# them and the old dwindle/togglesplit errors persist). New .install scriptlet
# edits each existing user's ~/.config/hypr/hyprland.conf in place: drops the
# removed pseudotile line, routes togglesplit via layoutmsg, and appends the tray
# exec-once + popup windowrule + SUPER-tap launcher if missing. Idempotent, backs
# the file up once (.genesi-bak), only touches Genesi's shipped config, preserves
# ownership. So now `pacman -Syu` (or the update notifier) + `hyprctl reload`
# brings a running install fully up to date — no reinstall.
pkgrel=7
pkgdesc='Genesi OS Hyprland + caelestia-shell default configuration and branding'
arch=('any')
url='https://github.com/zFreshy/GenesiOS'
license=('GPL-3.0-or-later')
depends=(
    'hyprland'
    'caelestia-shell'
    'genesi-settings'          # ships /usr/share/wallpapers/genesi/wallpaper.png
    'genesi-update'            # `genesi-update --tray` SNI applet, started from
                               # hyprland.conf (Hyprland ignores xdg/autostart)
    'genesi-ai-mode'           # `genesi-ai-tray` SNI applet (AI Mode widget)
    'genesi-containers'        # `genesi-containers-tray` SNI applet
    'polkit-kde-agent'
    'foot'                     # $terminal in hyprland.conf — no-GL Wayland term
                               # that renders in VMs (kitty needs OpenGL -> crash)
    'dolphin'                  # $fileManager
    'fuzzel'                   # launcher fallback + clipboard picker
    'cliphist'
    'wl-clipboard'
    'brightnessctl'
    'qt6ct'
    'papirus-icon-theme'       # app icons for the launcher/menus (no icon theme
                               # shipped before -> magenta "missing icon" squares)
)
install='genesi-caelestia-settings.install'
source=('hyprland.conf' 'qt6ct.conf' 'kdeglobals' 'gtk-settings.ini')
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    # Default Hyprland config for new users. Hyprland reads
    # ~/.config/hypr/hyprland.conf; shipping it via /etc/skel means the users
    # module (Calamares) copies it into /home/<user> at account creation.
    install -Dm644 "${srcdir}/hyprland.conf" \
        "${pkgdir}/etc/skel/.config/hypr/hyprland.conf"

    # Icon theme for new users (Papirus-Dark). Set it for Qt6 (qt6ct is the
    # platform theme via QT_QPA_PLATFORMTHEME in hyprland.conf), for Quickshell/
    # KDE-framework icon lookups (kdeglobals), and for GTK apps (dolphin, etc.).
    # Without this, caelestia's launcher shows magenta placeholders for app icons.
    # Safe in /etc/skel: genesi-kde-settings deliberately strips its own skel.
    install -Dm644 "${srcdir}/qt6ct.conf" \
        "${pkgdir}/etc/skel/.config/qt6ct/qt6ct.conf"
    install -Dm644 "${srcdir}/kdeglobals" \
        "${pkgdir}/etc/skel/.config/kdeglobals"
    install -Dm644 "${srcdir}/gtk-settings.ini" \
        "${pkgdir}/etc/skel/.config/gtk-3.0/settings.ini"
}
