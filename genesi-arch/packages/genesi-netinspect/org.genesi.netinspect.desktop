[Desktop Entry]
Type=Application
Name=Genesi API Inspector
GenericName=HTTP/HTTPS Interception Proxy
Comment=Intercept, edit, replay & fuzz HTTP/HTTPS & API traffic (Burp-style, powered by mitmproxy)
Exec=genesi-netinspect-gui
Icon=network-wired
Terminal=false
Categories=Development;Network;Security;
Keywords=proxy;mitmproxy;http;https;api;intercept;burp;repeater;intruder;scanner;debug;network;
StartupNotify=true
Actions=web;trustca;

[Desktop Action web]
Name=Classic mitmweb UI
Exec=konsole --hold -e genesi-netinspect web

[Desktop Action trustca]
Name=Trust HTTPS interception certificate
Exec=konsole --hold -e genesi-netinspect cert
