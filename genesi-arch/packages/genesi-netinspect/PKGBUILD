# Maintainer: Genesi OS Team <dev@genesios.org>
#
# Phase 4.5 — Network inspection. "Genesi API Inspector": a full HTTP/HTTPS
# interception workbench (the free, scriptable Burp-Suite equivalent on Linux)
# built on mitmproxy. pkgrel 3 ships a NATIVE Genesi UI built directly on
# mitmproxy's Python addon API (PySide6/Kirigami, same identity as the AI
# Monitor): four Burp-style lanes — Proxy/Intercept, Repeater, Intruder (Sniper
# fuzzing) and a passive Scanner — with mitmproxy running in-process as the
# engine. The classic mitmweb UI stays available via `genesi-netinspect web`.
# `genesi-netinspect cert` still trusts the mitmproxy CA system-wide, and
# `genesi-proxy on|off|toggle` flips the desktop proxy.
# pkgrel 4: two real fixes. (1) The passive Scanner never delivered findings —
# the addon emitted a `scannerFinding` signal that was never declared on the
# Backend, so it raised AttributeError and the QML handler bound to nothing;
# now declared. (2) Port resilience — if 8080 is busy (e.g. a docker container
# already publishes -p 8080:80) the engine now hops to the next free port
# (8081, 8082, …) and reports the REAL bound port to the desktop proxy + UI,
# instead of dying with "address already in use".
# pkgrel 5: visual identity pass — drop the placeholder emoji (🛰🔎🔁🎯🛡) for
# a crafted Genesi SVG icon set (app/icons/, brand-green accented line icons)
# in the header + nav rail. Adds qt6-svg so QtQuick Image renders them.
# pkgrel 6: (1) taskbar identity — setDesktopFileName + StartupWMClass +
# a real app icon (genesi-netinspect.svg) so the window shows our name/logo
# instead of "python3". (2) Neutral system-dark surfaces (green is now an
# accent only, not the whole background). (3) Guard the asyncio shutdown so
# closing the window no longer prints "RuntimeError: Event loop is closed".
pkgname=genesi-netinspect
pkgver=1.0.0
# pkgrel 7: app surfaces now use the Genesi system blue (the desktop's window
# colour) instead of the neutral grey, so the app matches the rest of the OS.
# pkgrel 8: don't crash on launch via the Darkly style. Like the Monitor and
# Sandboxes, this Qt6/QML app picked up the org.kde.desktop QQC2 style, which
# delegates drawing to Darkly — and Darkly6 SIGSEGVs from QML (null QWidget* in
# drawControl). Force the Fusion QQC2 style (self-drawn, dark via the kde
# platform theme) and fall back to the software backend in a VM.
# pkgrel 9: UI polish pass on the shared kit. (1) GlassCard finally moves off its
# leftover green-tinted surface to the Genesi system blue (#122E42), completing
# pkgrel 7's "match the rest of the OS" intent — it was the last holdout. (2) It
# gained shader-free depth (top sheen + bottom shade), an animated hover lift +
# brighten. Kept SHADER-FREE so it still renders under the software backend in
# VMs. Same GlassCard upgrade landed in the AI Monitor + Sandboxes.
pkgrel=9
pkgdesc='Genesi API Inspector — native Burp-style HTTP/HTTPS interception workbench (mitmproxy)'
arch=('any')
url='https://github.com/zFreshy/GenesiOS'
license=('GPL-3.0-or-later')
depends=('mitmproxy' 'python' 'pyside6' 'qqc2-desktop-style' 'qt6-svg')
optdepends=(
    'konsole: terminal for the classic mitmweb UI and cert trust'
    'kdialog: graphical error when mitmproxy is missing'
    'libnotify: desktop notification on proxy toggle'
)
source=()
sha256sums=()

package() {
    install -Dm755 "${startdir}/genesi-proxy" \
        "$pkgdir/usr/local/bin/genesi-proxy"
    install -Dm755 "${startdir}/genesi-netinspect" \
        "$pkgdir/usr/local/bin/genesi-netinspect"
    install -Dm755 "${startdir}/genesi-netinspect-gui" \
        "$pkgdir/usr/local/bin/genesi-netinspect-gui"

    # Native GUI app (PySide6 + Kirigami over mitmproxy's addon API)
    install -Dm644 "${startdir}/app/genesi_netinspect.py" \
        "$pkgdir/usr/share/genesi-netinspect/app/genesi_netinspect.py"
    install -Dm644 "${startdir}/app/Main.qml" \
        "$pkgdir/usr/share/genesi-netinspect/app/Main.qml"
    install -Dm644 "${startdir}/app/Theme.qml" \
        "$pkgdir/usr/share/genesi-netinspect/app/Theme.qml"
    install -Dm644 "${startdir}/app/GlassCard.qml" \
        "$pkgdir/usr/share/genesi-netinspect/app/GlassCard.qml"

    # Crafted SVG icon set (header logo + Proxy/Repeater/Intruder/Scanner)
    for ic in "${startdir}/app/icons/"*.svg; do
        install -Dm644 "$ic" \
            "$pkgdir/usr/share/genesi-netinspect/app/icons/$(basename "$ic")"
    done

    install -Dm644 "${startdir}/org.genesi.netinspect.desktop" \
        "$pkgdir/usr/share/applications/org.genesi.netinspect.desktop"
    # Branded app icon (the inspector magnifier logo) for the taskbar / menu
    install -Dm644 "${startdir}/app/icons/logo.svg" \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/genesi-netinspect.svg"
    install -Dm644 "${startdir}/org.genesi.proxy-toggle.desktop" \
        "$pkgdir/usr/share/applications/org.genesi.proxy-toggle.desktop"
}
