#!/usr/bin/env bash
#
# Genesi OS — DEV / TESTE ONLY  (NÃO é pra usuário final, NÃO vai pro sistema
# instalado). Prepara, NA SESSÃO LIVE (overlay em RAM), o driver NVIDIA aberto +
# CUDA pra você validar o Genesi Turbo speculative decoding sob um driver maduro
# (CUDA) — o cenário que NÃO dá pra testar no NVK/nouveau.
#
# Faz TODOS os passos de uma vez:
#   1. confere que você bootou pela entrada DEV (nouveau bloqueado);
#   2. instala o módulo NVIDIA aberto (dkms) p/ o kernel em uso + nvidia-utils;
#   3. carrega nvidia + nvidia_uvm e valida com nvidia-smi;
#   4. instala o stack CUDA do ollama (ollama-cuda) e liga o serviço;
#   5. compila o backend CUDA do Turbo (llama.cpp-cuda via AUR) — opcional, pesado.
#
# Depois disso só falta TESTAR O TURBO: abra o Genesi AI Monitor, ligue o Turbo
# (e o ⚡ speculative), ou rode:  genesi-ai-turbo bench qwen2.5:7b
#
# Tudo vive em RAM e SOME no reboot. Rode como usuário normal (ele usa sudo onde
# precisa; o build do AUR precisa rodar como não-root).
set -uo pipefail

say()  { printf '\n\033[1;32m:: %s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m[!] %s\033[0m\n' "$*"; }
die()  { printf '\033[1;31m[x] %s\033[0m\n' "$*"; exit 1; }

[[ $EUID -eq 0 ]] && warn "Rodando como root: o backend CUDA do Turbo (AUR) será PULADO (makepkg não roda como root). Rode como usuário normal pra incluí-lo."

SUDO=""
[[ $EUID -ne 0 ]] && SUDO="sudo"

say "Genesi DEV/TESTE — setup NVIDIA + CUDA (sessão live, em RAM)"

# 1) nouveau precisa estar bloqueado (entrada de boot DEV) senão o módulo NVIDIA
#    não consegue assumir a GPU e não há reboot pra corrigir (overlay some).
if lsmod | grep -q '^nouveau'; then
    die "nouveau ainda está carregado. Reinicie e escolha a entrada de boot \
'Genesi OS [DEV/TESTE] NVIDIA + CUDA' (ela passa module_blacklist=nouveau)."
fi

# 2) cabeçalhos do kernel EM USO (linux-cachyos vs -lts) p/ o dkms compilar.
KREL="$(uname -r)"
case "$KREL" in
    *-lts*) HEADERS="linux-cachyos-lts-headers" ;;
    *)      HEADERS="linux-cachyos-headers" ;;
esac
say "Kernel em uso: $KREL  →  headers: $HEADERS"

say "Atualizando bancos de pacotes…"
$SUDO pacman -Sy --noconfirm || die "pacman -Sy falhou"

say "Instalando driver NVIDIA aberto (dkms) + utils… (compila o módulo, ~1-3 min)"
$SUDO pacman -S --needed --noconfirm dkms "$HEADERS" nvidia-open-dkms nvidia-utils \
    || die "falha ao instalar o driver NVIDIA"

# 3) carrega os módulos (sem reboot). nvidia_uvm é o que o CUDA usa de fato.
say "Carregando módulos NVIDIA…"
$SUDO modprobe nvidia        || die "modprobe nvidia falhou (veja: dmesg | grep -i nvidia)"
$SUDO modprobe nvidia_uvm    || warn "nvidia_uvm não carregou — CUDA pode não funcionar"
$SUDO modprobe nvidia_drm modeset=1 2>/dev/null || true

if ! nvidia-smi; then
    die "nvidia-smi não respondeu — o driver não inicializou. Veja: dmesg | grep -i nvidia"
fi
say "nvidia-smi OK — GPU pronta para CUDA."

# 4) stack CUDA do ollama (validação rápida via genesi-ai-mode bench).
say "Instalando ollama-cuda (puxa o CUDA, ~5-6 GB)…"
$SUDO pacman -Rdd --noconfirm ollama 2>/dev/null || true   # evita conflito ollama↔ollama-cuda
if $SUDO pacman -S --needed --noconfirm ollama-cuda; then
    $SUDO systemctl enable --now ollama 2>/dev/null || true
    say "ollama-cuda instalado e serviço ligado."
else
    warn "ollama-cuda não instalou — siga só com o backend do Turbo abaixo."
fi

# 5) backend CUDA do Turbo: llama.cpp-cuda (AUR). Pesado e PRECISA rodar como
#    usuário normal (makepkg recusa root). Sem isso o Turbo cai no Vulkan.
if [[ $EUID -ne 0 ]] && command -v paru >/dev/null 2>&1; then
    say "Compilando backend CUDA do Turbo (llama.cpp-cuda via AUR)… pode demorar bastante"
    paru -S --needed --noconfirm llama.cpp-cuda \
        || warn "build do llama.cpp-cuda falhou — dá pra tentar depois pelo botão CUDA do Monitor"
elif [[ $EUID -ne 0 ]] && command -v yay >/dev/null 2>&1; then
    say "Compilando backend CUDA do Turbo (llama.cpp-cuda via AUR/yay)…"
    yay -S --needed --noconfirm llama.cpp-cuda \
        || warn "build do llama.cpp-cuda falhou — tente depois pelo botão CUDA do Monitor"
else
    warn "Sem helper do AUR (paru/yay) como usuário normal — o backend CUDA do Turbo \
não foi compilado. Use o botão 'Instalar Backend → CUDA' no Genesi AI Monitor."
fi

cat <<'EOF'

============================================================
 PRONTO. Agora é só TESTAR O TURBO:
   • Abra o "Genesi AI Monitor", ligue o Turbo e o ⚡ speculative; ou
   • Terminal:  genesi-ai-turbo bench qwen2.5:7b
 (compare spec vs no-spec — agora sob CUDA, não NVK)

 Lembrete: tudo isto está em RAM e some ao reiniciar (sessão live DEV).
============================================================
EOF
