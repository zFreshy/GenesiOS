#!/usr/bin/env python3
"""
Genesi OS Welcome App
A simple welcome application for Genesi OS that replaces cachyos-hello.
"""

import subprocess
import sys
import os

try:
    from PyQt6.QtWidgets import (
        QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
        QLabel, QPushButton, QFrame, QCheckBox, QSpacerItem, QSizePolicy
    )
    from PyQt6.QtCore import Qt, QSize
    from PyQt6.QtGui import QPixmap, QFont, QIcon, QPalette, QColor
except ImportError:
    try:
        from PyQt5.QtWidgets import (
            QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
            QLabel, QPushButton, QFrame, QCheckBox, QSpacerItem, QSizePolicy
        )
        from PyQt5.QtCore import Qt, QSize
        from PyQt5.QtGui import QPixmap, QFont, QIcon, QPalette, QColor
    except ImportError:
        print("Error: PyQt6 or PyQt5 is required.")
        sys.exit(1)


VERDE_GENESIS = "#1D9E75"
VERDE_PROFUNDO = "#0F6E56"
AZUL_OCEAN = "#185FA5"
AZUL_CEU = "#378ADD"
CARVAO = "#2C2C2A"
FLORESTA = "#04342C"
MENTA = "#E1F5EE"
AREIA = "#F1EFE8"

STYLESHEET = f"""
QMainWindow {{
    background-color: {FLORESTA};
}}
QWidget#central {{
    background-color: {FLORESTA};
}}
QLabel#title {{
    color: {MENTA};
    font-size: 28px;
    font-weight: bold;
}}
QLabel#subtitle {{
    color: {VERDE_GENESIS};
    font-size: 14px;
}}
QLabel#description {{
    color: {MENTA};
    font-size: 13px;
    line-height: 1.5;
}}
QLabel#sectionTitle {{
    color: {VERDE_GENESIS};
    font-size: 16px;
    font-weight: bold;
    padding-top: 10px;
}}
QPushButton {{
    background-color: {VERDE_GENESIS};
    color: {FLORESTA};
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: bold;
    min-width: 180px;
}}
QPushButton:hover {{
    background-color: {VERDE_PROFUNDO};
}}
QPushButton#secondary {{
    background-color: transparent;
    color: {VERDE_GENESIS};
    border: 2px solid {VERDE_GENESIS};
}}
QPushButton#secondary:hover {{
    background-color: rgba(29, 158, 117, 0.1);
}}
QFrame#separator {{
    background-color: rgba(29, 158, 117, 0.3);
    max-height: 1px;
}}
QCheckBox {{
    color: {MENTA};
    font-size: 12px;
    spacing: 8px;
}}
QCheckBox::indicator {{
    width: 18px;
    height: 18px;
}}
"""


def run_command(cmd):
    """Run a shell command."""
    try:
        subprocess.Popen(cmd, shell=True)
    except Exception as e:
        print(f"Error running command: {e}")


class GenesiWelcome(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Welcome to Genesi OS")
        self.setFixedSize(700, 600)
        self.setStyleSheet(STYLESHEET)

        central = QWidget()
        central.setObjectName("central")
        self.setCentralWidget(central)

        layout = QVBoxLayout(central)
        layout.setContentsMargins(40, 30, 40, 30)
        layout.setSpacing(12)

        # Logo + Title
        header = QHBoxLayout()
        logo_path = "/usr/share/wallpapers/genesi/logo.png"
        if os.path.exists(logo_path):
            logo_label = QLabel()
            pixmap = QPixmap(logo_path).scaled(
                64, 64, Qt.AspectRatioMode.KeepAspectRatio,
                Qt.TransformationMode.SmoothTransformation
            )
            logo_label.setPixmap(pixmap)
            header.addWidget(logo_label)

        title_layout = QVBoxLayout()
        title = QLabel("Welcome to Genesi OS")
        title.setObjectName("title")
        title_layout.addWidget(title)

        subtitle = QLabel("A developer-first operating system")
        subtitle.setObjectName("subtitle")
        title_layout.addWidget(subtitle)

        header.addLayout(title_layout)
        header.addStretch()
        layout.addLayout(header)

        # Separator
        sep = QFrame()
        sep.setObjectName("separator")
        sep.setFrameShape(QFrame.Shape.HLine)
        layout.addWidget(sep)

        # Description
        desc = QLabel(
            "Genesi OS is built on top of Arch Linux and CachyOS technologies,\n"
            "optimized for developers and AI workloads. It features a custom\n"
            "KDE Plasma desktop with performance-tuned kernel and tools."
        )
        desc.setObjectName("description")
        desc.setWordWrap(True)
        layout.addWidget(desc)

        # Quick Actions section
        section = QLabel("Quick Actions")
        section.setObjectName("sectionTitle")
        layout.addWidget(section)

        # Buttons grid
        btn_row1 = QHBoxLayout()
        btn_row1.setSpacing(12)

        install_btn = QPushButton("  Install Genesi OS")
        install_btn.clicked.connect(lambda: run_command("sudo calamares-online.sh"))
        btn_row1.addWidget(install_btn)

        terminal_btn = QPushButton("  Open Terminal")
        terminal_btn.setObjectName("secondary")
        terminal_btn.clicked.connect(lambda: run_command("konsole"))
        btn_row1.addWidget(terminal_btn)

        layout.addLayout(btn_row1)

        btn_row2 = QHBoxLayout()
        btn_row2.setSpacing(12)

        files_btn = QPushButton("  File Manager")
        files_btn.setObjectName("secondary")
        files_btn.clicked.connect(lambda: run_command("dolphin"))
        btn_row2.addWidget(files_btn)

        settings_btn = QPushButton("  System Settings")
        settings_btn.setObjectName("secondary")
        settings_btn.clicked.connect(lambda: run_command("systemsettings"))
        btn_row2.addWidget(settings_btn)

        layout.addLayout(btn_row2)

        btn_row3 = QHBoxLayout()
        btn_row3.setSpacing(12)

        browser_btn = QPushButton("  Web Browser")
        browser_btn.setObjectName("secondary")
        browser_btn.clicked.connect(lambda: run_command("firefox"))
        btn_row3.addWidget(browser_btn)

        github_btn = QPushButton("  GitHub Project")
        github_btn.setObjectName("secondary")
        github_btn.clicked.connect(
            lambda: run_command("xdg-open https://github.com/zFreshy/GenesiOS")
        )
        btn_row3.addWidget(github_btn)

        layout.addLayout(btn_row3)

        # Spacer
        layout.addStretch()

        # Separator
        sep2 = QFrame()
        sep2.setObjectName("separator")
        sep2.setFrameShape(QFrame.Shape.HLine)
        layout.addWidget(sep2)

        # Footer
        footer = QHBoxLayout()

        autostart_cb = QCheckBox("Show this window on startup")
        autostart_cb.setChecked(True)
        autostart_cb.stateChanged.connect(self.toggle_autostart)
        footer.addWidget(autostart_cb)

        footer.addStretch()

        version_label = QLabel("Genesi OS v0.1.0-alpha")
        version_label.setObjectName("description")
        version_label.setStyleSheet(f"color: rgba(225, 245, 238, 0.5); font-size: 11px;")
        footer.addWidget(version_label)

        layout.addLayout(footer)

    def toggle_autostart(self, state):
        """Enable or disable autostart."""
        autostart_dir = os.path.expanduser("~/.config/autostart")
        autostart_file = os.path.join(autostart_dir, "genesi-welcome.desktop")

        if state == 2:  # Checked
            os.makedirs(autostart_dir, exist_ok=True)
            with open(autostart_file, "w") as f:
                f.write("[Desktop Entry]\n")
                f.write("Type=Application\n")
                f.write("Name=Genesi OS Welcome\n")
                f.write("Exec=genesi-welcome\n")
                f.write("Hidden=false\n")
                f.write("X-KDE-autostart-after=panel\n")
        else:
            if os.path.exists(autostart_file):
                os.remove(autostart_file)


def main():
    app = QApplication(sys.argv)
    app.setApplicationName("Genesi OS Welcome")
    app.setDesktopFileName("genesi-welcome")

    window = GenesiWelcome()
    window.show()

    sys.exit(app.exec())


if __name__ == "__main__":
    main()
