[org.kde.kdecoration2]
BorderSize=None
BorderSizeAuto=false
ButtonsOnLeft=XIA
ButtonsOnRight=
library=org.kde.klassy
theme=Klassy

[Compositing]
Backend=OpenGL
Enabled=true
GLCore=true
GLPreferBufferSwap=a
GLTextureFilter=2
HiddenPreviews=5
OpenGLIsUnsafe=false
WindowsBlockCompositing=true
AnimationSpeed=3

[Effect-blur]
BlurStrength=12
NoiseStrength=2

[Effect-slide]
Duration=200
HorizontalGap=0
VerticalGap=0

[Effect-fadingpopups]
FadeDuration=100

[Effect-translucency]
Inactive=90
MoveResize=80

[Plugins]
blurEnabled=true
contrastEnabled=true
slideEnabled=true
fadingpopupsEnabled=true
translucencyEnabled=true
dimscreenEnabled=true

[Windows]
Placement=Centered
FocusPolicy=ClickToFocus
AutoRaise=false
DelayFocusInterval=300
RollOverDesktops=true

[TabBox]
LayoutName=thumbnail_grid
