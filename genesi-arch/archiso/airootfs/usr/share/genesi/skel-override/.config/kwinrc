[org.kde.kdecoration2]
BorderSize=Normal
BorderSizeAuto=false
ButtonsOnLeft=XIA
ButtonsOnRight=
library=org.kde.kdecoration3
theme=Breeze

[Compositing]
Backend=OpenGL
Enabled=true
GLCore=true
GLPreferBufferSwap=a
GLTextureFilter=2
HiddenPreviews=5
OpenGLIsUnsafe=false
WindowsBlockCompositing=true
AnimationSpeed=3

[Effect-Blur]
BlurStrength=12
NoiseStrength=3

[Effect-slide]
Duration=200
HorizontalGap=0
VerticalGap=0

[Effect-fadingpopups]
FadeDuration=100

[Effect-Translucency]
ActiveOpacity=85
InactiveOpacity=85

[Plugins]
blurEnabled=true
translucencyEnabled=true
forceblurEnabled=true
kwin4_effect_translucencyEnabled=true

[Windows]
Placement=Centered
FocusPolicy=ClickToFocus
AutoRaise=false
DelayFocusInterval=300
RollOverDesktops=true

[TabBox]
LayoutName=thumbnail_grid
