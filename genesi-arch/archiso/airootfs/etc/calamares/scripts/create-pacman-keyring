#!/usr/bin/env bash
# SPDX-FileCopyrightText: no
# SPDX-License-Identifier: CC0-1.0
#
# Genesi OS - create-pacman-keyring script
# Initializes pacman keyring for package verification

set -e

echo ">>> Genesi OS: Creating pacman keyring..."

# Remove old keyring if it exists
rm -rf /etc/pacman.d/gnupg

# Initialize new keyring
pacman-key --init

# Populate with Arch Linux keys
pacman-key --populate archlinux

# If CachyOS keyring is available, populate it too (for kernel packages)
if pacman-key --list-keys cachyos 2>/dev/null; then
    echo ">>> Populating CachyOS keyring..."
    pacman-key --populate cachyos
fi

echo ">>> Pacman keyring created successfully"
exit 0
