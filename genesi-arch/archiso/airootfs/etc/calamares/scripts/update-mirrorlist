#!/usr/bin/env bash
# SPDX-FileCopyrightText: no
# SPDX-License-Identifier: CC0-1.0
#
# Genesi OS - update-mirrorlist script
# Updates and ranks mirrors for optimal download speed

set -e

echo ">>> Genesi OS: Updating mirrorlist..."

# Create mirrorlist directory if it doesn't exist
mkdir -p /etc/pacman.d

# Create Genesi mirrorlist (using GitHub releases as mirror)
cat > /etc/pacman.d/genesi-mirrorlist << 'EOF'
##
## Genesi OS repository mirrorlist
##

# GitHub Releases (Primary)
Server = https://github.com/zFreshy/genesi-pkgbuilds/releases/download/packages/$arch

# Fallback to Arch mirrors for base packages
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
EOF

# Also update the main Arch mirrorlist if needed
if [ ! -f /etc/pacman.d/mirrorlist ] || [ ! -s /etc/pacman.d/mirrorlist ]; then
    echo ">>> Creating Arch mirrorlist..."
    cat > /etc/pacman.d/mirrorlist << 'EOF'
##
## Arch Linux repository mirrorlist
##

Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirror.osbeck.com/archlinux/$repo/os/$arch
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
EOF
fi

echo ">>> Mirrorlist updated successfully"
exit 0
