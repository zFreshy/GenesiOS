#!/usr/bin/env bash
# SPDX-FileCopyrightText: no
# SPDX-License-Identifier: CC0-1.0
#
# Genesi OS - remove-ucode script
# Removes unnecessary microcode packages (keeps only the one for current CPU)

set -e

echo ">>> Genesi OS: Removing unnecessary microcode..."

# Detect CPU vendor
if grep -q "GenuineIntel" /proc/cpuinfo; then
    echo ">>> Intel CPU detected, removing AMD microcode..."
    pacman -Rns --noconfirm amd-ucode 2>/dev/null || true
elif grep -q "AuthenticAMD" /proc/cpuinfo; then
    echo ">>> AMD CPU detected, removing Intel microcode..."
    pacman -Rns --noconfirm intel-ucode 2>/dev/null || true
else
    echo ">>> Unknown CPU, removing all microcode..."
    pacman -Rns --noconfirm amd-ucode intel-ucode 2>/dev/null || true
fi

echo ">>> Microcode cleanup complete"
exit 0
