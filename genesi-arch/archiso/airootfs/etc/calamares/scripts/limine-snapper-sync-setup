#!/usr/bin/env bash
# SPDX-FileCopyrightText: no
# SPDX-License-Identifier: CC0-1.0
#
# Genesi OS - limine-snapper-sync-setup script
# Configures Limine bootloader with snapper integration (if using Limine)

set -e

echo ">>> Genesi OS: Configuring Limine bootloader..."

# Check if Limine is installed
if ! command -v limine &> /dev/null; then
    echo ">>> Limine not installed, skipping..."
    exit 0
fi

# Check if snapper is installed
if command -v snapper &> /dev/null; then
    echo ">>> Configuring Limine with Snapper integration..."
    
    # Install limine-mkinitcpio-hook if available
    if pacman -Ss limine-mkinitcpio-hook &> /dev/null; then
        pacman -S --noconfirm --needed limine-mkinitcpio-hook 2>/dev/null || true
    fi
    
    # Configure snapper-sync if available
    if [ -f /etc/limine-snapper-sync.conf ]; then
        echo ">>> Limine-snapper-sync configured"
    fi
fi

echo ">>> Limine configuration complete"
exit 0
