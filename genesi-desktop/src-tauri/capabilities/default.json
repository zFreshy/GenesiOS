{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "opener:default",
    "store:default",
    "shell:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "start-chrome",
          "cmd": "cmd",
          "args": ["/c", "start", "chrome"]
        }
      ]
    }
  ]
}
