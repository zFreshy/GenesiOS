{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "opener:default",
    "store:default",
    "shell:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "start-browser-windows",
          "cmd": "cmd",
          "args": ["/c", "start", "msedge"]
        },
        {
          "name": "open-firefox-linux",
          "cmd": "firefox",
          "args": true
        },
        {
          "name": "open-epiphany-linux",
          "cmd": "epiphany",
          "args": true
        },
        {
          "name": "open-path",
          "cmd": "cmd",
          "args": true
        },
        {
          "name": "powershell",
          "cmd": "powershell",
          "args": true
        },
        {
          "name": "taskkill",
          "cmd": "taskkill",
          "args": true
        }
      ]
    }
  ]
}
