# Shell scripts and CI workflows MUST stay LF: a CRLF shebang breaks under
# bash on Linux (CI runs in a CachyOS container). Force LF regardless of the
# committer's OS / core.autocrlf setting.
*.sh   text eol=lf
*.bash text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
# PKGBUILDs and .install scriptlets are sourced by bash/makepkg in the
# CachyOS CI container; a stray CRLF appends \r to array values (e.g.
# depends=("qt6-svg\r")) and breaks dependency resolution. Keep them LF.
PKGBUILD   text eol=lf
*.install  text eol=lf

# Extensionless scripts + Linux runtime configs that have no global rule above.
# The AI Mode daemon (Python) and CLI (bash) run on Linux; a CRLF shebang would
# yield `bad interpreter: ...^M`. systemd units, sysctl and tmpfiles configs
# also choke on a trailing \r in their values. Keep them all LF.
genesi-arch/packages/genesi-ai-mode/genesi-aid             text eol=lf
genesi-arch/packages/genesi-ai-mode/genesi-ai-mode         text eol=lf
genesi-arch/packages/genesi-ai-mode/genesi-ai-kwin-helper  text eol=lf
genesi-arch/packages/genesi-ai-mode/monitor/genesi-ai-monitor text eol=lf
*.service     text eol=lf
*.conf        text eol=lf
*.tmpfiles    text eol=lf
*.hook        text eol=lf
# Python is run on Linux, QML is parsed by Qt, .desktop by the XDG stack — all
# happier as LF, and it keeps the extensionless launchers above consistent.
*.py          text eol=lf
*.qml         text eol=lf
*.desktop     text eol=lf
